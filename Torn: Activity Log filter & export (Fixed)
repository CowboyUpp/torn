    }

    function findNativeSearch(root) {
        return [...root.querySelectorAll('input[type="search"],input[type="text"]')].find((input) => {
            if (input.id === SEARCH_ID || input.closest('#' + UI_ID)) return false;
            const hint = (input.placeholder || input.getAttribute('aria-label') || '').toLowerCase();
            return hint.includes('search') || hint.includes('filter');
        });
    }

    function concealNativeSearch(root) {
        findNativeSearch(root)?.classList.add('alf-native-search-hidden');
    }

    function findRows(root) {
        const preferred = [...root.querySelectorAll('tr,[class*="logRow___"]')];
        const candidates = preferred.length ? preferred : [...root.querySelectorAll('[class*="row___"]')];
        return [...new Set(candidates)].filter((row) =>
            !row.closest('#' + UI_ID) &&
            !String(row.className || '').toLowerCase().includes('title') &&
            row.querySelector('span.log-text,[id^="text-"],[class*="text___"]')
        );
    }

    function rowInfo(row) {
        const textElement = row.querySelector('span.log-text,[id^="text-"],[class*="text___"]');
        const timeElement = row.querySelector('td[class^="time"],[class*="time___"],time');
        const categoryElement = row.querySelector('[class*="category"],[class*="type___"],.category');
        const text = textElement?.textContent?.trim() || '';
        const timeText = timeElement?.textContent?.trim() || '';
        const categoryText = categoryElement?.textContent?.trim() || '';
        return {
            row,
            text,
            timeText,
            date: findSemanticDate(row, timeElement) || parseDisplayedDate(timeText),
            category: categoryText || 'Other',
            categoryDetected: Boolean(categoryText)
        };
    }

    function categoriesAreReliable(infos) {
        if (infos.length < 5) return true;
        const detected = infos.filter((info) => info.categoryDetected).length;
        return detected / infos.length >= 0.2;
    }

    function parseQuery(query) {
        const result = { includes: [], excludes: [], categories: [], has: [] };
        const matcher = /"([^"]+)"|(\S+)/g;
        let match;
        while ((match = matcher.exec(query))) {
            let token = match[1] ?? match[2];
            const quoted = match[1] != null;
            if (!quoted && token.startsWith('-') && token.length > 1) {
                result.excludes.push(token.slice(1).toLowerCase());
                continue;
            }
            const operator = !quoted && token.match(/^([a-z]+):(.*)$/i);
            if (operator?.[1].toLowerCase() === 'category') result.categories.push(operator[2].toLowerCase());
            else if (operator?.[1].toLowerCase() === 'has') result.has.push(operator[2].toLowerCase());
            else result.includes.push(token.toLowerCase());
        }
        return result;
    }

    function matchesHas(info, filter) {
        const text = info.text.toLowerCase();
        const category = info.category.toLowerCase();
        if (filter === 'money') return /[$£€]\s*[\d,.]+/.test(info.text) || category.includes('money');
        if (filter === 'item') return category.includes('item') || /\bused\b|\bbought\b|\bpurchased\b|\breceived\b/.test(text);
        if (filter === 'link') return Boolean(info.row.querySelector('a[href]'));
        return text.includes(filter) || category.includes(filter);
    }

    function rowMatches(info, query, categoriesReliable = true) {
        const haystack = (info.text + ' ' + info.category + ' ' + info.timeText).toLowerCase();
        if (query.includes.some((term) => !haystack.includes(term))) return false;
        if (query.excludes.some((term) => haystack.includes(term))) return false;
        if (categoriesReliable && query.categories.length && !query.categories.some((term) => info.category.toLowerCase().includes(term))) return false;
        if (query.has.some((filter) => !matchesHas(info, filter))) return false;
        if (categoriesReliable && state.categories.size && ![...state.categories].some((category) => category.toLowerCase() === info.category.toLowerCase())) return false;

        const from = parseDateValue(state.from);
        const to = parseDateValue(state.to, true);
        if ((from || to) && !info.date) return false;
        if (from && info.date < from) return false;
        if (to && info.date > to) return false;
        return true;
    }

    function sortRows(infos, direction = state.sort) {
        const groups = new Map();
        for (const info of infos) {
            const parent = info.row.parentElement;
            if (!parent) continue;
            if (!groups.has(parent)) groups.set(parent, []);
            groups.get(parent).push(info);
        }
        for (const [container, group] of groups) {
            const dated = group.filter((info) => info.date);
            if (dated.length < 2) continue;
            const desired = dated.map((info, index) => ({ info, index })).sort((a, b) =>
                (direction === 'oldest' ? a.info.date - b.info.date : b.info.date - a.info.date)
                    || a.index - b.index
            ).map((entry) => entry.info);
            if (desired.every((info, index) => info.row === dated[index].row)) continue;
            const children = [...container.children];
            const indexes = dated.map((info) => children.indexOf(info.row));
            if (indexes.some((index) => index < 0)) continue;
            indexes.forEach((childIndex, index) => { children[childIndex] = desired[index].row; });
            container.replaceChildren(...children);
        }
    }

    function refreshCategories(ui, infos, categoriesReliable) {
        ui.querySelector('.alf-category-warning').hidden = categoriesReliable;
        const categories = [...new Set([
            ...state.categories,
            ...infos.filter((info) => info.categoryDetected).map((info) => info.category)
        ])].sort((a, b) => a.localeCompare(b));
        const list = ui.querySelector('.alf-category-list');
        const signature = categories.join('\u0000') + '|' + String(categoriesReliable);
        if (list.dataset.signature === signature) {
            list.querySelectorAll('input').forEach((input) => {
                input.checked = state.categories.has(input.value);
                input.disabled = !categoriesReliable;
            });
            return;
        }
        list.dataset.signature = signature;
        list.replaceChildren();
        for (const category of categories) {
            const label = document.createElement('label');
            label.className = 'alf-check';
            const checkbox = document.createElement('input');
            checkbox.type = 'checkbox';
            checkbox.value = category;
            checkbox.checked = state.categories.has(category);
            checkbox.disabled = !categoriesReliable;
            const text = document.createElement('span');
            text.textContent = category;
            label.append(checkbox, text);
            list.append(label);
        }
        if (!categories.length && categoriesReliable) {
            const empty = document.createElement('span');
            empty.textContent = 'Categories appear when logs load.';
            empty.style.color = '#888';
            list.append(empty);
        }
    }

    function renderChips(ui) {
        const chips = ui.querySelector('.alf-chips');
        const entries = [];
        if (state.query) entries.push({ type: 'query', value: '', label: 'Search: ' + state.query });
        if (state.dateLabel !== 'All time') entries.push({ type: 'date', value: '', label: state.dateLabel });
        state.categories.forEach((category) => entries.push({ type: 'category', value: category, label: category }));
        const signature = JSON.stringify(entries);
        if (chips.dataset.signature === signature) {
            ui.querySelector('.alf-clear-all').hidden = entries.length === 0;
            ui.querySelector('.alf-count-badge').textContent = String(state.categories.size);
            return;
        }
        chips.dataset.signature = signature;
        chips.replaceChildren();
        for (const entry of entries) {
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'alf-chip';
            button.dataset.chipType = entry.type;
            button.dataset.chipValue = entry.value;
            button.textContent = entry.label + ' ×';
            chips.append(button);
        }
        ui.querySelector('.alf-clear-all').hidden = entries.length === 0;
        ui.querySelector('.alf-count-badge').textContent = String(state.categories.size);
    }

    function applyFilters() {
        renderScheduled = false;
        if (!matchMedia(DESKTOP_QUERY).matches) return;
        const root = document.querySelector(ROOT_SELECTOR);
        const ui = document.getElementById(UI_ID);
        if (!root || !ui) return;

        applyTheme(ui);
        syncTornControlStyle(ui, root);
        concealNativeSearch(root);
        const search = ui.querySelector('#' + SEARCH_ID);
        if (search.value !== state.query) search.value = state.query;
        ui.querySelector('.alf-date-label').textContent = state.dateLabel;
        const datePopover = ui.querySelector('.alf-date-popover');
        const editingRange = datePopover.classList.contains('alf-open')
            && ui.querySelector('.alf-tab.alf-active')?.dataset.tab === 'range';
        if (!editingRange) {
            ui.querySelector('.alf-from').value = state.from;
            ui.querySelector('.alf-to').value = state.to;
        }
        ui.querySelector('.alf-reverse-button').textContent = state.sort === 'oldest' ? '↕ Restore View' : '↕ Reverse View';
        if (!ui.querySelector('.alf-month').value) ui.querySelector('.alf-month').value = localDateValue(new Date()).slice(0, 7);
        if (!ui.querySelector('.alf-year').value) ui.querySelector('.alf-year').value = String(new Date().getUTCFullYear());
        if (!ui.querySelector('.alf-day').value) {
            ui.querySelector('.alf-day').value = state.from && state.from === state.to
                ? state.from
                : localDateValue(new Date());
        }

        const query = parseQuery(state.query);
        const infos = findRows(root).map(rowInfo);
        const categoriesReliable = categoriesAreReliable(infos);
        let visible = 0;
        for (const info of infos) {
            const matches = rowMatches(info, query, categoriesReliable);
            info.row.classList.toggle('alf-hidden', !matches);
            if (matches) visible += 1;
        }
        sortRows(infos);
        refreshCategories(ui, infos, categoriesReliable);
        renderChips(ui);
        ui.querySelector('.alf-meta').textContent = visible + ' of ' + infos.length + ' currently loaded';
    }

    function scheduleRender() {
        if (renderScheduled) return;
        renderScheduled = true;
        requestAnimationFrame(applyFilters);
    }

    function commitFilters() {
        saveState();
        closePopovers();
        scheduleRender();
    }

    function clearAll() {
        state.query = '';
        state.from = '';
        state.to = '';
        state.dateLabel = 'All time';
        state.categories.clear();
        commitFilters();
    }

    function closePopovers(except) {
        const ui = document.getElementById(UI_ID);
        if (!ui) return;
        ui.querySelectorAll('.alf-popover').forEach((popover) => {
            if (popover !== except) popover.classList.remove('alf-open');
        });
        ui.querySelectorAll('[aria-expanded="true"]').forEach((button) => {
            const expected = button.classList.contains('alf-date-button') ? 'alf-date-popover' : 'alf-filter-popover';
            if (!except?.classList.contains(expected)) button.setAttribute('aria-expanded', 'false');
        });
    }

    function togglePopover(button, popover) {
        const opening = !popover.classList.contains('alf-open');
        closePopovers(opening ? popover : null);
        popover.classList.toggle('alf-open', opening);
        button.setAttribute('aria-expanded', String(opening));
    }

    function setQuickRange(range) {
        const now = new Date();
        let from = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate()));
        let to = new Date(from);
        let label = 'All time';
        if (range === 'all') {
            state.from = '';
            state.to = '';
            state.dateLabel = label;
            commitFilters();
            return;
        }
        if (range === 'yesterday') {
            from.setUTCDate(from.getUTCDate() - 1);
            to = new Date(from);
            label = 'Yesterday';
        } else if (/^\d+days$/.test(range)) {
            const days = Number(range.replace('days', ''));
            from.setUTCDate(from.getUTCDate() - days + 1);
            label = 'Last ' + days + ' days';
        } else if (range === 'thismonth') {
            from = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), 1));
            to = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth() + 1, 0));
            label = 'This month';
        } else if (range === 'lastmonth') {
            from = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth() - 1, 1));
            to = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), 0));
            label = 'Last month';
        } else if (range === 'thisyear') {
            from = new Date(Date.UTC(now.getUTCFullYear(), 0, 1));
            to = new Date(Date.UTC(now.getUTCFullYear(), 11, 31));
            label = 'This year';
        } else {
            label = 'Today';
        }
        state.from = localDateValue(from);
        state.to = localDateValue(to);
        state.dateLabel = label;
        commitFilters();
    }

    function applyDatePanel(ui) {
        const mode = ui.querySelector('.alf-tab.alf-active')?.dataset.tab || 'day';
        if (mode === 'day') {
            const value = ui.querySelector('.alf-day').value;
            if (!value) return;
            const date = parseDateValue(value);
            state.from = value;
            state.to = value;
            state.dateLabel = date.toLocaleDateString(undefined, {
                day: 'numeric', month: 'short', year: 'numeric', timeZone: 'UTC'
            });
        } else if (mode === 'month') {
            const value = ui.querySelector('.alf-month').value;
            if (!value) return;
            const parts = value.split('-').map(Number);
            const from = new Date(Date.UTC(parts[0], parts[1] - 1, 1));
            const to = new Date(Date.UTC(parts[0], parts[1], 0));
            state.from = localDateValue(from);
            state.to = localDateValue(to);
            state.dateLabel = from.toLocaleDateString(undefined, { month: 'long', year: 'numeric', timeZone: 'UTC' });
        } else if (mode === 'year') {
            const year = Number(ui.querySelector('.alf-year').value);
            if (!year || year < 2004 || year > 2100) return;
            state.from = year + '-01-01';
            state.to = year + '-12-31';
            state.dateLabel = String(year);
        } else {
            state.from = ui.querySelector('.alf-from').value;
            state.to = ui.querySelector('.alf-to').value;
            state.dateLabel = formatRangeLabel(state.from, state.to);
        }
        commitFilters();
    }

    function csvCell(value) {
        let text = value == null ? '' : String(value).replace(/\r?\n/g, ' ');
        if (/^[=+\-@\t\r]/.test(text)) text = "'" + text;
        return '"' + text.replace(/"/g, '""') + '"';
    }

    function exportCsv() {
        const root = document.querySelector(ROOT_SELECTOR);
        if (!root) return;
        const rows = findRows(root)
            .filter((row) => !row.classList.contains('alf-hidden') && getComputedStyle(row).display !== 'none')
            .map(rowInfo);
        if (!rows.length) {
            alert('No currently visible activity-log entries are available to export.');
            return;
        }
        const csv = '\uFEFF' + [
            ['time', 'category', 'text'],
            ...rows.map((row) => [row.timeText || 'N/A', row.category, row.text])
        ].map((line) => line.map(csvCell).join(',')).join('\r\n') + '\r\n';
        const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const anchor = document.createElement('a');
        anchor.href = url;
        anchor.download = 'filtered_activity_log.csv';
        anchor.hidden = true;
        document.documentElement.append(anchor);
        anchor.click();
        anchor.remove();
        setTimeout(() => URL.revokeObjectURL(url), 1000);
    }

    function bindUi(ui) {
        const search = ui.querySelector('#' + SEARCH_ID);
        search.value = state.query;
        search.addEventListener('input', () => {
            state.query = search.value;
            saveState();
            scheduleRender();
        });
        ui.querySelector('.alf-clear-search').addEventListener('click', () => {
            state.query = '';
            commitFilters();
            search.focus();
        });
        ui.querySelector('.alf-clear-all').addEventListener('click', clearAll);
        ui.querySelector('.alf-reverse-button').addEventListener('click', () => {
            state.sort = state.sort === 'oldest' ? 'newest' : 'oldest';
            saveState();
            scheduleRender();
        });
        ui.querySelector('.alf-export-button').addEventListener('click', exportCsv);
        ui.querySelector('.alf-theme-button').addEventListener('click', () => {
            state.theme = state.theme === 'dark' ? 'light' : 'dark';
            saveState();
            applyTheme(ui);
            const root = document.querySelector(ROOT_SELECTOR);
            if (root) syncTornControlStyle(ui, root, true);
        });

        const dateButton = ui.querySelector('.alf-date-button');
        const datePopover = ui.querySelector('.alf-date-popover');
        dateButton.addEventListener('click', () => togglePopover(dateButton, datePopover));
        const filterButton = ui.querySelector('.alf-filter-button');
        const filterPopover = ui.querySelector('.alf-filter-popover');
        filterButton.addEventListener('click', () => togglePopover(filterButton, filterPopover));

        ui.querySelectorAll('.alf-tab').forEach((tab) => {
            tab.addEventListener('click', () => {
                ui.querySelectorAll('.alf-tab').forEach((item) => item.classList.toggle('alf-active', item === tab));
                ui.querySelectorAll('.alf-date-panel').forEach((panel) => panel.classList.toggle('alf-active', panel.dataset.panel === tab.dataset.tab));
                if (tab.dataset.tab === 'range') {
                    const fromInput = ui.querySelector('.alf-from');
                    const toInput = ui.querySelector('.alf-to');
                    fromInput.value = state.from;
                    toInput.value = state.from && state.from === state.to ? '' : state.to;
                }
            });
        });
        ui.querySelector('.alf-date-apply').addEventListener('click', () => applyDatePanel(ui));
        ui.querySelector('.alf-date-clear').addEventListener('click', () => setQuickRange('all'));
        ui.querySelector('.alf-day').addEventListener('change', (event) => {
            if (!event.target.value) return;
            const date = parseDateValue(event.target.value);
            state.from = event.target.value;
            state.to = event.target.value;
            state.dateLabel = date.toLocaleDateString(undefined, {
                day: 'numeric', month: 'short', year: 'numeric', timeZone: 'UTC'
            });
            commitFilters();
        });
        ui.querySelector('.alf-category-list').addEventListener('change', (event) => {
            if (event.target.type !== 'checkbox') return;
            if (event.target.checked) state.categories.add(event.target.value);
            else state.categories.delete(event.target.value);
            commitFilters();
        });
        ui.addEventListener('click', (event) => {
            const quick = event.target.closest('[data-range]');
            if (quick) setQuickRange(quick.dataset.range);
            const chip = event.target.closest('[data-chip-type]');
            if (!chip) return;
            if (chip.dataset.chipType === 'query') state.query = '';
            else if (chip.dataset.chipType === 'date') {
                state.from = '';
                state.to = '';
                state.dateLabel = 'All time';
            } else if (chip.dataset.chipType === 'category') {
                state.categories.delete(chip.dataset.chipValue);
            }
            commitFilters();
        });
    }

    function ensureUi() {
        if (!isLogPage() || !desktopMedia.matches || document.getElementById(UI_ID)) return;
        const root = document.querySelector(ROOT_SELECTOR);
        if (!root) return;
        if (!state.theme) state.theme = detectedTornTheme(root);
        installStyles();
        const ui = document.createElement('section');
        ui.id = UI_ID;
        ui.setAttribute('aria-label', 'Activity log filters');
        ui.innerHTML = markup();
        applyTheme(ui);
        const nativeToolbar = root.querySelector('[class*="filterWrapper"],[class*="buttonsWrapper"]');
        if (nativeToolbar) nativeToolbar.insertAdjacentElement('afterend', ui);
        else root.prepend(ui);
        bindUi(ui);
        concealNativeSearch(root);
        scheduleRender();
    }

    function onDocumentClick(event) {
        const ui = document.getElementById(UI_ID);
        if (ui && !ui.contains(event.target)) closePopovers();
    }

    function onDocumentKeydown(event) {
        if (event.key === 'Escape') closePopovers();
        if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'k') {
            const search = document.getElementById(SEARCH_ID);
            if (search) {
                event.preventDefault();
                search.focus();
            }
        }
    }

    function bindInteractions() {
        if (interactionsBound) return;
        interactionsBound = true;
        document.addEventListener('click', onDocumentClick);
        document.addEventListener('keydown', onDocumentKeydown);
    }

    function unbindInteractions() {
        if (!interactionsBound) return;
        interactionsBound = false;
        document.removeEventListener('click', onDocumentClick);
        document.removeEventListener('keydown', onDocumentKeydown);
    }

    function teardownUi() {
        const root = document.querySelector(ROOT_SELECTOR);
        if (root) {
            const infos = findRows(root).map(rowInfo);
            infos.forEach((info) => info.row.classList.remove('alf-hidden'));
            sortRows(infos, 'newest');
        }
        document.querySelectorAll('.alf-native-search-hidden').forEach((element) => {
            element.classList.remove('alf-native-search-hidden');
        });
        document.getElementById(UI_ID)?.remove();
        document.getElementById(STYLE_ID)?.remove();
        controlStyleCache = null;
        renderScheduled = false;
    }

    function updatePageLifecycle() {
        if (!isLogPage() || !desktopMedia.matches) {
            teardownUi();
            unbindInteractions();
            return;
        }
        bindInteractions();
        ensureUi();
        scheduleRender();
    }

    function onViewportChange() {
        updatePageLifecycle();
        if (!desktopMedia.matches) return;
        const ui = document.getElementById(UI_ID);
        const root = document.querySelector(ROOT_SELECTOR);
        if (ui && root) syncTornControlStyle(ui, root, true);
    }

    function init() {
        loadState();
        GM_registerMenuCommand('Focus Activity Log Search', () => {
            ensureUi();
            document.getElementById(SEARCH_ID)?.focus();
        });
        GM_registerMenuCommand('Export Visible Logs as CSV', exportCsv);
        GM_registerMenuCommand('Clear Activity Log Filters', clearAll);
        pageObserver = new MutationObserver((mutations) => {
            if (!isLogPage() || !desktopMedia.matches) {
                updatePageLifecycle();
                return;
            }
            const externalMutation = mutations.some((mutation) =>
                !mutation.target.closest?.('#' + UI_ID)
            );
            if (!externalMutation) return;
            updatePageLifecycle();
            if (!controlStyleCache?.sample) {
                const ui = document.getElementById(UI_ID);
                const root = document.querySelector(ROOT_SELECTOR);
                if (ui && root) syncTornControlStyle(ui, root, true);
            }
        });
        pageObserver.observe(document.body, { childList: true, subtree: true });
        desktopMedia.addEventListener('change', onViewportChange);
        window.addEventListener('popstate', updatePageLifecycle);
        window.addEventListener('hashchange', updatePageLifecycle);
        updatePageLifecycle();
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init, { once: true });
    else init();
})();
