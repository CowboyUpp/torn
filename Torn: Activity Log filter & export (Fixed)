                        </div>
                        <div class="alf-date-panel" data-panel="range">
                            <div class="alf-field-row"><label>From<input class="alf-from" type="date"></label><label>To<input class="alf-to" type="date"></label></div>
                            <p class="alf-panel-help">Choose From and To separately, then click Apply.</p>
