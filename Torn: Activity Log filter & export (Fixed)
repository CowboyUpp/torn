(() => {
    'use strict';

    if (new URL(location.href).searchParams.get('sid') !== 'log') return;

    const ROOT_SELECTOR = '#activity-log-root';
    const UI_ID = 'cowboyup-activity-log-ui';
    const SEARCH_ID = 'cowboyup-log-search';
    const STYLE_ID = 'cowboyup-activity-log-styles';
    const STORAGE_KEY = 'cowboyup.activityLogFilter.lite.v1';
    const DESKTOP_QUERY = '(min-width: 1100px)';
    const SCRIPT_VERSION = '1.1.3';

    const state = {
        query: '',
        from: '',
        to: '',
        dateLabel: 'All time',
        categories: new Set(),
        sort: 'newest',
        theme: ''
    };

    let renderScheduled = false;
    let controlStyleCache = null;
    let pageObserver = null;
    let interactionsBound = false;
    const desktopMedia = matchMedia(DESKTOP_QUERY);

    function isLogPage() {
        return new URL(location.href).searchParams.get('sid') === 'log';
    }

    function localDateValue(date) {
        return [
            date.getUTCFullYear(),
            String(date.getUTCMonth() + 1).padStart(2, '0'),
            String(date.getUTCDate()).padStart(2, '0')
        ].join('-');
    }

    function parseDateValue(value, endOfDay = false) {
        if (!value) return null;
        const parts = value.split('-').map(Number);
        if (parts.length !== 3 || parts.some(Number.isNaN)) return null;
        return new Date(Date.UTC(
            parts[0], parts[1] - 1, parts[2],
            endOfDay ? 23 : 0,
            endOfDay ? 59 : 0,
            endOfDay ? 59 : 0,
            endOfDay ? 999 : 0
        ));
    }

    function validUtcDate(year, month, day, hour = 0, minute = 0, second = 0) {
        const date = new Date(Date.UTC(year, month - 1, day, hour, minute, second));
        return date.getUTCFullYear() === year
            && date.getUTCMonth() === month - 1
            && date.getUTCDate() === day
            && date.getUTCHours() === hour
            && date.getUTCMinutes() === minute
            && date.getUTCSeconds() === second
            ? date
            : null;
    }

    function parseDisplayedDate(text) {
        if (!text) return null;
        const normalized = String(text).trim();
        const yearFirst = normalized.match(
            /(\d{4})[/. -](\d{1,2})[/. -](\d{1,2})(?:\D+(\d{1,2}):(\d{2})(?::(\d{2}))?)?/
        );
        if (yearFirst) {
            return validUtcDate(
                Number(yearFirst[1]), Number(yearFirst[2]), Number(yearFirst[3]),
                Number(yearFirst[4] || 0), Number(yearFirst[5] || 0), Number(yearFirst[6] || 0)
            );
        }
        const match = normalized.match(
            /(\d{1,2})[/. -](\d{1,2})[/. -](\d{2,4})(?:\D+(\d{1,2}):(\d{2})(?::(\d{2}))?)?/
        );
        if (match) {
            let year = Number(match[3]);
            if (year < 100) year += 2000;
            return validUtcDate(
                year, Number(match[2]), Number(match[1]),
                Number(match[4] || 0), Number(match[5] || 0), Number(match[6] || 0)
            );
        }
        const parsed = new Date(normalized);
        return Number.isNaN(parsed.getTime()) ? null : parsed;
    }

    function parseSemanticDateValue(value) {
        if (value == null) return null;
        const normalized = String(value).trim();
        if (!normalized) return null;
        if (/^\d{10}(?:\d{3})?$/.test(normalized)) {
            const milliseconds = Number(normalized) * (normalized.length === 10 ? 1000 : 1);
            const date = new Date(milliseconds);
            return Number.isNaN(date.getTime()) ? null : date;
        }
        if (!/^\d{4}-\d{2}-\d{2}(?:[T\s].*)?$/.test(normalized)) return null;
        const hasTimezone = /(?:Z|[+-]\d{2}:?\d{2})$/i.test(normalized);
        const isoValue = normalized.replace(' ', 'T') + (hasTimezone ? '' : 'Z');
        const date = new Date(isoValue);
        return Number.isNaN(date.getTime()) ? null : date;
    }

    function findSemanticDate(row, timeElement) {
        const selector = '[datetime],[data-timestamp],[data-time],[data-date],[data-created],[data-unix]';
        const candidates = new Set([
            timeElement,
            timeElement?.matches(selector) ? timeElement : null,
            timeElement?.querySelector(selector),
            row.querySelector(selector)
        ]);
        const attributes = ['datetime', 'data-timestamp', 'data-time', 'data-date', 'data-created', 'data-unix'];
        for (const element of candidates) {
            if (!element) continue;
            for (const attribute of attributes) {
                const date = parseSemanticDateValue(element.getAttribute(attribute));
                if (date) return date;
            }
        }
        return null;
    }

    function formatRangeLabel(fromValue, toValue) {
        const from = parseDateValue(fromValue);
        const to = parseDateValue(toValue);
        const format = (date, options) => date.toLocaleDateString(undefined, {
            ...options,
            timeZone: 'UTC'
        });

        if (from && to) {
            const sameYear = from.getUTCFullYear() === to.getUTCFullYear();
            const sameMonth = sameYear && from.getUTCMonth() === to.getUTCMonth();
            if (sameMonth) {
                return from.getUTCDate() + '–' + format(to, {
                    day: 'numeric', month: 'short', year: 'numeric'
                });
            }
            if (sameYear) {
                return format(from, { day: 'numeric', month: 'short' }) + ' – '
                    + format(to, { day: 'numeric', month: 'short', year: 'numeric' });
            }
            return format(from, { day: 'numeric', month: 'short', year: 'numeric' }) + ' – '
                + format(to, { day: 'numeric', month: 'short', year: 'numeric' });
        }
        if (from) return 'From ' + format(from, { day: 'numeric', month: 'short', year: 'numeric' });
        if (to) return 'Until ' + format(to, { day: 'numeric', month: 'short', year: 'numeric' });
        return 'All time';
    }

    function loadState() {
        try {
            const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
            state.query = typeof saved.query === 'string' ? saved.query : '';
            state.from = typeof saved.from === 'string' ? saved.from : '';
            state.to = typeof saved.to === 'string' ? saved.to : '';
            state.dateLabel = typeof saved.dateLabel === 'string' ? saved.dateLabel : 'All time';
            state.categories = new Set(Array.isArray(saved.categories) ? saved.categories : []);
            state.sort = saved.sort === 'oldest' ? 'oldest' : 'newest';
            state.theme = saved.theme === 'light' || saved.theme === 'dark' ? saved.theme : '';
        } catch (error) {
            console.warn('[Activity Log Filter] Could not restore saved filters.', error);
        }
    }

    function saveState() {
        try {
            localStorage.setItem(STORAGE_KEY, JSON.stringify({
                query: state.query,
                from: state.from,
                to: state.to,
                dateLabel: state.dateLabel,
                categories: [...state.categories],
                sort: state.sort,
                theme: state.theme
            }));
        } catch (error) {
            console.warn('[Activity Log Filter] Could not save filters.', error);
        }
    }

    function detectedTornTheme(startNode) {
        const classHint = (document.documentElement.className + ' ' + document.body.className).toLowerCase();
        if (classHint.includes('dark')) return 'dark';
        if (classHint.includes('light')) return 'light';

        let node = startNode;
        while (node) {
            const color = getComputedStyle(node).backgroundColor;
            const match = color?.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)(?:,\s*([\d.]+))?/);
            if (match && (match[4] == null || Number(match[4]) > 0.05)) {
                const luminance = (Number(match[1]) * 0.2126 + Number(match[2]) * 0.7152 + Number(match[3]) * 0.0722) / 255;
                return luminance > 0.55 ? 'light' : 'dark';
            }
            node = node.parentElement;
        }
        return matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }

    function applyTheme(ui) {
        ui.classList.toggle('alf-light', state.theme === 'light');
        ui.classList.toggle('alf-dark', state.theme === 'dark');
        const button = ui.querySelector('.alf-theme-button');
        if (!button) return;
        const dark = state.theme === 'dark';
        button.textContent = dark ? '☀' : '☾';
        button.title = dark ? 'Use light interface' : 'Use dark interface';
        button.setAttribute('aria-label', button.title);
    }

    function findTornControlSample(root) {
        const labels = new Set(['all categories', 'all logs', 'all time']);
        return [...root.querySelectorAll('button,a,[role="button"],div')]
            .filter((element) => {
                if (element.closest('#' + UI_ID)) return false;
                if (!labels.has(element.textContent.trim().toLowerCase())) return false;
                const rect = element.getBoundingClientRect();
                if (rect.width < 90 || rect.height < 30 || rect.height > 70) return false;
                const style = getComputedStyle(element);
                return style.backgroundImage !== 'none'
                    || style.backgroundColor !== 'rgba(0, 0, 0, 0)'
                    || parseFloat(style.borderTopWidth) > 0;
            })
            .sort((a, b) => {
                const first = a.getBoundingClientRect();
                const second = b.getBoundingClientRect();
                return first.width * first.height - second.width * second.height;
            })[0] || null;
    }

    function syncTornControlStyle(ui, root, force = false) {
        if (force || !controlStyleCache || controlStyleCache.root !== root
            || (controlStyleCache.sample && !controlStyleCache.sample.isConnected)) {
            const sample = findTornControlSample(root);
            if (!sample) {
                controlStyleCache = { root, sample: null, values: null };
                return;
            }
            const style = getComputedStyle(sample);
            const rect = sample.getBoundingClientRect();
            controlStyleCache = {
                root,
                sample,
                values: {
                    height: Math.round(rect.height) + 'px',
                    fontSize: style.fontSize,
                    fontFamily: style.fontFamily,
                    fontWeight: style.fontWeight,
                    borderRadius: style.borderRadius,
                    pageTheme: detectedTornTheme(root),
                    backgroundColor: style.backgroundColor,
                    backgroundImage: style.backgroundImage,
                    border: [style.borderTopWidth, style.borderTopStyle, style.borderTopColor].join(' '),
                    boxShadow: style.boxShadow,
                    color: style.color
                }
            };
        }
        const values = controlStyleCache?.values;
        if (!values) return;

        ui.style.setProperty('--alf-native-height', values.height);
        ui.style.setProperty('--alf-native-font-size', values.fontSize);
        ui.style.setProperty('--alf-native-font-family', values.fontFamily);
        ui.style.setProperty('--alf-native-font-weight', values.fontWeight);
        ui.style.setProperty('--alf-native-radius', values.borderRadius);

        const colorProperties = [
            '--alf-native-bg-color', '--alf-native-bg-image', '--alf-native-control-border',
            '--alf-native-control-shadow', '--alf-native-control-color'
        ];
        if (state.theme !== values.pageTheme) {
            colorProperties.forEach((property) => ui.style.removeProperty(property));
            return;
        }

        ui.style.setProperty('--alf-native-bg-color', values.backgroundColor);
        ui.style.setProperty('--alf-native-bg-image', values.backgroundImage);
        ui.style.setProperty('--alf-native-control-border', values.border);
        ui.style.setProperty('--alf-native-control-shadow', values.boxShadow);
        ui.style.setProperty('--alf-native-control-color', values.color);
    }

