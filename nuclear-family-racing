    if (skillPoints >= 10)  return { title: 'Amateur',       bg: '#ffedd5', text: '#c2410c' };
    return                         { title: 'Rookie',        bg: (STATE_DARK_MODE ? '#374151' : '#f3f4f6'), text: (STATE_DARK_MODE ? '#9ca3af' : '#4b5563') };
  }

