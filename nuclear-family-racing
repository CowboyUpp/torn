// ==UserScript==
// @name         Nuclear Family — MultiFaction Edition (Hyper-Drive)
// @namespace    torn.com.nuclearfamily.strict
// @version      5.7.1
// @description  Deeply isolated multi-faction alliance tournament dashboard. Built on KISS principles with dynamic tooltips, Class Handicaps, and track select drop-downs.
// @author       cowboyup
// @match        https://www.torn.com/page.php?sid=racing*
// @match        https://www.torn.com/loader.php?sid=racing*
// @license      MIT
// @grant        GM_xmlhttpRequest
// @connect      *
// ==/UserScript==

(function() {
    'use strict';

    // --- [NB Racing] Dashboard UI ---
    function renderLeagueDashboard() {
        if (document.getElementById('nb-league-dashboard')) return;

        const dashboard = document.createElement('div');
        dashboard.id = 'nb-league-dashboard';
        dashboard.style.cssText = `
            position: fixed; top: 100px; right: 20px; width: 350px; height: auto;
            background: #2a2a2a; color: #fff; border: 2px solid #555;
            z-index: 9999; padding: 15px; border-radius: 8px; font-size: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
        `;

        // Mock data
        const mockData = [
            { team: "Alpha Squad", points: 145, handicap: "+0.4s", lastPos: "1st" },
            { team: "Bravo Unit", points: 132, handicap: "-0.2s", lastPos: "3rd" }
        ];

        dashboard.innerHTML = `
            <h4 style="margin: 0 0 10px 0; color: #ffcc00; border-bottom: 1px solid #444;">League Standings</h4>
            <table style="width: 100%; border-collapse: collapse;">
                <thead><tr><th>Team</th><th>Pts</th><th>Hndcp</th><th>Last</th></tr></thead>
                <tbody>${mockData.map(d => `<tr><td>${d.team}</td><td>${d.points}</td><td>${d.handicap}</td><td>${d.lastPos}</td></tr>`).join('')}</tbody>
            </table>
        `;

        // Appending to document.body is safe, but we will wrap this in an observer
        document.body.appendChild(dashboard);
    }

    // --- Observer to detect Page Loading ---
    // This waits for the main racing container to appear before firing
    const observer = new MutationObserver((mutations, obs) => {
        const racingPage = document.querySelector('.racing-main-block');
        if (racingPage) {
            renderLeagueDashboard();
            obs.disconnect(); // Stop observing once rendered
        }
    });

    observer.observe(document.body, { childList: true, subtree: true });

    // --- [NB Racing] Scraper Logic ---
    function checkAndScrapeRace() {
        const leaderBoard = document.getElementById('leaderBoard');
        if (!leaderBoard) return;
        
        const raceID = new URLSearchParams(window.location.search).get('raceID');
        console.log("[NB Racing] Scraper active for Race ID:", raceID);
        // ... (rest of your scraping logic)
    }

    if (window.location.href.includes('tab=log')) checkAndScrapeRace();

})();
