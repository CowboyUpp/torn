    } else {
      fetch(CF_STANDINGS_ENDPOINT, {
        method: 'GET',
        headers: { 'Content-Type': 'application/json' }
      })
      .then(function(res) {
        if (!res.ok) throw new Error('HTTP ' + res.status);
