;(function (window, document) {
  'use strict';

  // --- [CORE 5.7 LOGIC] ---
  // (All your original configuration, CSS, and UI logic remains here)
  var CONFIG_STORAGE_KEY = 'nbf_v3_api_key';
  // ... [Keep all your original vars, CSS, and functions here] ...
  
  // NOTE: Ensure your existing functions (mountFloatingInterface, renderModalInterface, etc.) are intact.

  // --- [NB Racing] Scraper Integration (v5.7.1) ---
  function checkAndScrapeRace() {
    const leaderBoard = document.getElementById('leaderBoard');
    if (!leaderBoard) {
      console.log("[NB Racing] Leaderboard not found, retrying...");
      setTimeout(checkAndScrapeRace, 1000);
      return;
    }

    const raceID = new URLSearchParams(window.location.search).get('raceID');
    const drivers = leaderBoard.querySelectorAll('li[id^="lbr-"]');
    
    console.log(`[NB Racing] Found ${drivers.length} drivers for Race ID: ${raceID}`);

    const results = [];
    drivers.forEach((driverLi) => {
        const placeText = driverLi.querySelector('.race-place')?.textContent.replace(/\D/g, '') || "0";
        const position = parseInt(placeText, 10);
        const name = driverLi.querySelector('.race-name')?.textContent.trim() || "Unknown";
        const time = driverLi.querySelector('.time')?.textContent.trim() || "DNF";
        results.push({ position, name, time });
    });

    const payload = {
        race_id: raceID,
        race_meta: {
            track: document.querySelector('.title-black.top-round')?.textContent.split('-')[0].trim() || "Unknown",
            timestamp: Date.now()
        },
        results: results
    };

    console.log("[NB Racing] Payload ready:", payload);
  }

  // --- Trigger Initialization ---
  window.addEventListener('load', function() {
      // 1. Run your original UI build
      if (typeof mountFloatingInterface === 'function') {
          mountFloatingInterface();
      }

      // 2. Run the Scraper if on log page
      if (window.location.href.includes('tab=log')) {
          checkAndScrapeRace();
      }
  });

})(window, document);
