;(function (window, document) {
  'use strict';

  // --- CONFIGURATION ---
  var CONFIG_STORAGE_KEY = 'nbf_v3_api_key';
  var CONFIG_THEME_KEY   = 'nbf_v3_theme';
  var CONFIG_LEAGUE_KEY  = 'nbf_v57_league_cfg'; 
  var ENGINE_VERSION     = '5.7.1';

  // --- FACTION & TRACK DATA ---
  var TARGET_FACTIONS = [
    { id: 8085, name: 'Nuclear Blast' }, { id: 8954, name: 'Nuclear Armageddon' },
    { id: 16282, name: 'Nuclear Winter' }, { id: 12094, name: 'Nuclear Fusion' },
    { id: 21028, name: 'Nuclear Clinic' }, { id: 13851, name: 'Nuclear Therapy' },
    { id: 17133, name: 'Torn Medical' }, { id: 366, name: 'Evolution' },
    { id: 15222, name: 'Ionization' }, { id: 9754, name: 'Emergency Room' }
  ];

  // --- CORE ENGINE FUNCTIONS (Original Logic) ---
  // [Placeholder: Your original 5.7 functions like mountFloatingInterface, renderModalInterface, etc. go here]
  // Ensure your original functions are exactly as they were in your working v5.7 file.

  // --- [NB Racing] Dashboard UI ---
  function renderLeagueDashboard() {
      if (document.getElementById('nb-league-dashboard')) return;
      const dashboard = document.createElement('div');
      dashboard.id = 'nb-league-dashboard';
      dashboard.style.cssText = "position: fixed; bottom: 20px; right: 20px; z-index: 99999; background: #2a2a2a; color: #fff; padding: 10px; border-radius: 5px; border: 1px solid #444;";
      dashboard.innerHTML = "<strong>League Dashboard</strong><br>Status: Active (v5.7.1)";
      document.body.appendChild(dashboard);
  }

  // --- [NB Racing] Scraper Logic ---
  function checkAndScrapeRace() {
    const leaderBoard = document.getElementById('leaderBoard');
    if (!leaderBoard) {
      setTimeout(checkAndScrapeRace, 1000);
      return;
    }
    const raceID = new URLSearchParams(window.location.search).get('raceID');
    const drivers = leaderBoard.querySelectorAll('li[id^="lbr-"]');
    
    const results = [];
    drivers.forEach((driverLi) => {
        const placeText = driverLi.querySelector('.race-place')?.textContent.replace(/\D/g, '') || "0";
        const position = parseInt(placeText, 10);
        const name = driverLi.querySelector('.race-name')?.textContent.trim() || "Unknown";
        const time = driverLi.querySelector('.time')?.textContent.trim() || "DNF";
        results.push({ position, name, time });
    });

    const payload = {
        race_id: raceID,
        race_meta: {
            track: document.querySelector('.title-black.top-round')?.textContent.split('-')[0].trim() || "Unknown",
            timestamp: Date.now()
        },
        results: results
    };
    console.log("[NB Racing] Payload extracted:", payload);
  }

  // --- Initialization ---
  window.addEventListener('load', function() {
      // 1. Initialize original UI
      if (typeof mountFloatingInterface === 'function') {
          mountFloatingInterface();
      }
      
      // 2. Initialize Dashboard
      renderLeagueDashboard();

      // 3. Scrape if on log
      if (window.location.href.includes('tab=log')) {
          checkAndScrapeRace();
      }
  });

})(window, document);
