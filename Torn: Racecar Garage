        '502':'Alpha Milano 156','503':'Bavaria X5','504':'Coche Basurero','505':'Bedford Nova',
        '506':'Verpestung Sport','507':'Echo S3','508':'Volt RS','509':'Edomondo S2',
        '510':'Nano Cavalier','511':'Colina Tanprice','512':'Cosmos EX','513':'Yotsuhada EVX',
        '514':'Sturmfahrt 111','515':'Tsubasa Impressor','516':'Wington GGU',
        '517':'Weston Marlin 177','518':'Echo R8','519':'Stormatti Casteon','520':'Lolo 458',
        '521':'Lambrini Torobravo','522':'Veloria LFA','523':'Mercia SLR','524':'Zaibatsu GT-R',
    };
    const CAR_CLASSES = {
        '77':'D','78':'A','79':'C','80':'B','81':'C','82':'C','83':'B','84':'C',
        '85':'A','86':'D','87':'B','88':'C','89':'D','90':'E','91':'D','92':'D',
        '93':'B','94':'E','95':'C','494':'E','495':'E','496':'E','497':'E','498':'E',
        '499':'E','500':'E','501':'E','502':'D','503':'D','504':'D','505':'D','506':'D',
        '507':'C','508':'C','509':'C','510':'C','511':'B','512':'B','513':'B','514':'B',
        '515':'B','516':'B','517':'A','518':'A','519':'A','520':'A','521':'A','522':'A',
        '523':'A','524':'A',
    };

    // ─── DOM extraction ───────────────────────────────────────────────────────────

    function extractCarsFromList(listEl) {
        const items = [...listEl.querySelectorAll(':scope > li')];
        return items.map((el, idx) => {
            const removeLink = el.querySelector('a.enlist-link.remove[id-value]');

            // "Select" link — navigates to selectParts page for this car.
            // Only present on tab=parts.
            const actionLink = el.querySelector('a.link.btn-action-tab[step-value="selectParts"]');
            const partsHref = actionLink ? actionLink.getAttribute('href') : '';
            // Normalize to absolute URL so it survives cross-page collection
            const upgradeUrl = partsHref ? new URL(partsHref, location.origin).href : null;

            // Race-join link, present only on tab=customrace's join page
            const joinLink = el.querySelector('a.link.btn-action-joinRace[carid-value]');
            const joinHref = joinLink ? joinLink.getAttribute('href') : null;

            const modelEl = el.querySelector('.model');
            let tornModel = '', carClass = 'A';
            if (modelEl) {
                const boldEl = modelEl.querySelector('.bold');
                tornModel = boldEl ? boldEl.textContent.trim() : '';
                const classMatch = modelEl.textContent.match(/Class\s+([A-E])/i);
                if (classMatch) carClass = classMatch[1].toUpperCase();
            }

            const customNameEl = el.querySelector('[class*="model-car-name-"]');
            const tornCustomName = customNameEl ? customNameEl.textContent.trim() : '';

            // Unified car identifier. Prefer the model-car-name-{id} class —
            // present on tab=cars, tab=parts, AND the tab=customrace join
            // page, and is the value used for live re-querying in the click
            // handler. Fall back to the remove-link's id-value (same
            // underlying id, different markup source). Only fall back to a
            // synthetic idx-based id if BOTH sources are missing, which would
            // indicate Torn changed markup significantly.
            let carId = null;
            if (customNameEl) {
                const cls = [...customNameEl.classList].find(c => c.startsWith('model-car-name-'));
                if (cls) {
                    const m = cls.match(/model-car-name-(\d+)/);
                    if (m) carId = m[1];
                }
            }
            if (!carId && removeLink) carId = removeLink.getAttribute('id-value');
            if (!carId) carId = `idx-${idx}`;

            const imgEl = el.querySelector('.enlist-car img');
            const imgSrc = imgEl ? imgEl.src.replace(/large(@\dx)?\.png$/, 'large.png') : '';

            // Extract item ID from image URL for fallback name/class
            const itemIdMatch = imgSrc.match(/items\/(\d+)\//);
            const itemId = itemIdMatch ? itemIdMatch[1] : '';
            if (!tornModel && itemId) tornModel = CAR_NAMES[itemId] || '';
            if (carClass === 'A' && itemId && CAR_CLASSES[itemId]) carClass = CAR_CLASSES[itemId];

            function getListedStat(keyword) {
                for (const li of el.querySelectorAll('ul.enlisted-stat > li')) {
                    const text = li.textContent;
                    if (text.toLowerCase().includes(keyword.toLowerCase())) {
                        const m = text.match(/:\s*([\d,]+(?:\.\d+)?)/);
                        if (m) return parseFloat(m[1].replace(/,/g, ''));
                    }
                }
                return null;
            }
            function getBarStat(labelText) {
                for (const li of el.querySelectorAll('ul.enlist-bars > li')) {
                    const titleEl = li.querySelector('.title');
                    if (titleEl && titleEl.textContent.trim().toLowerCase() === labelText.toLowerCase()) {
                        const pbWrap = li.querySelector('.progressbar-wrap');
                        if (pbWrap) {
                            const m = (pbWrap.getAttribute('title') || '').match(/^(\d+)/);
                            if (m) return parseInt(m[1], 10);
                        }
                    }
                }
                return null;
            }

            return {
                carId, itemId, tornModel, tornCustomName, carClass, imgSrc,
                partsHref, upgradeUrl, joinHref,
                topSpeedMph:  getListedStat('Top Speed'),
                zeroSixty:    getListedStat('0-60'),
                brakeDist:    getListedStat('Brake Dist'),
                upgrades:     getListedStat('Upgrades'),
                racesWon:     getListedStat('Races won'),
                racesEntered: getListedStat('Races entered'),
                winPct:       getListedStat('Win Percentage'),
                speedPts:     getBarStat('Top Speed'),
                accelPts:     getBarStat('Acceleration'),
                brakingPts:   getBarStat('Braking'),
                handlingPts:  getBarStat('Handling'),
                dirtPts:      getBarStat('Dirt'),
                tarmacPts:    getBarStat('Tarmac'),
                safetyPts:    getBarStat('Safety'),
            };
        });
    }

    // ─── Pagination collector ────────────────────────────────────────────────────
    // Clicks each a.page-number in order, waits for the list to refresh,
    // collects cars, then navigates back to page 1.

    function getPageLinks() {
        // De-dupe by page-value, sort numerically
        const seen = new Set();
        return [...document.querySelectorAll('a.page-number[page-value]')]
            .filter(a => {
                const v = a.getAttribute('page-value');
                if (seen.has(v)) return false;
                seen.add(v);
                return true;
            })
            .sort((a, b) => parseInt(a.getAttribute('page-value')) - parseInt(b.getAttribute('page-value')));
    }

    // ─── Page fetcher ─────────────────────────────────────────────────────────────
    // Fetches each pagination page as HTML and parses li elements — no clicking,
    // no waiting, no observer interference.

    async function fetchPageCars(url) {
        const resp = await fetch(url, { credentials: 'include' });
        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
        const html = await resp.text();
        const doc  = new DOMParser().parseFromString(html, 'text/html');
        const list = doc.querySelector('ul.enlist-list');
        return list ? extractCarsFromList(list) : [];
    }

    async function collectAllCars(loadingEl) {
        // Get all page links from current DOM
        const seen = new Set();
        const pageLinks = [...document.querySelectorAll('a.page-number[page-value]')]
            .filter(a => { const v = a.getAttribute('page-value'); if (seen.has(v)) return false; seen.add(v); return true; })
            .sort((a, b) => parseInt(a.getAttribute('page-value')) - parseInt(b.getAttribute('page-value')));

        // Page 1 is already in the DOM — extract directly
        const firstList = document.querySelector('ul.enlist-list');
        const page1Cars = firstList ? extractCarsFromList(firstList) : [];

        // Dedup by carId across all collected pages, first-seen wins. This
        // guards against pagination glitches returning overlapping pages.
        const byId = new Map();
        for (const car of page1Cars) {
            if (!byId.has(car.carId)) byId.set(car.carId, car);
        }

        if (pageLinks.length > 1) {
            for (let i = 1; i < pageLinks.length; i++) {
                if (loadingEl) loadingEl.querySelector('span').textContent = `Loading page ${i + 1} of ${pageLinks.length}…`;
                const url = pageLinks[i].href;
                const cars = await fetchPageCars(url);
                for (const car of cars) {
                    if (!byId.has(car.carId)) byId.set(car.carId, car);
                }
            }
        }

        return [...byId.values()];
    }

    // ─── Sorting ─────────────────────────────────────────────────────────────────

    function sortedVisible() {
        let list = activeClass === 'ALL'
            ? [...carData]
            : carData.filter(c => c.carClass === activeClass);

        if (sortKey === 'custom') {
            list.sort((a, b) => {
                const ia = customOrder.indexOf(a.carId);
                const ib = customOrder.indexOf(b.carId);
                if (ia === -1 && ib === -1) return 0;
                if (ia === -1) return 1;
                if (ib === -1) return -1;
                return ia - ib;
            });
        } else if (sortKey === 'class') {
            list.sort((a, b) => {
                const ca = CLASS_ORDER.indexOf(a.carClass);
                const cb = CLASS_ORDER.indexOf(b.carClass);
                return sortDir * (ca - cb) || a.tornModel.localeCompare(b.tornModel);
            });
        } else if (sortKey === 'name') {
            list.sort((a, b) => sortDir * a.tornModel.localeCompare(b.tornModel));
        } else {
            list.sort((a, b) => {
                const va = a[sortKey] ?? -Infinity;
                const vb = b[sortKey] ?? -Infinity;
                return sortDir * (va - vb);
            });
        }
        return list;
    }

    // ─── Drag & drop ─────────────────────────────────────────────────────────────

    function enableDrag(card, car, visibleList) {
        card.draggable = true;
        card.addEventListener('dragstart', e => {
            dragSrcIdx = visibleList.indexOf(car);
            card.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
        });
        card.addEventListener('dragend', () => {
            card.classList.remove('dragging');
            document.querySelectorAll('.tcs-car-card').forEach(c => c.classList.remove('drag-over'));
        });
        card.addEventListener('dragover', e => {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            card.classList.add('drag-over');
        });
        card.addEventListener('dragleave', () => card.classList.remove('drag-over'));
        card.addEventListener('drop', e => {
            e.preventDefault();
            card.classList.remove('drag-over');
            const destIdx = visibleList.indexOf(car);
            if (dragSrcIdx === null || dragSrcIdx === destIdx) return;
            const [moved] = visibleList.splice(dragSrcIdx, 1);
            visibleList.splice(destIdx, 0, moved);
            dragSrcIdx = destIdx;

            // Rebuild the MASTER order (all cars, not just the filtered/visible
            // subset) by taking the existing order (or full carData order if
            // none exists yet), removing the moved car, and reinserting it
            // adjacent to its new neighbor in the visible list. This avoids
            // discarding ordering information for cars hidden by the current
            // class filter.
            let master = customOrder.length
                ? [...customOrder]
                : carData.map(c => c.carId);

            master = master.filter(id => id !== moved.carId);

            const prevInVisible = visibleList[destIdx - 1];
            const nextInVisible = visibleList[destIdx + 1];
            if (prevInVisible) {
                const anchorIdx = master.indexOf(prevInVisible.carId);
                master.splice(anchorIdx + 1, 0, moved.carId);
            } else if (nextInVisible) {
                const anchorIdx = master.indexOf(nextInVisible.carId);
                master.splice(Math.max(0, anchorIdx), 0, moved.carId);
            } else {
                master.unshift(moved.carId);
            }

            customOrder = master;
            saveCustomOrder();
            sortKey = 'custom';
            updateSortButtons();
            renderGrid();
        });
    }

