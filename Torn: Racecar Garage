// Changelog:
// v1.6.0 - Added support for tab=parts: each car card now extracts the "Select"
//          action link (a.link.btn-action-tab[step-value="selectParts"], href
//          contains &id={carId}) and clicking the card navigates directly to
//          the parts/upgrades page for that car. Falls back to the old
//          race-selection click if no parts link is found. Tooltip added.
// v1.6.1 - Fixed click handler for cars collected from fetched (non-page-1)
//          pages: car.el may be detached from the live document, so
//          selection now re-resolves the live <li> via .model-car-name-{id}
//          before clicking, with car.el as a last-resort fallback.
//          Added context detection (IS_PARTS_PAGE, live join-link lookup)
//          so cards behave correctly on tab=cars, tab=parts, and the
//          tab=customrace "choose car to join" page.
//          upgradeUrl is now stored as an absolute URL via new URL().
//          Added Dirt/Tarmac/Safety extraction (dirtPts/tarmacPts/safetyPts),
//          new sort buttons, and stat display on each card.
// v1.6.2 - Unified carId/carIdNum into a single robust carId (prefers
//          .model-car-name-{id}, falls back to remove-link id-value, then
//          idx-based as last resort). Dropped car.el entirely — click
//          handler now always re-resolves live DOM nodes by carId, removing
//          the detached-document fallback and its memory retention.
//          Click handler simplified to 3 steps (parts / join / cars).
//          Fixed sort direction polarity: sortDir=-1 now correctly means
//          descending/highest-first, matching the displayed "↓" arrow.
//          Fixed drag-and-drop: reordering under a class filter now splices
//          the moved car into the master customOrder instead of overwriting
//          it with the filtered subset, preserving order for hidden cars.
//          Added dedup-by-carId during multi-page collection (first-seen
//          wins), guarding against pagination overlap/glitches.
//          Wired up the previously-unused car-list cache: reads/writes a
//          context-aware cache (cars/parts/join each cached separately,
//          since their per-car fields differ), 5-minute TTL. Refresh button
//          clears only the current context's cache.
//          Selection now tracked via a single selectedCard/selectedCarId
//          pair instead of a full querySelectorAll('.tcs-car-card') sweep on
//          every click, and persists across sort/filter re-renders.
//          Observer now disconnects after the widget builds successfully
//          (tab switches are full page loads, so each gets a fresh script
//          execution — no reconnect needed). Removed stale/incorrect comment
//          about pagination-driven disconnect/reconnect.
// v1.7.0 - MAJOR: Torn's Racing page is an AJAX/SPA — switching sub-tabs
//          (Cars/Parts/Race/Custom Events) swaps ul.enlist-list and
//          .categories li.active via jQuery .html() WITHOUT changing
//          location.href and WITHOUT a page reload. All of v1.6.2's
//          location.href-based detection (IS_PARTS_PAGE) and the
//          observer-disconnect-after-success change were built on a false
//          full-reload assumption and are now wrong.
//          Replaced IS_PARTS_PAGE with getCurrentTab(), which reads
//          .racing-main-wrap .categories li.active a's href fresh on every
//          call — confirmed reliable across tab switches via live testing.
//          The observer is now permanent (never disconnects) and tracks
//          currentTab; on each mutation it compares the live active tab
//          against currentTab. On a real tab change it tears down the
//          existing widget immediately and re-inits for the new tab once
//          ul.enlist-list reappears (debounced 400ms as before). On the
//          same tab, it only inits if no widget/loader exists yet (handles
//          the async-chunk-loading first-paint case).
//          getCacheContext() now takes the current tab explicitly instead
//          of relying on the stale page-load-time constant.
//          The parts-page click branch re-checks getCurrentTab() live at
//          click time rather than trusting a render-time value, in case the
//          user switched tabs without (yet) triggering a rebuild.

(function () {
    'use strict';

    // ─── Constants ──────────────────────────────────────────────────────────────

    const CLASS_ORDER  = ['A', 'B', 'C', 'D', 'E'];
    const CLASS_COLORS = {
        A: '#ffd700', B: '#c0c0c0', C: '#4ca8ff', D: '#44cc44', E: '#888888',
    };
    const NICKNAMES_KEY    = 'tcs_nicknames';
    const CUSTOM_ORDER_KEY = 'tcs_custom_order';
    const CACHE_KEY_PREFIX = 'tcs_car_cache';
    const CACHE_TTL_MS     = 5 * 60 * 1000; // 5 minutes

    // Active-tab detection. Torn's Racing page is an AJAX/SPA: clicking a
    // sub-tab (Cars/Parts/Race/Custom Events) swaps content via jQuery
    // without changing location.href, so location.href-based detection is
    // unreliable after the first tab. The active tab's <li> reliably gets
    // an "active" class on its <a>'s containing <li>, and its href always
    // reflects the real tab — so we read that fresh every time instead of
    // caching a constant at load.
    function getCurrentTab() {
        const href = document.querySelector('.racing-main-wrap .categories li.active a')?.href || '';
        if (href.includes('tab=parts'))      return 'parts';
        if (href.includes('tab=race'))       return 'race';
        if (href.includes('tab=customrace')) return 'customrace';
        if (href.includes('tab=cars'))       return 'cars';
        return 'unknown';
    }

    // ─── State ───────────────────────────────────────────────────────────────────

    let activeClass = 'ALL';
    let sortKey     = 'speedPts';
    let sortDir     = -1;
    let carData     = [];
    let customOrder = [];
    let nicknames   = {};
    let dragSrcIdx  = null;
    let selectedCard = null;
    let selectedCarId = null;
    let _initTimer  = null;
    let _collecting = false;
    let currentTab  = ''; // tab the active widget (if any) was built for

    // ─── Storage ─────────────────────────────────────────────────────────────────

    const getNicknames    = ()  => { try { return JSON.parse(GM_getValue(NICKNAMES_KEY, '{}')); } catch (_) { return {}; } };
    const saveNicknames   = ()  => GM_setValue(NICKNAMES_KEY, JSON.stringify(nicknames));
    const getCustomOrder  = ()  => { try { return JSON.parse(GM_getValue(CUSTOM_ORDER_KEY, '[]')); } catch (_) { return []; } };
    const saveCustomOrder = ()  => GM_setValue(CUSTOM_ORDER_KEY, JSON.stringify(customOrder));

    function getCacheContext(tab) {
        if (tab === 'parts') return 'parts';
        if (tab === 'customrace' && document.querySelector('a.link.btn-action-joinRace[carid-value]')) return 'join';
        return 'cars';
    }

    function getCachedCars(ctx) {
        try {
            const raw = GM_getValue(`${CACHE_KEY_PREFIX}_${ctx}`, null);
            if (!raw) return null;
            const { ts, data } = JSON.parse(raw);
            if (Date.now() - ts > CACHE_TTL_MS) return null;
            return data;
        } catch (_) { return null; }
    }
    function setCachedCars(ctx, data) {
        GM_setValue(`${CACHE_KEY_PREFIX}_${ctx}`, JSON.stringify({ ts: Date.now(), data }));
    }
    function clearCache(ctx) {
        GM_setValue(`${CACHE_KEY_PREFIX}_${ctx}`, null);
    }

    // ─── CAR_NAMES / CAR_CLASSES ─────────────────────────────────────────────────

