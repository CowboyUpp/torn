        .tcs-stat-val.hl { color: #ffd700; }
        .tcs-edit-btn {
            position: absolute; bottom: 5px; right: 6px;
            font-size: 10px; color: #777; cursor: pointer; padding: 1px 3px;
        }
        .tcs-edit-btn:hover { color: #999; }
        #tcs-status { font-size: 10px; color: #777; margin-top: 5px; }
        .tcs-bar-wrap {
            height: 4px; background: #1e1e1e; border-radius: 2px;
            margin: 1px 0; overflow: hidden; position: relative; flex: 1;
        }
        .tcs-bar-fill {
            height: 100%; border-radius: 2px; position: absolute; left: 0; top: 0;
        }
    `;

    // ─── Render ──────────────────────────────────────────────────────────────────

    function updateSortButtons() {
        document.querySelectorAll('.tcs-sort-btn').forEach(b => {
            const active = b.dataset.sort === sortKey;
            b.classList.toggle('sort-active', active);
            const base = b.dataset.label;
            b.textContent = active && sortKey !== 'custom'
                ? base + (sortDir === -1 ? ' ↓' : ' ↑')
                : base;
        });
    }

    function renderGrid() {
        const grid   = document.getElementById('tcs-grid');
        const status = document.getElementById('tcs-status');
        if (!grid) return;

        const tab = getCurrentTab();
        const visible = sortedVisible();
        grid.innerHTML = '';
        selectedCard = null;

        visible.forEach(car => {
            const card = document.createElement('div');
            card.className = 'tcs-car-card';
            card.dataset.carId = car.carId;
            if (car.carId === selectedCarId) {
                card.classList.add('selected');
                selectedCard = card;
            }

            // Context-aware tooltip
            if (tab === 'parts' && car.upgradeUrl) card.title = 'Click to manage parts/upgrades';
            else if (car.joinHref) card.title = 'Click to select this car for the race';

            const badgeColor = CLASS_COLORS[car.carClass] || '#888';

            const handle = document.createElement('span');
            handle.className = 'tcs-drag-handle';
            handle.title = 'Drag to reorder';
            handle.textContent = '⠿';
            card.appendChild(handle);

            const badge = document.createElement('span');
            badge.className = 'tcs-class-badge';
            badge.textContent = car.carClass;
            badge.style.cssText = `color:${badgeColor};border-color:${badgeColor}55;background:${badgeColor}0f;`;
            card.appendChild(badge);

            const modelEl = document.createElement('div');
            modelEl.className = 'tcs-torn-model';
            modelEl.textContent = car.tornModel || '—';
            modelEl.title = car.tornModel;
            card.appendChild(modelEl);

            if (car.imgSrc) {
                const img = document.createElement('img');
                img.className = 'tcs-car-img';
                img.src = car.imgSrc;
                img.alt = car.tornModel;
                card.appendChild(img);
            }

            const nicknameEl = document.createElement('div');
            nicknameEl.className = 'tcs-nickname';
            nicknameEl.textContent = nicknames[car.carId] || car.tornCustomName || '—';
            card.appendChild(nicknameEl);

            const statsEl = document.createElement('div');
            statsEl.className = 'tcs-car-stats';

            [
                { key: 'speedPts',    label: 'Spd', color: '#ff9900' },
                { key: 'accelPts',    label: 'Acc', color: '#00cfff' },
                { key: 'brakingPts',  label: 'Brk', color: '#cc44ff' },
                { key: 'handlingPts', label: 'Hdl', color: '#44cc44' },
            ].forEach(({ key, label, color }) => {
                const val = car[key];
                if (val == null) return;
                const lbl = document.createElement('span');
                lbl.className = 'tcs-stat-label';
                lbl.textContent = label;
                const vWrap = document.createElement('div');
                vWrap.style.cssText = 'display:flex;align-items:center;gap:4px;';
                const vEl = document.createElement('span');
                vEl.className = 'tcs-stat-val' + (key === sortKey ? ' hl' : '');
                vEl.textContent = val;
                vEl.style.minWidth = '24px';
                const barWrap = document.createElement('div');
                barWrap.className = 'tcs-bar-wrap';
                const fill = document.createElement('div');
                fill.className = 'tcs-bar-fill';
                fill.style.cssText = `width:${Math.min(100, val / 120 * 100)}%;background:${color};`;
                barWrap.appendChild(fill);
                vWrap.appendChild(vEl);
                vWrap.appendChild(barWrap);
                statsEl.appendChild(lbl);
                statsEl.appendChild(vWrap);
            });

            [
                ['Speed',    car.topSpeedMph != null ? car.topSpeedMph + ' mph' : null],
                ['0-60',     car.zeroSixty   != null ? car.zeroSixty + 's'      : null],
                ['Dirt',     car.dirtPts     != null ? String(car.dirtPts)      : null],
                ['Tarmac',   car.tarmacPts   != null ? String(car.tarmacPts)    : null],
                ['Safety',   car.safetyPts   != null ? String(car.safetyPts)    : null],
                ['Upgrades', car.upgrades    != null ? String(car.upgrades)      : null],
                ['W%',       car.winPct      != null ? car.winPct + '%'          : null],
            ].forEach(([label, val]) => {
                if (val == null) return;
                const lbl = document.createElement('span');
                lbl.className = 'tcs-stat-label';
                lbl.textContent = label;
                const vEl = document.createElement('span');
                vEl.className = 'tcs-stat-val' + (
                    (label === 'Upgrades' && sortKey === 'upgrades') ||
                    (label === 'W%' && sortKey === 'winPct') ||
                    (label === 'Dirt' && sortKey === 'dirtPts') ||
                    (label === 'Tarmac' && sortKey === 'tarmacPts') ||
                    (label === 'Safety' && sortKey === 'safetyPts') ? ' hl' : '');
                vEl.textContent = val;
                statsEl.appendChild(lbl);
                statsEl.appendChild(vEl);
            });

            card.appendChild(statsEl);

            card.addEventListener('click', e => {
                if (e.target === handle || e.target.classList.contains('tcs-edit-btn')) return;

                if (selectedCard) selectedCard.classList.remove('selected');
                card.classList.add('selected');
                selectedCard = card;
                selectedCarId = car.carId;

                // 1) Parts page: navigate to the upgrades/parts page for this car.
                //    Re-check live — the user may have switched tabs without a
                //    rebuild happening yet.
                if (getCurrentTab() === 'parts' && car.upgradeUrl) {
                    window.location.href = car.upgradeUrl;
                    return;
                }

                // 2) Race-join page: look up the live join link by car id.
                const liveJoinLink = document.querySelector(`a.link.btn-action-joinRace[carid-value="${car.carId}"]`);
                if (liveJoinLink) {
                    liveJoinLink.click();
                    return;
                }

                // 3) tab=cars (or anything else): re-resolve the live <li> by id
                //    and click its selection target.
                const nameEl = document.querySelector(`.model-car-name-${car.carId}`);
                const liveLi = nameEl ? nameEl.closest('li') : null;
                if (liveLi) {
                    const target = liveLi.querySelector('input[type="radio"], a.enlist-link:not(.remove), button');
                    if (target) target.click();
                }
            });

            const editBtn = document.createElement('span');
            editBtn.className = 'tcs-edit-btn';
            editBtn.textContent = '✎';
            editBtn.title = 'Set nickname';
            editBtn.addEventListener('click', e => {
                e.stopPropagation();
                const input = document.createElement('input');
                input.type = 'text';
                input.className = 'tcs-nickname-input';
                input.value = nicknames[car.carId] || '';
                input.placeholder = 'Nickname…';
                input.maxLength = 22;
                nicknameEl.replaceWith(input);
                input.focus(); input.select();
                function commit() {
                    const val = input.value.trim();
                    if (val) nicknames[car.carId] = val;
                    else delete nicknames[car.carId];
                    saveNicknames();
                    nicknameEl.textContent = val || car.tornCustomName || '—';
                    input.replaceWith(nicknameEl);
                }
                input.addEventListener('blur', commit);
                input.addEventListener('keydown', ev => {
                    if (ev.key === 'Enter')  { ev.preventDefault(); input.blur(); }
                    if (ev.key === 'Escape') { input.value = nicknames[car.carId] || ''; input.blur(); }
                });
            });
            card.appendChild(editBtn);

            enableDrag(card, car, visible);
            grid.appendChild(card);
        });

        if (status) {
            const total = carData.length;
            const shown = visible.length;
            status.textContent = shown === total
                ? `${total} cars  ·  drag ⠿ to reorder  ·  click ✎ to nickname`
                : `${shown} of ${total} cars  ·  class filter active`;
        }
    }

    // ─── Build widget ────────────────────────────────────────────────────────────

    function buildWidget(anchor) {
        if (!document.getElementById('tcs-styles')) {
            const s = document.createElement('style');
            s.id = 'tcs-styles';
            s.textContent = STYLE;
            document.head.appendChild(s);
        }

        const wrapper = document.createElement('div');
        wrapper.id = 'tcs-wrapper';

        const toolbar = document.createElement('div');
        toolbar.id = 'tcs-toolbar';

        // Filter
        const filterGroup = document.createElement('div');
        filterGroup.className = 'tcs-toolbar-group';
        const filterLabel = document.createElement('span');
        filterLabel.className = 'tcs-toolbar-label';
        filterLabel.textContent = 'Class:';
        filterGroup.appendChild(filterLabel);
        ['ALL', ...CLASS_ORDER].forEach(cls => {
            const btn = document.createElement('button');
            btn.className = 'tcs-btn' + (cls === activeClass ? ' active' : '');
            btn.dataset.class = cls;
            btn.textContent = cls;
            btn.addEventListener('click', () => {
                activeClass = cls;
                filterGroup.querySelectorAll('.tcs-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                renderGrid();
            });
            filterGroup.appendChild(btn);
        });

        // Sort
        const sortGroup = document.createElement('div');
        sortGroup.className = 'tcs-toolbar-group';
        const sortLabel = document.createElement('span');
        sortLabel.className = 'tcs-toolbar-label';
        sortLabel.textContent = 'Sort:';
        sortGroup.appendChild(sortLabel);
        [
            { key: 'speedPts',    label: 'Speed'    },
            { key: 'accelPts',    label: 'Accel'    },
            { key: 'handlingPts', label: 'Handling' },
            { key: 'dirtPts',     label: 'Dirt'     },
            { key: 'tarmacPts',   label: 'Tarmac'   },
            { key: 'safetyPts',   label: 'Safety'   },
            { key: 'upgrades',    label: 'Upgrades' },
            { key: 'winPct',      label: 'Win%'     },
            { key: 'name',        label: 'Name'     },
            { key: 'class',       label: 'Class'    },
            { key: 'custom',      label: 'Custom'   },
        ].forEach(({ key, label }) => {
            const btn = document.createElement('button');
            btn.className = 'tcs-btn tcs-sort-btn' + (sortKey === key ? ' sort-active' : '');
            btn.dataset.sort  = key;
            btn.dataset.label = label;
            btn.textContent   = label + (sortKey === key && key !== 'custom' ? ' ↓' : '');
            btn.addEventListener('click', () => {
                if (sortKey === key && key !== 'custom') sortDir *= -1;
                else { sortKey = key; sortDir = -1; }
                updateSortButtons();
                renderGrid();
            });
            sortGroup.appendChild(btn);
        });

        // Refresh button — clears cache and re-collects
        const refreshBtn = document.createElement('button');
        refreshBtn.className = 'tcs-refresh-btn';
        refreshBtn.title = 'Refresh car list';
        refreshBtn.textContent = '↺ Refresh';
        refreshBtn.addEventListener('click', () => {
            clearCache(getCacheContext(getCurrentTab()));
            wrapper.remove();
            document.querySelectorAll('ul.enlist-list').forEach(l => l.style.display = '');
            document.querySelectorAll('.gallery-wrapper.pagination').forEach(p => p.style.display = '');
            _collecting = false;
            init();
        });

        const divider = document.createElement('div');
        divider.className = 'tcs-divider';
        toolbar.appendChild(filterGroup);
        toolbar.appendChild(divider);
        toolbar.appendChild(sortGroup);
        toolbar.appendChild(refreshBtn);

        const grid   = document.createElement('div');
        grid.id      = 'tcs-grid';
        const status = document.createElement('div');
        status.id    = 'tcs-status';

        wrapper.appendChild(toolbar);
        wrapper.appendChild(grid);
        wrapper.appendChild(status);

        anchor.parentNode.insertBefore(wrapper, anchor);
        document.querySelectorAll('ul.enlist-list').forEach(l => l.style.display = 'none');
        document.querySelectorAll('.gallery-wrapper.pagination').forEach(p => p.style.display = 'none');
    }

    // ─── Loading indicator ───────────────────────────────────────────────────────

    function showLoading(anchor) {
        if (!document.getElementById('tcs-styles')) {
            const s = document.createElement('style');
            s.id = 'tcs-styles';
            s.textContent = STYLE;
            document.head.appendChild(s);
        }
        const el = document.createElement('div');
        el.id = 'tcs-loading';
        el.innerHTML = '<div class="tcs-spinner"></div><span>Loading cars…</span>';
        anchor.parentNode.insertBefore(el, anchor);
        return el;
    }

    // ─── Teardown ────────────────────────────────────────────────────────────────
    // Removes our injected widget/loader. Torn's AJAX tab-swap replaces the
    // ul.enlist-list / pagination subtree wholesale (confirmed via jQuery
    // .html() calls in racing.js), so the OLD hidden list is discarded by
    // Torn itself — we don't need to un-hide anything from the previous tab.

    function teardownWidget() {
        document.getElementById('tcs-wrapper')?.remove();
        document.getElementById('tcs-loading')?.remove();
        selectedCard = null;
        selectedCarId = null;
    }

    // ─── Init ────────────────────────────────────────────────────────────────────

    async function init(tab) {
        clearTimeout(_initTimer);
        _initTimer = setTimeout(async () => {
            if (_collecting) return;
            const firstList = document.querySelector('ul.enlist-list');
            if (!firstList) return;
            if (document.getElementById('tcs-wrapper') || document.getElementById('tcs-loading')) return;

            _collecting = true;
            currentTab  = tab;
            customOrder = getCustomOrder();
            nicknames   = getNicknames();

            const ctx = getCacheContext(tab);
            const cached = getCachedCars(ctx);

            if (cached) {
                carData = cached;
                firstList.style.display = 'none';
                document.querySelectorAll('.gallery-wrapper.pagination').forEach(p => p.style.display = 'none');
                buildWidget(firstList);
                renderGrid();
                _collecting = false;
                return;
            }

            const loader = showLoading(firstList);
            firstList.style.display = 'none';

            try {
                carData = await collectAllCars(loader);
                setCachedCars(ctx, carData);
                loader.remove();
                buildWidget(firstList);
                renderGrid();
            } catch (e) {
                loader.remove();
                firstList.style.display = '';
                console.error('[Car Sorter]', e);
            } finally {
                _collecting = false;
            }
        }, 400);
    }

    // ─── Observer ────────────────────────────────────────────────────────────────
    // Torn's Racing page is a long-lived AJAX/SPA: switching sub-tabs
    // (Cars/Parts/Race/Custom Events) replaces ul.enlist-list and the
    // .categories li.active marker via jQuery .html(), without a full page
    // reload and without changing location.href. A single tab-swap fires
    // dozens of childList mutations as jQuery incrementally rebuilds the
    // DOM, but .categories li.active updates reliably and early, so we use
    // a *tab change* (not "list appeared") as the rebuild trigger.
    //
    // The observer is NEVER disconnected — Torn keeps swapping content for
    // the lifetime of the racing page.

    const observer = new MutationObserver(() => {
        if (_collecting) return;

        const tab = getCurrentTab();
        if (tab === 'unknown') return; // transient state during a swap

        const hasList   = !!document.querySelector('ul.enlist-list');
        const hasWidget = !!(document.getElementById('tcs-wrapper') || document.getElementById('tcs-loading'));

        if (tab !== currentTab) {
            // Tab changed (or this is the first run). Tear down any stale
            // widget immediately so we don't show the previous tab's cars,
            // then (re)init for the new tab once its content is present.
            // Update currentTab right away so the burst of mutations that
            // follows a tab-swap doesn't repeatedly re-teardown.
            currentTab = tab;
            if (hasWidget) teardownWidget();
            if (hasList) init(tab);
            return;
        }

        // Same tab as our current widget — only act if no widget exists yet
        // (e.g. first load, where ul.enlist-list appears asynchronously
        // after the build-chunk scripts finish loading).
        if (hasList && !hasWidget) init(tab);
    });

    observer.observe(document.body, { childList: true, subtree: true });
    {
        const tab = getCurrentTab();
        if (tab !== 'unknown') {
            currentTab = tab;
            init(tab);
        }
    }

})();
