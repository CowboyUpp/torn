            saveSpeedLog(log);
            renderLapTable();
        }
    });

    const speedOpen = getBooleanSetting(SETTING_SPEED_OPEN, false);
    const lapOpen = getBooleanSetting(SETTING_LAP_OPEN, false);
    setPanelOpen('#rslogSpeedPanelContent', '#rslogSpeedToggle', speedOpen, 'Top Speeds', 'Top Speeds');
