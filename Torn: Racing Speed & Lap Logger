// ─── Cleanup ───────────────────────────────────────────────────────────────────
function cleanupRaceState() {
    maybeClear();
    ['rslogWrapper', 'rslogLobbyBtn', 'rslogLobbyPanel'].forEach(id => {
        document.getElementById(id)?.remove();
    });
    currentTrack    = '';
    currentCar      = '';
    last_compl      = -1.0;
    sessionTopSpeed = 0;
    _initialized    = false;
}

// ─── Init ──────────────────────────────────────────────────────────────────────
let _raceObserver = null;

function watchForRaceStart() {
    if (_raceObserver) return;
    _raceObserver = new MutationObserver(() => {
        if (document.getElementById('racingdetails') && !document.getElementById('rslogWrapper')) {
            cleanupRaceState();
            injectWidget();
            startSpeedLoop();
        }
        if (document.getElementById('racingAdditionalContainer') && !document.getElementById('racingdetails')) {
            injectLobbyPanel();
        }
        if (!document.getElementById('racingAdditionalContainer') && !document.getElementById('racingdetails')) {
            maybeClear();
        }
    });
    _raceObserver.observe(document.body, { childList: true, subtree: true });
}

let _currentHref = location.href;
const _navObserver = new MutationObserver(() => {
    if (location.href !== _currentHref) {
        _currentHref = location.href;
        if (!location.href.includes('sid=racing')) {
            cleanupRaceState();
        }
    }
});
_navObserver.observe(document.body, { childList: true, subtree: false });

let _initialized = false;

function init() {
    if (_initialized) return;
    _initialized = true;
    migrateSpeedLog();
    if (document.getElementById('racingdetails') && !document.getElementById('rslogWrapper')) {
        injectWidget();
        startSpeedLoop();
    } else if (document.getElementById('racingAdditionalContainer') && !document.getElementById('racingdetails')) {
        injectLobbyPanel();
    }
    watchForRaceStart();
}

tornAjax(() => { init(); });
init();
