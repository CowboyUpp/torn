    let outsideClickWired = false;

    function wireOutsideClickOnce() {
        if (outsideClickWired) return;
        outsideClickWired = true;

        // Single delegated listener for the lifetime of the page. Looks up the
        // *current* #cct-root and #cct-settings-popover at click time instead of
        // closing over a specific widget instance, so rebuilding the widget
        // after SPA navigation never accumulates extra document listeners.
        document.addEventListener('click', (e) => {
            const root = document.querySelector('#cct-root');
            const popover = document.querySelector('#cct-settings-popover');
            if (!root || !popover) return;
            if (!root.contains(e.target)) popover.classList.remove('cct-open');
        });
    }

    function wireSettings(el) {
        const gear = el.querySelector('#cct-gear');
        const popover = el.querySelector('#cct-settings-popover');

        gear.addEventListener('click', (e) => {
            e.stopPropagation();
            popover.classList.toggle('cct-open');
            if (popover.classList.contains('cct-open')) renderCorrectionLog();
        });

        wireOutsideClickOnce();

        el.querySelector('#cct-chain-save').addEventListener('click', () => {
            const input = el.querySelector('#cct-chain-input');
            const oldChain = chain;
            chain = clampChain(input.value);
            input.value = chain;
            if (chain !== oldChain) logCorrection('manual', oldChain, chain, null, 'Set manually in Settings');
            saveChain();
            render(true);
        });

        el.querySelector('#cct-log-clear').addEventListener('click', () => {
            saveCorrectionLog([]);
            renderCorrectionLog();
        });

        el.querySelector('#cct-log-key-save').addEventListener('click', () => {
            const input = el.querySelector('#cct-log-key-input');
            const hint = el.querySelector('#cct-log-sync-hint');
            const cleanKey = saveLogApiKey(input.value);
            logSyncPageBefore = null; // fresh key, don't carry over old pagination state
            hint.textContent = cleanKey ? 'Log key saved — verification available' : 'Save a log key first';
        });

        el.querySelector('#cct-log-sync-now').addEventListener('click', async () => {
            const hint = el.querySelector('#cct-log-sync-hint');
            const key = getLogApiKey();
            if (!key) {
                hint.textContent = 'Save a log key first';
                return;
            }
            hint.textContent = 'Verifying from logs...';
            const result = await syncFromLogs('manual');
            if (result.ok) {
                hint.textContent = `Verified from logs — chain is ${result.chain}`;
            } else if (result.reason === 'no-reset-found') {
                hint.textContent = 'Need older logs — click again to search further back';
            } else if (result.error && result.error.code === 16) {
                hint.textContent = `Key needs the 'log' selection — use the button above to create one`;
            } else if (result.reason === 'empty') {
                hint.textContent = 'No crime log entries found for this key';
            } else {
                hint.textContent = `Sync failed: ${result.error ? result.error.message : 'unknown error'}`;
            }
        });
    }

    function render(animate) {
        const arc = document.querySelector('#cct-ring-arc');
        const label = document.querySelector('#cct-ring-label');
        const status = document.querySelector('#cct-status');
        const manual = document.querySelector('#cct-chain-input');
        if (!arc || !label || !status) return;

        const pct = Math.min(chain / CHAIN_CAP_DISPLAY, 1);
        const offset = CIRC * (1 - pct);
        const color = chainColor(chain);

        arc.style.strokeDashoffset = offset;
        arc.style.stroke = color;
        label.textContent = String(chain);
        status.textContent = statusText(chain);
        if (manual && document.activeElement !== manual) manual.value = chain;

        if (animate) {
            status.classList.remove('cct-flash');
            void status.offsetWidth;
            status.classList.add('cct-flash');
        }
    }

    function isVisibleElement(el) {
        if (!el || el.closest('#cct-root')) return false;
        if (el.hidden || el.getAttribute('aria-hidden') === 'true') return false;
        return Boolean(el.offsetParent || el.getClientRects().length);
    }

    function inspectPossibleOutcomeNode(node) {
        const element = node.nodeType === Node.TEXT_NODE ? node.parentElement : node;
        if (!element || element.nodeType !== Node.ELEMENT_NODE) return;

        const candidates = [];
        if (element.matches && element.matches(OUTCOME_CONTAINER_SELECTOR)) candidates.push(element);
        if (element.closest) {
            const closest = element.closest(OUTCOME_CONTAINER_SELECTOR);
            if (closest) candidates.push(closest);
        }
        if (element.querySelectorAll) candidates.push(...element.querySelectorAll(OUTCOME_CONTAINER_SELECTOR));

        for (const candidate of new Set(candidates)) {
            if (!isVisibleElement(candidate)) continue;
            if (candidate.dataset && candidate.dataset.cctSeen === '1') continue;

            const text = normalizeText(candidate.textContent);
            const outcome = classifyOutcome(text);
            if (!outcome) continue;

            if (candidate.dataset) candidate.dataset.cctSeen = '1';
            applyOutcomeFromText(text);
            break;
        }
    }

    function startDOMObserver() {
        if (observer) observer.disconnect();

        const root = findCrimesApp();
        if (!root) return;

        observer = new MutationObserver((mutations) => {
            if (!document.querySelector('#cct-root')) renderWidget();

            const synced = syncFromNativeBadge();

            if (!synced && !applyResultCountDeltaFallback({ source: 'mutation-observer', mutations })) {
                for (const mutation of mutations) {
                    for (const node of mutation.addedNodes) inspectPossibleOutcomeNode(node);
                    if (mutation.type === 'characterData') inspectPossibleOutcomeNode(mutation.target);
                }
            }
        });

        observer.observe(root, { childList: true, characterData: true, subtree: true });
    }

    // Fetches one page (up to 100 entries) of crime-outcome log entries. Verified
    // against real API responses — log IDs confirmed via torn/logtypes and
    // cross-checked against the in-game log page down to the exact second:
    //   9010 = Crime success, 9150 = Crime fail (new)
    //   9154/9155/9158/9160/9163/9165 = Crime critical fail (fragmented by side effect —
    //   a jail-outcome crit logs ONLY as 9155, not the generic 9154)
    // Optional `to` pages further back in time (unix seconds) per Torn's documented
    // log pagination. Paginated (to/from) queries are cached ~30s by Torn's API.
    async function fetchCrimeLogPage(key, to) {
        const idsParam = LOG_IDS_ALL.join(',');
        let url = `https://api.torn.com/user/?selections=log&log=${idsParam}&key=${encodeURIComponent(key)}`;
        if (to) url += `&to=${to}`;
        const res = await fetch(url);
        const data = await res.json();
        if (data.error) {
            const err = new Error(data.error.error || 'Torn API error');
            err.code = data.error.code;
            throw err;
        }
        const raw = data.log || {};
        return Object.values(raw).map((e) => ({ log: e.log, timestamp: e.timestamp }));
    }

    // Replays success (+1) / fail (halve, floored) from just after the most recent
    // critical fail (reset to 0) found in the given entries. Returns null if no
    // critical fail appears in this batch at all — caller should page further back.
    function replayChainFromEntries(entries) {
        const sorted = entries.slice().sort((a, b) => a.timestamp - b.timestamp);
        let lastCritIndex = -1;
        sorted.forEach((e, i) => { if (LOG_IDS_CRITICAL.includes(e.log)) lastCritIndex = i; });
        if (lastCritIndex === -1) return null;

        let result = 0;
        let successCount = 0;
        let failCount = 0;
        for (let i = lastCritIndex + 1; i < sorted.length; i++) {
            const e = sorted[i];
            if (e.log === LOG_ID_SUCCESS) { result += 1; successCount++; }
            else if (e.log === LOG_ID_FAIL) { result = Math.floor(result / 2); failCount++; }
        }
        return { chain: result, successCount, failCount, resetTimestamp: sorted[lastCritIndex].timestamp, oldestTimestamp: sorted[0].timestamp };
    }

    // Remembers where to page backward to if the last attempt found no critical fail
    // in its batch — cleared on any successful reconstruction.
    let logSyncPageBefore = null;

    async function syncFromLogs(trigger) {
        const key = getLogApiKey();
        if (!key) return { ok: false, reason: 'no-key' };

        try {
            const entries = await fetchCrimeLogPage(key, logSyncPageBefore);
            if (!entries.length) return { ok: false, reason: 'empty' };

            const result = replayChainFromEntries(entries);
            if (!result) {
                // No critical fail in this batch — remember to page further back on
                // the next attempt rather than auto-chaining calls (30s cache on
                // paginated queries would just return the same data back-to-back).
                const oldest = entries.slice().sort((a, b) => a.timestamp - b.timestamp)[0].timestamp;
                logSyncPageBefore = oldest - 1;
                return { ok: false, reason: 'no-reset-found' };
            }

            logSyncPageBefore = null;
            const oldChain = chain;
            chain = clampChain(result.chain);

            pendingCriticalConfirm = null;
            resetResultCounterTracking();

            if (chain !== oldChain) {
                const reason = `${result.successCount} success${result.successCount === 1 ? '' : 'es'}, ${result.failCount} fail${result.failCount === 1 ? '' : 's'} since last reset${trigger ? ` (${trigger})` : ''}`;
                logCorrection('log', oldChain, chain, result, reason);
                saveChain();
                render(true);
            }
            return { ok: true, chain };
        } catch (e) {
            console.log(`[CCT v${VERSION}] log sync failed:`, e.message, e.code || '');
            return { ok: false, reason: 'error', error: e };
        }
    }

    function runSyncLoop() {
        clearTimeout(syncTimer);
        syncTimer = setTimeout(() => {
            const route = currentCrimesRoute();
            if (route !== lastCrimesRoute) {
                lastCrimesRoute = route;
                cachedNativeChainValueEl = null;
                resetResultCounterTracking();
            }
            renderWidget();
            startDOMObserver();
            if (!syncFromNativeBadge()) applyResultCountDeltaFallback({ source: 'sync-loop' });
            render(false);
        }, 100);
    }

    async function waitForApp(timeout = 15000) {
        const started = Date.now();
        while (Date.now() - started < timeout) {
            const app = findCrimesApp();
            if (app) return app;
            await new Promise((resolve) => setTimeout(resolve, 250));
        }
        return null;
    }

    function watchSpaNavigation() {
        const originalPushState = history.pushState;
        const originalReplaceState = history.replaceState;

        history.pushState = function (...args) {
            const result = originalPushState.apply(this, args);
            runSyncLoop();
            return result;
        };

        history.replaceState = function (...args) {
            const result = originalReplaceState.apply(this, args);
            runSyncLoop();
            return result;
        };

        window.addEventListener('popstate', runSyncLoop);
        window.addEventListener('hashchange', runSyncLoop);
    }

    async function init() {
        injectCSS();
        watchSpaNavigation();

        const app = await waitForApp();
        if (!app) return;

        runSyncLoop();
        console.log(`[CCT v${VERSION}] Hardened crime chain tracker loaded.`);
    }

    init();
})();
