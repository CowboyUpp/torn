function carName(carImg) {
    return CAR_NAMES[carKey(carImg)] || null;
}

// Returns true if a new top speed was set.
function updateTopSpeed(trackName, speed, carImg) {
    const log     = getSpeedLog();
    const rounded = parseFloat(speed.toFixed(2));
    const key     = trackName + '|' + carKey(carImg);
    if (!log[key] || rounded > log[key].topSpeed) {
        if (!log[key]) log[key] = { track: trackName, car: carImg || '', topSpeed: 0 };
        log[key].topSpeed = rounded;
        log[key].date     = new Date().toISOString().split('T')[0];
        saveSpeedLog(log);
        return true;
    }
    return false;
}

// Saves best lap if it improves on the stored record. No return value needed.
function updateBestLap(trackName, carImg, bestLapMs) {
    if (!bestLapMs || bestLapMs <= 0) return;
    const log = getSpeedLog();
    const key = trackName + '|' + carKey(carImg);
    if (!log[key]) log[key] = { track: trackName, car: carImg || '', topSpeed: 0, date: new Date().toISOString().split('T')[0] };
    if (!log[key].bestLapMs || bestLapMs < log[key].bestLapMs) {
        log[key].bestLapMs = bestLapMs;
        saveSpeedLog(log);
    }
}

// ─── Lap time formatting ───────────────────────────────────────────────────────
function formatLapTime(ms) {
    if (!ms || ms <= 0) return '–';
    const m   = Math.floor(ms / 60000);
    const s   = Math.floor((ms % 60000) / 1000);
    const dec = Math.floor((ms % 1000) / 100); // tenths
    return m + 'm ' + String(s).padStart(2, '0') + '.' + dec + 's';
}

