        '  </div>' +
        '  <div id="rslogPanel">' +
        '    <table id="rslogTable">' +
        '      <thead><tr><th>Track</th><th>Car</th><th>Top Speed</th><th>Best Lap</th><th>Date</th></tr></thead>' +
