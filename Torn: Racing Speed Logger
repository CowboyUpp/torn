// Changelog:
// v1.6.23 - Fixed best lap not recording. Two bugs: the split timer was only
//           started after the first lap boundary (so 1-lap races got nothing
//           and all races lost the first lap), and the final lap was not
//           captured when completion hit 100%. Now the timer seeds on the
//           first valid reading and the finish line is treated as a boundary.
// v1.6.22 - Added a Best Lap column to both the in-race and lobby log tables.
//           Lap time is measured with wall-clock splits: each time completion
//           crosses a full-lap boundary the delta since the previous crossing
//           is recorded. The best (shortest) time for the current track+car
//           combo is saved alongside the top speed. Resolution is ±1 s because
//           the poller runs every second. The very first lap boundary after
//           page load is skipped (no prior split to diff against).
// v1.6.21 - Added a firework burst when you hit a new record. Also made the
//           ★ NEW RECORD text much bigger so you actually notice it.
// v1.6.19 - Each car now gets its own record per track, so your Colina and
//           your NSX on Mudpit are tracked separately.
// v1.6.18 - Fixed a bug where a single bad reading could log something crazy
//           like 760 mph. Speeds above 400 mph are now ignored.
// v1.6.17 - Replaced the car name text with the actual car image in the log.
//           Much easier to recognise at a glance.
// v1.6.16 - Fixed car detection. Was looking at the wrong element — now reads
//           the right one and actually finds your car.
// v1.6.15 - Simplified how the car name is read. Previous approach was
//           overengineered and kept failing.
// v1.6.0  - Added the full log table with car, speed and date. Also added
//           CSV export and the lobby panel under Statistics.
// v1.5.5  - Fixed a timing issue where the speed loop sometimes didn't start
//           because the race elements hadn't loaded yet.
// v1.5.4  - Fixed the wrong heading being read for the track name — it was
//           picking up "Current car" instead of the actual race title.
// v1.5.3  - Fixed records not saving. Zero and negative speeds are now ignored
//           so a bad first reading can't corrupt the log.
// v1.5.2  - Made the log table easier to read — bigger text, brighter colours.
// v1.5.1  - Made the Download CSV and Clear all look like actual buttons.
// v1.5.0  - Added the Top Speeds Log panel to the racing lobby so you can
//           check your records without being in a race.
// v1.4.0  - Fixed a bug where navigating away from racing didn't stop the
//           speed loop properly.
// v1.3.0  - Narrowed when the script runs so it only does anything on the
//           racing pages.
// v1.2.0  - Fixed track names with hyphens in them breaking the lap count.
// v1.1.0  - Removed the dependency on an external library.
// v1.0.0  - First release. Real-time speed display during races.

'use strict';

const $ = unsafeWindow.$;

// ─── Torn AJAX hook ────────────────────────────────────────────────────────────
function tornAjax(callback) {
    $(document).ajaxComplete((event, xhr, settings) => {
        if (xhr.readyState > 3 && xhr.status === 200) {
            if (settings.url && settings.url.includes('sid=racing')) {
                callback();
            }
        }
    });
}

// ─── Config ────────────────────────────────────────────────────────────────────
const POLL_MS = 1000;

// ─── State ─────────────────────────────────────────────────────────────────────
let last_compl      = -1.0;
let speedInterval   = 0;
let sessionTopSpeed = 0;
let currentTrack    = '';
let currentCar      = '';

// Lap timing state — reset each time the speed loop starts
let lapCount        = 0;    // how many full laps have been completed this session
let lastLapSplit    = 0;    // Date.now() when the previous lap boundary was crossed

// ─── Interval helpers ──────────────────────────────────────────────────────────
function maybeClear() {
    if (speedInterval !== 0) {
        clearInterval(speedInterval);
        last_compl      = -1.0;
        sessionTopSpeed = 0;
        speedInterval   = 0;
        lapCount        = 0;
        lastLapSplit    = 0;
    }
}

// ─── Storage ───────────────────────────────────────────────────────────────────
function getSpeedLog() {
    return JSON.parse(GM_getValue('torn_top_speeds', '{}'));
}

function saveSpeedLog(log) {
    GM_setValue('torn_top_speeds', JSON.stringify(log));
}

function carKey(carImg) {
    const m = (carImg || '').match(/items\/([0-9]+)\//);
    return m ? m[1] : 'unknown';
}

// Returns true if a new top speed was set.
function updateRecord(trackName, speed, carImg, bestLapMs) {
    const log      = getSpeedLog();
    const rounded  = parseFloat(speed.toFixed(2));
    const key      = trackName + '|' + carKey(carImg);
    const existing = log[key];

    let changed = false;

    if (!existing || rounded > existing.topSpeed) {
        if (!existing) {
            log[key] = { track: trackName, topSpeed: rounded, car: carImg || '', date: new Date().toISOString().split('T')[0] };
        } else {
            log[key].topSpeed = rounded;
            log[key].date     = new Date().toISOString().split('T')[0];
        }
        changed = true;
    }

    // Update best lap independently — a faster lap is always saved regardless
    // of whether the top speed improved.
    if (bestLapMs > 0) {
        if (!log[key]) {
            log[key] = { track: trackName, topSpeed: rounded, car: carImg || '', date: new Date().toISOString().split('T')[0] };
        }
        if (!existing || !existing.bestLapMs || bestLapMs < existing.bestLapMs) {
            log[key].bestLapMs = bestLapMs;
        }
    }

    saveSpeedLog(log);
    return changed;
}

// ─── Lap time formatting ───────────────────────────────────────────────────────
function formatLapTime(ms) {
    if (!ms || ms <= 0) return '–';
    const totalSec = Math.round(ms / 1000);
    const m = Math.floor(totalSec / 60);
    const s = totalSec % 60;
    return m + 'm ' + String(s).padStart(2, '0') + 's';
}

