// ─── UI ────────────────────────────────────────────────────────────────────────
function injectWidget() {
    if ($('#rslogWrapper').length > 0) return;

    const html = `
        <div id="rslogWrapper">
            <div id="rslogSpeedRow">
                <span id="rslogSpeed">–.– mph</span>
                <span id="rslogSessionTop">
                    Session top: <span id="rslogSessionTopVal">0.00</span> mph
                </span>
                <span id="rslogNewRecord">★ NEW RECORD</span>
                <span id="rslogToggle">▼ Top speeds</span>
            </div>
            <div id="rslogPanel">
                <table id="rslogTable">
                    <thead>
                        <tr>
                            <th>Track</th>
                            <th>Top Speed</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody id="rslogTableBody"></tbody>
                </table>
                <a id="rslogCsvBtn" href="#">⬇ Download CSV</a>
                <span id="rslogClearBtn">✕ Clear all</span>
            </div>
        </div>
    `;

    if ($('#racingdetails').length > 0) {
        $('#racingdetails').after(html);
    } else {
        $('#racingupdatesnew').prepend(html);
    }

    $('#rslogToggle').on('click', function () {
        const panel = $('#rslogPanel');
        const wasOpen = panel.is(':visible');
        panel.toggle();
        $(this).text(wasOpen ? '▼ Top speeds' : '▲ Top speeds');
        if (!wasOpen) renderLogTable();
    });

    $('#rslogCsvBtn').on('click', function (e) {
        e.preventDefault();
        downloadCsv();
    });

    $('#rslogClearBtn').on('click', function () {
        if (confirm('Clear all saved top speed records?')) {
            saveSpeedLog({});
            renderLogTable();
        }
    });
}

function escapeHtml(str) {
    return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
}

function renderLogTable() {
    const log     = getSpeedLog();
    const tbody   = $('#rslogTableBody');
    tbody.empty();

    const entries = Object.entries(log).sort((a, b) => b[1].topSpeed - a[1].topSpeed);

    if (entries.length === 0) {
        tbody.append('<tr><td colspan="3" style="color:#555;padding:6px;">No records yet.</td></tr>');
        return;
    }

    for (const [track, data] of entries) {
        const isCurrent = (track === currentTrack);
        tbody.append(`
            <tr class="${isCurrent ? 'rslogCurrentTrack' : ''}">
                <td>${escapeHtml(track)}</td>
                <td class="rslogTopSpeed">${data.topSpeed.toFixed(2)} mph</td>
                <td>${data.date}</td>
            </tr>
        `);
    }
}

function downloadCsv() {
    const log = getSpeedLog();
    let csv   = 'Track,Top Speed (mph),Date\n';
    for (const [track, data] of Object.entries(log)) {
        csv += `"${track.replace(/"/g, '""')}",${data.topSpeed.toFixed(2)},${data.date}\n`;
    }
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = 'torn_top_speeds.csv';
    a.click();
    URL.revokeObjectURL(url);
}

// ─── Speed polling ─────────────────────────────────────────────────────────────
function startSpeedLoop() {
    maybeClear();
    speedInterval = setInterval(function () {
        const trackInfo = $('#racingupdatesnew').find('div.track-info');
        if (trackInfo.length < 1) {
            maybeClear();
            return;
        }

        const titleText = $('#racingupdatesnew').find('div.title-black').text();
        const parts     = titleText.split(' - ');
        const lapString = parts.pop();                  // always the last segment e.g. "15 Laps"
        const laps      = parseFloat(lapString);
        currentTrack    = parts.join(' - ').trim();     // re-join so "Custom-Track" stays intact
        const len       = parseFloat(trackInfo.attr('data-length').replace('mi', ''));
        const compl     = parseFloat($('#racingdetails').find('li.pd-completion').text().replace('%', ''));

        if (last_compl >= 0) {
            const speed = (compl - last_compl) / 100 * laps * len * 3600000 / POLL_MS;

            $('#rslogSpeed').text(speed.toFixed(2) + ' mph');

            if (speed > sessionTopSpeed) {
                sessionTopSpeed = speed;
                $('#rslogSessionTopVal').text(speed.toFixed(2));
            }

            if (updateRecord(currentTrack, speed)) {
                $('#rslogNewRecord').stop(true, true).show().delay(2000).fadeOut(500);
                if ($('#rslogPanel').is(':visible')) renderLogTable();
            }
        }

        last_compl = compl;
    }, POLL_MS);
}

// ─── Init ──────────────────────────────────────────────────────────────────────
function init() {
    if ($('#racingdetails').length < 1) return;
    if ($('#rslogWrapper').length > 0)  return;
    injectWidget();
    startSpeedLoop();
}

// Re-init when navigating to racing; clean up when navigating away.
tornAjax((isRacingXhr) => {
    if (isRacingXhr) {
        $('#racingupdatesnew').ready(init);
    } else {
        maybeClear();
    }
});

// Initial page load
$('#racingupdatesnew').ready(init);
