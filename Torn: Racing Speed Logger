    if ($('#rslogWrapper').length > 0) return;

    const html =
        '<div id="rslogWrapper">' +
        '  <div id="rslogSpeedRow">' +
        '    <span id="rslogSpeed">–.– mph</span>' +
        '    <span id="rslogSessionTop">Session top: <span id="rslogSessionTopVal">0.00</span> mph</span>' +
        '    <span id="rslogNewRecord">★ NEW RECORD</span>' +
        '    <span id="rslogToggle">▼ Top speeds</span>' +
        '  </div>' +
        '  <div id="rslogPanel">' +
        '    <table id="rslogTable">' +
        '      <thead><tr><th>Track</th><th>Car</th><th>Top Speed</th><th>Best Lap</th><th>Date</th></tr></thead>' +
        '      <tbody id="rslogTableBody"></tbody>' +
        '    </table>' +
        '    <a id="rslogCsvBtn" href="#">⬇ Download CSV</a>' +
        '    <span id="rslogClearBtn">✕ Clear all</span>' +
        '  </div>' +
        '</div>';

    if ($('#racingdetails').length > 0) {
        $('#racingdetails').after(html);
    } else if ($('#racingupdatesnew').length > 0) {
        $('#racingupdatesnew').prepend(html);
    }

    $('#rslogToggle').on('click', function () {
        const panel  = $('#rslogPanel');
        const wasOpen = panel.is(':visible');
        panel.toggle();
        $(this).text(wasOpen ? '▼ Top speeds' : '▲ Top speeds');
        if (!wasOpen) renderLogTable();
    });

    $('#rslogCsvBtn').on('click', function (e) {
        e.preventDefault();
        downloadCsv();
    });

    $('#rslogClearBtn').on('click', function () {
        if (confirm('Clear all saved top speed records?')) {
            saveSpeedLog({});
            renderLogTable();
        }
    });
}

function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

function renderLogTable() {
    const log    = getSpeedLog();
    const tbody  = $('#rslogTableBody');
    tbody.empty();
    const entries = Object.entries(log).sort((a, b) => b[1].topSpeed - a[1].topSpeed);
    if (entries.length === 0) {
        tbody.append('<tr><td colspan="5" style="color:#555;padding:6px;">No records yet.</td></tr>');
        return;
    }
    for (const [key, data] of entries) {
        const trackName = data.track || key.split('|')[0];
        const isCurrent = (trackName === currentTrack);
        tbody.append(
            '<tr class="' + (isCurrent ? 'rslogCurrentTrack' : '') + '">' +
            '<td>' + escapeHtml(trackName) + '</td>' +
            '<td class="rslogCar">' + (data.car ? '<img src="' + data.car + '" title="' + (carName(data.car) || 'Unknown car') + '">' : '–') + '</td>' +
            '<td class="rslogTopSpeed">' + data.topSpeed.toFixed(2) + ' mph</td>' +
            '<td class="rslogBestLap">' + formatLapTime(data.bestLapMs) + '</td>' +
            '<td>' + data.date + '</td>' +
            '</tr>'
        );
    }
}

function downloadCsv() {
    const log = getSpeedLog();
    let csv   = 'Track,Car,Top Speed (mph),Best Lap,Date\n';
    for (const [key, data] of Object.entries(log)) {
        const trackName = data.track || key.split('|')[0];
        csv += '"' + trackName.replace(/"/g, '""') + '",' +
               '"' + (data.car || '').replace(/"/g, '""') + '",' +
               data.topSpeed.toFixed(2) + ',' +
               formatLapTime(data.bestLapMs) + ',' +
               data.date + '\n';
    }
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = 'torn_top_speeds.csv';
    a.click();
    URL.revokeObjectURL(url);
}

// ─── Car name ──────────────────────────────────────────────────────────────────
function parseCarImg() {
    const img = document.querySelector('.car-selected .torn-item');
    if (img && img.src) {
        return img.src.replace('/large.png', '/small.png');
    }
    return '';
}

// ─── Firework burst ────────────────────────────────────────────────────────────
function launchFirework() {
    const el = document.getElementById('rslogNewRecord');
    if (!el) return;

    const rect = el.getBoundingClientRect();
    const cx   = rect.left + rect.width / 2;
    const cy   = rect.top  + rect.height / 2;

    const canvas  = document.createElement('canvas');
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    Object.assign(canvas.style, {
        position:      'fixed',
        top:           '0',
        left:          '0',
        pointerEvents: 'none',
        zIndex:        '999999'
    });
    document.body.appendChild(canvas);

    const ctx      = canvas.getContext('2d');
    const colors   = ['#00ff88', '#fff200', '#ff9900', '#ffffff', '#00cfff'];
    const particles = [];
    const COUNT    = 60;

    for (let i = 0; i < COUNT; i++) {
        const angle  = (Math.PI * 2 / COUNT) * i + Math.random() * 0.3;
        const speed  = 3 + Math.random() * 6;
        particles.push({
            x:    cx,
            y:    cy,
            vx:   Math.cos(angle) * speed,
            vy:   Math.sin(angle) * speed,
            alpha: 1,
            size: 2 + Math.random() * 3,
            color: colors[Math.floor(Math.random() * colors.length)]
        });
    }

    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        let alive = false;
        for (const p of particles) {
            if (p.alpha <= 0) continue;
            alive = true;
            p.x     += p.vx;
            p.y     += p.vy;
            p.vy    += 0.12;
            p.alpha -= 0.018;
            ctx.globalAlpha = Math.max(0, p.alpha);
            ctx.fillStyle   = p.color;
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
            ctx.fill();
        }
        if (alive) {
            requestAnimationFrame(draw);
        } else {
            canvas.remove();
        }
    }
    requestAnimationFrame(draw);
}

// ─── Best lap from AJAX response ──────────────────────────────────────────────
// Torn encodes each driver's full interval data as a base64 string in the
// racing AJAX response. We decode it, sum per-lap intervals, and take the
// minimum — exactly the same approach as the Lugburz Racing Enhancements
// script, which is where this data source was identified.
//
// data.raceData.cars        — { playerName: base64string, ... }
// data.raceData.trackData.intervals — array of interval definitions (length = segments per lap)
// data.laps                 — total laps in the race
// data.user.playername      — the current player's name
// data.timeData.status      — 3+ means race is running or finished (data available)
// Interval values are in seconds; we convert to ms for storage.

function parseBestLapFromResponse(data) {
    try {
        if (!data || !data.timeData || data.timeData.status < 3) return;
        const cars         = data.raceData && data.raceData.cars;
        const trackData    = data.raceData && data.raceData.trackData;
        const playerName   = data.user && data.user.playername;
        const totalLaps    = data.laps;
        if (!cars || !trackData || !playerName || !totalLaps) return;

        const encoded = cars[playerName];
        if (!encoded) return;

        const trackIntervals = trackData.intervals.length;
        // atob is equivalent to the Lugburz decode64 for clean base64
        const decoded  = atob(encoded);
        const intervals = decoded.split(',').map(Number);

        // Need at least one complete lap worth of intervals
        if (intervals.length < trackIntervals) return;

        const completedLaps = Math.floor(intervals.length / trackIntervals);
        let bestLapSec = Infinity;
        for (let i = 0; i < completedLaps; i++) {
            let lapTime = 0;
            for (let j = 0; j < trackIntervals; j++) {
                lapTime += intervals[i * trackIntervals + j];
            }
            if (lapTime > 0) bestLapSec = Math.min(bestLapSec, lapTime);
        }

        if (bestLapSec === Infinity) return;
        const bestLapMs = Math.round(bestLapSec * 1000);

        // currentTrack / currentCar may not be set yet if the speed loop
        // hasn't ticked. Read them fresh from the DOM as fallback.
        const trackEl   = document.querySelector('div.title-black.t-overflow');
        const trackText = trackEl ? trackEl.textContent.trim() : '';
        const clean     = trackText.replace(/\s*-\s*(Race started|Race finished|Waiting.*|Cancelled.*)$/i, '').trim();
        const parts     = clean.split(' - ');
        parts.pop(); // remove lap count
        const trackName = parts.join(' - ').trim() || currentTrack;
        const carImg    = parseCarImg() || currentCar;
        if (!trackName || !carImg) return;

        updateBestLap(trackName, carImg, bestLapMs);
        if ($('#rslogPanel').is(':visible')) renderLogTable();
        if ($('#rslogLobbyPanel').is(':visible')) renderLobbyTable();
    } catch (e) {
        // fail silently — best lap is a nice-to-have
    }
}

// ─── Speed polling ─────────────────────────────────────────────────────────────
function getCompletion() {
    const el = document.querySelector('li.pd-completion');
    if (!el) return NaN;
    return parseFloat(el.textContent.replace('%', '').trim());
}

function startSpeedLoop() {
    maybeClear();
    speedInterval = setInterval(function () {
        const trackInfo = $('#racingupdatesnew').find('div.track-info');
        if (trackInfo.length < 1) {
            maybeClear();
            return;
        }

        const titleEl    = document.querySelector('div.title-black.t-overflow');
        const titleText  = titleEl ? titleEl.textContent.trim() : '';
        const cleanTitle = titleText.replace(/\s*-\s*(Race started|Race finished|Waiting.*|Cancelled.*)$/i, '').trim();
        const parts      = cleanTitle.split(' - ');
        const lapString  = parts.pop();
        const laps       = parseFloat(lapString);
        currentTrack     = parts.join(' - ').trim();
        const len        = parseFloat(trackInfo.attr('data-length'));
        const compl      = getCompletion();

        const foundCar = parseCarImg();
        if (foundCar) currentCar = foundCar;

        if (isNaN(compl) || isNaN(laps) || isNaN(len)) return;

        // ── Speed calculation ─────────────────────────────────────────────────
        if (last_compl >= 0) {
            const speed = (compl - last_compl) / 100 * laps * len * 3600000 / POLL_MS;

            if (speed > 0 && speed < 400) {
                $('#rslogSpeed').text(speed.toFixed(2) + ' mph');

                if (speed > sessionTopSpeed) {
                    sessionTopSpeed = speed;
                    $('#rslogSessionTopVal').text(speed.toFixed(2));
                }

                if (updateTopSpeed(currentTrack, speed, currentCar)) {
                    $('#rslogNewRecord').stop(true, true).show().delay(2000).fadeOut(500);
                    launchFirework();
                    if ($('#rslogPanel').is(':visible')) renderLogTable();
                }
            }
        }

        last_compl = compl;
    }, POLL_MS);
}

// ─── Lobby panel ───────────────────────────────────────────────────────────────
function injectLobbyPanel() {
    if ($('#rslogLobbyBtn').length > 0) return;

    const btn   = '<button id="rslogLobbyBtn">▼ Top Speeds Log</button>';
    const panel =
        '<div id="rslogLobbyPanel">' +
        '  <table>' +
        '    <thead><tr><th>Track</th><th>Car</th><th>Top Speed</th><th>Best Lap</th><th>Date</th></tr></thead>' +
        '    <tbody id="rslogLobbyTableBody"></tbody>' +
        '  </table>' +
        '  <div id="rslogLobbyFooter">' +
        '    <a id="rslogLobbyCsvBtn" href="#">⬇ Download CSV</a>' +
        '    <span id="rslogLobbyClearBtn">✕ Clear all</span>' +
        '  </div>' +
        '</div>';

    $('#racingAdditionalContainer').prepend(panel).prepend(btn);

    $('#rslogLobbyBtn').on('click', function () {
        const panelEl = $('#rslogLobbyPanel');
        const wasOpen = panelEl.is(':visible');
        panelEl.toggle();
        $(this).text(wasOpen ? '▼ Top Speeds Log' : '▲ Top Speeds Log');
        if (!wasOpen) renderLobbyTable();
    });

    $('#rslogLobbyCsvBtn').on('click', function (e) {
        e.preventDefault();
        downloadCsv();
    });

    $('#rslogLobbyClearBtn').on('click', function () {
        if (confirm('Clear all saved top speed records?')) {
            saveSpeedLog({});
            renderLobbyTable();
        }
    });
}

function renderLobbyTable() {
    const log    = getSpeedLog();
    const tbody  = $('#rslogLobbyTableBody');
    tbody.empty();
    const entries = Object.entries(log).sort((a, b) => b[1].topSpeed - a[1].topSpeed);
    if (entries.length === 0) {
        tbody.append('<tr><td colspan="5" style="color:#555;padding:6px;">No records yet — complete a race first.</td></tr>');
        return;
    }
    for (const [key, data] of entries) {
        const trackName = data.track || key.split('|')[0];
        tbody.append(
            '<tr>' +
            '<td>' + escapeHtml(trackName) + '</td>' +
            '<td class="rslogCar">' + (data.car ? '<img src="' + data.car + '" title="' + (carName(data.car) || 'Unknown car') + '">' : '–') + '</td>' +
            '<td class="rslogTopSpeed">' + data.topSpeed.toFixed(2) + ' mph</td>' +
            '<td class="rslogBestLap">' + formatLapTime(data.bestLapMs) + '</td>' +
            '<td>' + data.date + '</td>' +
            '</tr>'
        );
    }
}

function initLobby() {
    if ($('#racingAdditionalContainer').length < 1) return;
    if ($('#racingdetails').length > 0) return;
    injectLobbyPanel();
}

// ─── Init ──────────────────────────────────────────────────────────────────────
let _raceObserver = null;

function watchForRaceStart() {
    if (_raceObserver) return;
    _raceObserver = new MutationObserver(() => {
        if (document.getElementById('racingdetails') && !document.getElementById('rslogWrapper')) {
            injectWidget();
            startSpeedLoop();
        }
        if (document.getElementById('racingAdditionalContainer') && !document.getElementById('racingdetails')) {
            initLobby();
        }
        if (!document.getElementById('racingAdditionalContainer') && !document.getElementById('racingdetails')) {
            maybeClear();
        }
    });
    _raceObserver.observe(document.body, { childList: true, subtree: true });
}

function init() {
    if (document.getElementById('racingdetails') && !document.getElementById('rslogWrapper')) {
        injectWidget();
        startSpeedLoop();
    } else if (document.getElementById('racingAdditionalContainer') && !document.getElementById('racingdetails')) {
        initLobby();
    }
    watchForRaceStart();
}

tornAjax(() => { init(); });
init();
