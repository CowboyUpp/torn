// ==UserScript==
// @name         Torn: Racing Speed Logger
// @namespace    cowboyup.racing_speed_log
// @version      1.4.0
// @description  Real-time speed display + lifetime top speed log per track with CSV export. No external dependencies.
// @author       cowboyup
// @license      MIT
// @match        https://www.torn.com/*
// @grant        GM_setValue
// @grant        GM_getValue
// @grant        GM_addStyle
// ==/UserScript==
//
// Changelog:
// v1.4.0 - Fix tornAjax: page param was always "loader"/"page" (cut at .php),
//           making the cleanup else-branch dead code. Now passes isRacingXhr
//           bool (url.includes("sid=racing")) so cleanup fires correctly.
// v1.3.0 - Script now loads on all torn.com pages (required for SPA) but
//           strictly gates init and teardown via tornAjax and #racingupdatesnew.
// v1.2.0 - Fix track name parsing: use parts.pop() so hyphens in track names
//           don't corrupt the lap count or currentTrack string.
// v1.1.0 - Removed external @require dependency (lugburz_lib); inlined tornAjax().
// v1.0.0 - Initial release: real-time speed, session top, lifetime records per
//           track, expandable log table, CSV export, clear-all.

'use strict';

// ─── Torn AJAX hook ────────────────────────────────────────────────────────────
// Fires on every internal XHR. Passes isRacingXhr=true only when the request
// URL contains "sid=racing" — the only reliable signal in Torn's SPA since
// every XHR goes through loader.php or page.php regardless of section.
function tornAjax(callback) {
    $(document).ajaxComplete((event, xhr, settings) => {
        if (xhr.readyState > 3 && xhr.status === 200) {
            const isRacingXhr = settings.url.includes('sid=racing');
            callback(isRacingXhr, xhr, settings);
        }
    });
}

// ─── Config ────────────────────────────────────────────────────────────────────
const POLL_MS = 1000;

// ─── State ─────────────────────────────────────────────────────────────────────
let last_compl    = -1.0;
let speedInterval = 0;
let sessionTopSpeed = 0;
let currentTrack  = '';

// ─── Interval helpers ──────────────────────────────────────────────────────────
function maybeClear() {
    if (speedInterval !== 0) {
        clearInterval(speedInterval);
        last_compl      = -1.0;
        sessionTopSpeed = 0;
        speedInterval   = 0;
    }
}

// ─── Storage ───────────────────────────────────────────────────────────────────
function getSpeedLog() {
    return JSON.parse(GM_getValue('torn_top_speeds', '{}'));
}

function saveSpeedLog(log) {
    GM_setValue('torn_top_speeds', JSON.stringify(log));
}

// Returns true if a new record was set
function updateRecord(trackName, speed) {
    const log     = getSpeedLog();
    const rounded = parseFloat(speed.toFixed(2));
    const existing = log[trackName];
    if (!existing || rounded > existing.topSpeed) {
        log[trackName] = {
            topSpeed: rounded,
            date: new Date().toISOString().split('T')[0]
        };
        saveSpeedLog(log);
        return true;
    }
    return false;
}

