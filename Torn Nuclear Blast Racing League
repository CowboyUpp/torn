// ==UserScript==
// @name         Torn Nuclear Blast Racing League
// @namespace    torn.com
// @version      3.1
// @description  Multi-track faction racing league: skill-bracket teams (steward-assigned snake draft OR open self-signup), race result capture, points standings, real-time sync via a Cloudflare Worker backend, tooltip help throughout.
// @author       cowboyup
// @match        https://www.torn.com/*
// @grant        GM_setValue
// @grant        GM_getValue
// @grant        GM_addStyle
// @grant        GM_xmlhttpRequest
// @connect      *
// @grant        unsafeWindow
// @license      MIT
// @downloadURL https://update.greasyfork.org/scripts/583776/Torn%20Nuclear%20Blast%20Racing%20League.user.js
// @updateURL https://update.greasyfork.org/scripts/583776/Torn%20Nuclear%20Blast%20Racing%20League.meta.js
// ==/UserScript==

(function () {
  'use strict';

  const $ = unsafeWindow.$;

  /* ============================================================
     CONFIG / STORAGE KEYS
     ============================================================ */
  const K_API_KEY       = 'trl_api_key';
  const K_FACTION_ID    = 'trl_faction_id';
  const K_STEWARD_HASH  = 'trl_steward_hash';
  const K_SERIES        = 'trl_series';        // { [id]: SeriesConfig } — local cache, mirrors backend
  const K_TEAMS         = 'trl_teams';         // { [seriesId]: Team[] } — local cache, mirrors backend
  const K_RESULTS       = 'trl_results';       // { [seriesId]: RaceResult[] } — local only, not yet synced
  const K_ROSTER_CACHE  = 'trl_roster_cache';  // { time, members:[...] } — local cache, mirrors backend
  const K_MY_NAME       = 'trl_my_name';       // this browser's identity for self-signup
  const K_WORKER_CONFIG = 'trl_worker_config'; // { url, adminToken } — the Cloudflare Worker backend

  const DEFAULT_POINTS = [25, 18, 15, 12, 10, 8, 6, 4, 2, 1];

  /* ============================================================
     GENERIC STORAGE HELPERS
     ============================================================ */
  function loadJSON(key, fallback) {
    try { return JSON.parse(GM_getValue(key, JSON.stringify(fallback))); }
    catch (e) { return fallback; }
  }
  function saveJSON(key, value) { GM_setValue(key, JSON.stringify(value)); }

  const getSeries       = () => loadJSON(K_SERIES, {});
  const saveSeries      = (s) => saveJSON(K_SERIES, s);
  const getTeams        = () => loadJSON(K_TEAMS, {});
  const saveTeams       = (t) => saveJSON(K_TEAMS, t);
  const getResults      = () => loadJSON(K_RESULTS, {});
  const saveResults     = (r) => saveJSON(K_RESULTS, r);
  const getRosterCache  = () => loadJSON(K_ROSTER_CACHE, { time: 0, members: [] });
  const saveRosterCache = (c) => saveJSON(K_ROSTER_CACHE, c);
  const getWorkerConfig  = () => loadJSON(K_WORKER_CONFIG, {});
  const saveWorkerConfig = (c) => saveJSON(K_WORKER_CONFIG, c);

  function uid(prefix) { return prefix + '_' + Date.now().toString(36) + Math.random().toString(36).slice(2, 7); }
  function escapeHtml(s) { return (s || '').toString().replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }

  /* ============================================================
     TOOLTIP HELPER
     ============================================================ */
  function tip(text) {
    return `<span class="trl-tip" data-tooltip="${escapeHtml(text)}">ⓘ</span>`;
  }

  /* ============================================================
     STEWARD PASSPHRASE (local UI gate)
     This is still just a quick client-side lock to keep casual
     faction members out of the Steward tab. The REAL security
     boundary is now the Worker's ADMIN_TOKEN, checked server-side
     on every write — that one can't be bypassed from devtools.
     ============================================================ */
  async function sha256(str) {
    const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
    return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
  }

  let stewardUnlocked = false;

  async function trySetOrCheckSteward(pass) {
    const stored = GM_getValue(K_STEWARD_HASH, '');
    const hash = await sha256(pass);
    if (!stored) { GM_setValue(K_STEWARD_HASH, hash); stewardUnlocked = true; return { ok: true, firstTime: true }; }
    if (stored === hash) { stewardUnlocked = true; return { ok: true, firstTime: false }; }
    return { ok: false };
  }

  /* ============================================================
     CLOUDFLARE WORKER BACKEND
     All of this is optional — if no URL is configured, every
     function below degrades gracefully and the script falls back
     to the local-only behavior. Once a URL is set, the Worker
     becomes the source of truth for series/roster/teams; claims
     are validated and serialized server-side via Durable Objects.
     ============================================================ */
  function gmRequest(opts) {
    return new Promise((resolve, reject) => {
      if (typeof GM_xmlhttpRequest === 'undefined') { reject(new Error('GM_xmlhttpRequest unavailable')); return; }
      GM_xmlhttpRequest({ ...opts, onload: resolve, onerror: reject, ontimeout: () => reject(new Error('timeout')) });
    });
  }

  async function apiGetRaw(path) {
    const cfg = getWorkerConfig();
    if (!cfg.url) return null;
    try {
      const res = await gmRequest({ method: 'GET', url: `${cfg.url}${path}` });
      if (res.status >= 400) return null;
      return JSON.parse(res.responseText);
    } catch (e) { return null; }
  }

  async function apiPostRaw(path, body, adminRequired) {
    const cfg = getWorkerConfig();
    if (!cfg.url) return { ok: false, message: 'No league server connected (🔌 Connect, top of this window).' };
    const headers = { 'Content-Type': 'application/json' };
    if (adminRequired) {
      if (!cfg.adminToken) return { ok: false, message: 'Steward admin token not set (Steward tab).' };
      headers['Authorization'] = `Bearer ${cfg.adminToken}`;
    }
    try {
      const res = await gmRequest({ method: 'POST', url: `${cfg.url}${path}`, headers, data: JSON.stringify(body || {}) });
      let parsed = {};
      try { parsed = JSON.parse(res.responseText); } catch (e) {}
      if (res.status >= 400) return { ok: false, message: parsed.error || `Server error (HTTP ${res.status})` };
      return { ok: true, data: parsed };
    } catch (e) { return { ok: false, message: 'Request failed: ' + (e && e.message ? e.message : e) }; }
  }

  const apiGetTeams        = (seriesId) => apiGetRaw(`/api/${seriesId}/teams`);
  const apiGetRoster       = (seriesId) => apiGetRaw(`/api/${seriesId}/roster`);
  const apiGetSeries       = (seriesId) => apiGetRaw(`/api/${seriesId}/series`);
  const apiClaim           = (seriesId, name, teamId, bracket) => apiPostRaw(`/api/${seriesId}/claim`, { name, teamId, bracket });
  const apiRelease         = (seriesId, name, teamId) => apiPostRaw(`/api/${seriesId}/release`, { name, teamId });
  const apiSetTeams        = (seriesId, teams) => apiPostRaw(`/api/${seriesId}/admin/teams`, { teams }, true);
  const apiSetRoster       = (seriesId, members, brackets) => apiPostRaw(`/api/${seriesId}/admin/roster`, { members, brackets }, true);
  const apiSetSeries       = (seriesId, series) => apiPostRaw(`/api/${seriesId}/admin/series`, { series }, true);
  const apiRegistryReg     = (id, name, active) => apiPostRaw('/api/_registry/register', { id, name, active }, true);
  const apiRegistryRemove  = (id) => apiPostRaw('/api/_registry/remove', { id }, true);

  async function apiRegistryList() {
    const resp = await apiGetRaw('/api/_registry/list');
    return resp && resp.series ? resp.series : [];
  }

  function connectToBackend() {
    const cur = getWorkerConfig().url || '';
    const url = prompt("Paste the league server URL your steward shared with you (e.g. https://your-worker.workers.dev):", cur);
    if (url === null) return;
    const cfg = getWorkerConfig();
    cfg.url = url.trim().replace(/\/+$/, '');
    saveWorkerConfig(cfg);
    populateSeriesSelect().then(() => renderTab());
  }

  /** Pulls series metadata + roster + teams for one series from the
   * Worker and merges them into local storage. No-ops silently if
   * no Worker is configured. */
  async function loadSeriesFromBackend(seriesId) {
    if (!seriesId) return;
    const cfg = getWorkerConfig();
    if (!cfg.url) return;

    const seriesResp = await apiGetSeries(seriesId);
    if (seriesResp && seriesResp.series) {
      const all = getSeries();
      all[seriesId] = seriesResp.series;
      saveSeries(all);
    }

    const rosterResp = await apiGetRoster(seriesId);
    if (rosterResp && rosterResp.members && rosterResp.members.length) {
      saveRosterCache({ time: Date.now(), members: rosterResp.members });
      const all = getSeries();
      if (all[seriesId] && rosterResp.brackets) { all[seriesId].brackets = rosterResp.brackets; saveSeries(all); }
    }

    const teamsResp = await apiGetTeams(seriesId);
    if (teamsResp && teamsResp.teams) {
      const all = getTeams();
      all[seriesId] = teamsResp.teams;
      saveTeams(all);
    }
  }

  /* ============================================================
     FACTION ROSTER + RACING SKILL  (Torn API, steward-only)
     ============================================================ */
  async function delay(ms) { return new Promise(r => setTimeout(r, ms)); }

  async function fetchWithRetry(url, retries = 3, backoff = 2000) {
    let wait = backoff;
    for (let i = 0; i < retries; i++) {
      try {
        const res = await fetch(url + (url.includes('?') ? '&' : '?') + 'comment=TRL_League_v3');
        const d = await res.json();
        if (d.error && (d.error.code === 5 || d.error.code === 8)) { await delay(wait); wait *= 2; continue; }
        return d;
      } catch (e) { await delay(1000); }
    }
    return null;
  }

  async function refreshRoster(apiKey, factionId, onProgress) {
    const factionData = await fetchWithRetry(`https://api.torn.com/faction/${factionId}?selections=basic&key=${apiKey}`);
    if (!factionData || factionData.error) return { error: true, message: factionData?.error?.error || 'API request failed' };

    const entries = Object.entries(factionData.members || {});
    const members = entries.map(([id, m]) => ({ id, name: m.name, position: m.position, skill: 0 }));

    for (let i = 0; i < members.length; i++) {
      const d = await fetchWithRetry(`https://api.torn.com/user/${members[i].id}?selections=personalstats&key=${apiKey}`);
      if (d && d.personalstats) members[i].skill = Number(d.personalstats.racingskill) || 0;
      if (onProgress) onProgress(i + 1, members.length);
      await delay(650);
    }

    const cache = { time: Date.now(), members };
    saveRosterCache(cache);
    return { error: false, members };
  }

  /* ============================================================
     SKILL BRACKETS
     ============================================================ */
  function bracketOf(skill, brackets) {
    if (skill < brackets.rookieMax) return 'Rookie';
    if (skill < brackets.skilledMax) return 'Skilled';
    return 'Pro';
  }
  const BRACKET_COLOR = { Rookie: '#16a34a', Skilled: '#2563eb', Pro: '#b45309' };

  /* ============================================================
     STEWARD-ASSIGNED SNAKE DRAFT
     ============================================================ */
  function buildTeams(roster, teamCount, teamSize, brackets) {
    const tiers = { Pro: [], Skilled: [], Rookie: [] };
    roster.forEach(m => tiers[bracketOf(m.skill, brackets)].push(m));
    Object.values(tiers).forEach(arr => arr.sort((a, b) => b.skill - a.skill));

    const teams = Array.from({ length: teamCount }, (_, i) => ({ id: uid('team'), name: `Team ${i + 1}`, members: [] }));

    ['Pro', 'Skilled', 'Rookie'].forEach(bracket => {
      const pool = tiers[bracket];
      let idx = 0, dir = 1, guard = 0, p = 0;
      while (p < pool.length && guard < pool.length * teamCount * 3) {
        guard++;
        const team = teams[idx];
        if (team.members.length < teamSize) {
          team.members.push({ ...pool[p], bracket });
          p++;
        }
        if (dir === 1 && idx === teamCount - 1) dir = -1;
        else if (dir === -1 && idx === 0) dir = 1;
        else idx += dir;
      }
    });

    return teams;
  }

  /* ============================================================
     OPEN SELF-SIGNUP TEAMS — local fallback logic
     Used directly when no Worker is connected. When a Worker IS
     connected, claims go through apiClaim/apiRelease instead (see
     the Sign Up tab handlers below) and these are just the offline
     fallback so the feature still works for a single browser.
     ============================================================ */
  function createOpenTeams(teamCount, slotShape) {
    return Array.from({ length: teamCount }, (_, i) => ({
      id: uid('team'), name: `Team ${i + 1}`,
      slotShape: { ...slotShape },
      members: [],
    }));
  }

  function claimSlotLocal(seriesId, teamId, bracket) {
    const myName = GM_getValue(K_MY_NAME, '');
    if (!myName) return { ok: false, message: 'Pick who you are first (top of this tab).' };

    const rosterMember = getRosterCache().members.find(m => m.name.toLowerCase() === myName.toLowerCase());
    if (!rosterMember) return { ok: false, message: "You're not in the cached roster — ask the steward to refresh it." };

    const series = getSeries()[seriesId];
    const myBracket = bracketOf(rosterMember.skill, series.brackets);
    if (myBracket !== bracket) return { ok: false, message: `You're bracketed as ${myBracket}, not ${bracket}.` };

    const allTeams = getTeams();
    const teams = allTeams[seriesId] || [];
    const alreadyOn = teams.find(t => t.members.some(m => m.name.toLowerCase() === myName.toLowerCase()));
    if (alreadyOn) return { ok: false, message: `You're already on ${alreadyOn.name} — leave that slot first to switch.` };

    const team = teams.find(t => t.id === teamId);
    if (!team) return { ok: false, message: 'Team not found.' };
    const filled = team.members.filter(m => m.bracket === bracket).length;
    const cap = (team.slotShape && team.slotShape[bracket]) || 0;
    if (filled >= cap) return { ok: false, message: 'That slot just got taken — pick another.' };

    team.members.push({ name: rosterMember.name, bracket, skill: rosterMember.skill, claimedAt: Date.now() });
    saveTeams(allTeams);
    return { ok: true };
  }

  function releaseSlotLocal(seriesId, teamId) {
    const myName = GM_getValue(K_MY_NAME, '');
    const allTeams = getTeams();
    const team = (allTeams[seriesId] || []).find(t => t.id === teamId);
    if (!team) return;
    team.members = team.members.filter(m => m.name.toLowerCase() !== myName.toLowerCase());
    saveTeams(allTeams);
  }

  function pickIdentity(rerender) {
    const roster = getRosterCache().members;
    if (!roster.length) { alert('No roster cached yet — connect to the league server (🔌 Connect) or ask your steward to refresh it.'); return; }
    const name = prompt("Type your exact Torn name as it appears in the faction roster:", GM_getValue(K_MY_NAME, ''));
    if (!name) return;
    const match = roster.find(m => m.name.toLowerCase() === name.trim().toLowerCase());
    if (!match) { alert("Name not found in the cached roster. Check spelling, or ask the steward to refresh it."); return; }
    GM_setValue(K_MY_NAME, match.name);
    if (rerender) rerender();
  }

  let signupPollInterval = null;
  function stopSignupPolling() { if (signupPollInterval) { clearInterval(signupPollInterval); signupPollInterval = null; } }
  function startSignupPolling(body) {
    stopSignupPolling();
    const cfg = getWorkerConfig();
    if (!cfg.url) return;
    signupPollInterval = setInterval(async () => {
      if (!document.body.contains(body)) { stopSignupPolling(); return; }
      await loadSeriesFromBackend(currentSeriesId);
      renderSignUpTab(body);
    }, 10000);
  }

  /* ============================================================
     RACE RESULT CAPTURE
     Still local-only — this part hasn't moved to the Worker yet.
     Standings/Races tabs reflect whatever races THIS browser has
     captured; two people's local race lists can differ until that
     gets synced too. Flagging this as a known remaining gap.
     ============================================================ */
  function normalizeTrackName(titleText) {
    if (!titleText) return '';
    return titleText
      .split(/\s*-\s*(Race (started|finished|will Start|in progress)|Waiting|Cancelled|Starts:|lap|Lap|\d+\s+seconds?)/i)[0]
      .replace(/\s*-\s*\d+\s*laps?.*$/i, '')
      .replace(/\s*-\s*Starts:.*$/i, '')
      .trim() || titleText.trim();
  }

  function decodeAllRacers(data) {
    const cars = data?.raceData?.cars;
    const trackData = data?.raceData?.trackData;
    if (!cars || !trackData || !trackData.intervals) return [];
    const trackIntervals = trackData.intervals.length;

    const out = [];
    for (const [playerName, encoded] of Object.entries(cars)) {
      try {
        const decoded = atob(encoded);
        const intervals = decoded.split(',').map(Number).filter(n => !isNaN(n));
        const completedLaps = Math.floor(intervals.length / trackIntervals);
        const totalMs = Math.round(intervals.reduce((a, b) => a + b, 0) * 1000);
        if (totalMs > 0) out.push({ name: playerName, totalMs, completedLaps });
      } catch (e) { /* skip unparseable entry */ }
    }
    out.sort((a, b) => b.completedLaps - a.completedLaps || a.totalMs - b.totalMs);
    out.forEach((r, i) => { r.position = i + 1; });
    return out;
  }

  function raceKeyFor(track, racers) {
    const names = racers.map(r => r.name).sort().join(',');
    return `${track}::${names}::${racers.length}`;
  }

  function pointsForPosition(pos, table) { return table[pos - 1] ?? 0; }

  function findMatchingSeries(track) {
    const series = getSeries();
    return Object.values(series).filter(s => s.active && s.tracks.some(t => t.name.toLowerCase() === track.toLowerCase()));
  }

  function captureRace(seriesId, track, racers) {
    const series = getSeries()[seriesId];
    if (!series) return { ok: false, message: 'Series not found.' };

    const results = getResults();
    if (!results[seriesId]) results[seriesId] = [];

    const key = raceKeyFor(track, racers);
    if (results[seriesId].some(r => r.key === key)) {
      return { ok: false, message: 'This exact race is already logged for this series.' };
    }

    const roster = getRosterCache().members;
    const teams = (getTeams()[seriesId] || []);
    const nameToTeam = {};
    teams.forEach(t => t.members.forEach(m => { nameToTeam[m.name.toLowerCase()] = t; }));
    const nameToSkill = {};
    roster.forEach(m => { nameToSkill[m.name.toLowerCase()] = m.skill; });

    const standings = racers.map(r => {
      const skill = nameToSkill[r.name.toLowerCase()];
      const bracket = skill !== undefined ? bracketOf(skill, series.brackets) : 'Unranked';
      const team = nameToTeam[r.name.toLowerCase()];
      return {
        name: r.name, totalMs: r.totalMs, position: r.position,
        points: pointsForPosition(r.position, series.pointsTable),
        bracket, teamId: team ? team.id : null,
      };
    });

    results[seriesId].push({ id: uid('race'), key, track, capturedAt: Date.now(), standings });
    saveResults(results);
    return { ok: true, count: standings.length };
  }

  /* ============================================================
     STANDINGS COMPUTATION
     ============================================================ */
  function computeStandings(seriesId) {
    const races = getResults()[seriesId] || [];
    const teams = getTeams()[seriesId] || [];

    const indiv = {};
    const teamPoints = {};
    teams.forEach(t => { teamPoints[t.id] = 0; });

    races.forEach(race => {
      race.standings.forEach(s => {
        if (!indiv[s.name]) indiv[s.name] = { name: s.name, bracket: s.bracket, points: 0, races: 0 };
        indiv[s.name].points += s.points;
        indiv[s.name].races += 1;
        if (s.teamId && teamPoints[s.teamId] !== undefined) teamPoints[s.teamId] += s.points;
      });
    });

    const indivList = Object.values(indiv).sort((a, b) => b.points - a.points);
    const teamList = teams.map(t => ({ ...t, points: teamPoints[t.id] || 0 })).sort((a, b) => b.points - a.points);

    return { indivList, teamList, raceCount: races.length };
  }

  /* ============================================================
     STYLES
     ============================================================ */
  GM_addStyle(`
