// @downloadURL  https://update.greasyfork.org/scripts/583776/Torn%20Nuclear%20Blast%20Racing%20League.user.js
// @updateURL    https://update.greasyfork.org/scripts/583776/Torn%20Nuclear%20Blast%20Racing%20League.meta.js
// ==/UserScript==

(function () {
  'use strict';

  const $ = unsafeWindow.$;

  /* ============================================================
     ONLY RUNS ON RACING PAGES
     sid=racing, tab=cars, tab=parts, tab=race, tab=customrace,
     tab=stats — nothing else
     ============================================================ */
  function isRacingPage() {
    return /[?&]sid=racing/i.test(location.search);
  }

  /* ============================================================
     STORAGE HELPERS
     ============================================================ */
  function load(key, fallback) {
    try { return JSON.parse(GM_getValue(key, JSON.stringify(fallback))); }
    catch (e) { return fallback; }
  }
  function save(key, value) { GM_setValue(key, JSON.stringify(value)); }

  const K = {
    STEWARD:  'tnbrl_steward_hash',
    SERIES:   'tnbrl_series',   // { id, name, tracks:[{name,laps}], password, brackets, pointsTable }
    TEAMS:    'tnbrl_teams',    // Team[]
    RESULTS:  'tnbrl_results',  // RaceResult[]
    ROSTER:   'tnbrl_roster',   // { time, members:[{name,skill}] }
    THEME:    'tnbrl_theme',    // 'light'|'dark'
  };

  const getSeries  = () => load(K.SERIES, null);
  const saveSeries = (s) => save(K.SERIES, s);
  const getTeams   = () => load(K.TEAMS, []);
  const saveTeams  = (t) => save(K.TEAMS, t);
  const getResults = () => load(K.RESULTS, []);
  const saveResults= (r) => save(K.RESULTS, r);
  const getRoster  = () => load(K.ROSTER, { time: 0, members: [] });
  const saveRoster = (r) => save(K.ROSTER, r);
  const getTheme   = () => GM_getValue(K.THEME, 'light');
  const setTheme   = (t) => GM_setValue(K.THEME, t);

  function uid() { return Date.now().toString(36) + Math.random().toString(36).slice(2, 6); }
  function esc(s) { return (s || '').toString().replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  /* ============================================================
     STEWARD PASSPHRASE (client-side UI lock only)
     ============================================================ */
  async function sha256(str) {
    const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
    return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2,'0')).join('');
  }

  let stewardUnlocked = false;

  async function checkSteward(pass) {
    const stored = GM_getValue(K.STEWARD, '');
    const hash = await sha256(pass);
    if (!stored) { GM_setValue(K.STEWARD, hash); stewardUnlocked = true; return true; }
    if (stored === hash) { stewardUnlocked = true; return true; }
    return false;
  }

  /* ============================================================
     SKILL BRACKETS
     Based on the actual Nuclear Blast roster (99 members):
     Rookie < 11  → 32 members
     Skilled 11–23 → 34 members
     Pro ≥ 24     → 33 members
     Adjust rookieMax / skilledMax in the series config if needed.
     ============================================================ */
  const BRACKET_COLOR = { Rookie: '#16a34a', Skilled: '#2563eb', Pro: '#b45309' };

  function bracketOf(skill, brackets) {
    if (skill < brackets.rookieMax) return 'Rookie';
    if (skill < brackets.skilledMax) return 'Skilled';
    return 'Pro';
  }

  /* ============================================================
     SNAKE DRAFT TEAM BUILDER
     Sort roster by skill desc, deal into teams alternating
     direction each pass (Pro → Skilled → Rookie).
     ============================================================ */
  function buildTeams(roster, teamCount, teamSize, brackets) {
    const tiers = { Pro: [], Skilled: [], Rookie: [] };
    roster.forEach(m => tiers[bracketOf(m.skill, brackets)].push(m));
    Object.values(tiers).forEach(arr => arr.sort((a, b) => b.skill - a.skill));

    const teams = Array.from({ length: teamCount }, (_, i) => ({
      id: uid(), name: `Team ${i + 1}`, members: []
    }));

    ['Pro', 'Skilled', 'Rookie'].forEach(bracket => {
      const pool = tiers[bracket];
      let idx = 0, dir = 1, p = 0, guard = 0;
      while (p < pool.length && guard++ < pool.length * teamCount * 3) {
        const team = teams[idx];
        if (team.members.length < teamSize) {
          team.members.push({ ...pool[p], bracket });
          p++;
        }
        if (dir === 1 && idx === teamCount - 1) dir = -1;
        else if (dir === -1 && idx === 0) dir = 1;
        else idx += dir;
      }
    });

    return teams;
  }

  /* ============================================================
     TORN API ROSTER FETCH (steward only, runs once per season)
     Pulls Racing Skill for every faction member via the API.
     Rate-limited to ~90 requests/min to stay well within limits.
     ============================================================ */
  async function fetchRoster(apiKey, factionId, onProgress) {
    async function apiFetch(url) {
      try {
        const r = await fetch(url + (url.includes('?') ? '&' : '?') + 'comment=TNBRL_v4');
        return await r.json();
      } catch (e) { return null; }
    }

    const faction = await apiFetch(`https://api.torn.com/faction/${factionId}?selections=basic&key=${apiKey}`);
    if (!faction || faction.error) return { error: faction?.error?.error || 'API call failed' };

    const entries = Object.entries(faction.members || {});
    const members = entries.map(([id, m]) => ({ id, name: m.name, skill: 0 }));

    for (let i = 0; i < members.length; i++) {
      await new Promise(r => setTimeout(r, 680));
      const d = await apiFetch(`https://api.torn.com/user/${members[i].id}?selections=personalstats&key=${apiKey}`);
      if (d && d.personalstats) members[i].skill = Number(d.personalstats.racingskill) || 0;
      if (onProgress) onProgress(i + 1, members.length);
    }

    return { members };
  }

  /* ============================================================
     RACE RESULT CAPTURE
     Hooks Torn's racing AJAX, decodes every racer's interval
     data (same technique as the Speed & Lap Logger), assigns
     finish positions, and scores points.
     Caveat: status >= 3 is assumed "usable data" but hasn't been
     verified live — use the manual capture button if the auto-
     banner doesn't fire at race end.
     ============================================================ */
  function normalizeTrack(title) {
    if (!title) return '';
    return title
      .split(/\s*-\s*(Race (started|finished|will Start|in progress)|Waiting|Cancelled|Starts:|lap|Lap|\d+\s+sec)/i)[0]
      .replace(/\s*-\s*\d+\s*laps?.*$/i, '')
      .replace(/\s*-\s*Starts:.*$/i, '')
      .trim();
  }

  function decodeRacers(data) {
    const cars = data?.raceData?.cars;
    const intervals = data?.raceData?.trackData?.intervals;
    if (!cars || !intervals) return [];

    const out = [];
    for (const [name, encoded] of Object.entries(cars)) {
      try {
        const decoded = atob(encoded);
        const laps = decoded.split(',').map(Number).filter(n => !isNaN(n));
        const lapsCompleted = Math.floor(laps.length / intervals.length);
        const totalMs = Math.round(laps.reduce((a, b) => a + b, 0) * 1000);
        if (totalMs > 0) out.push({ name, totalMs, lapsCompleted });
      } catch (e) {}
    }
    out.sort((a, b) => b.lapsCompleted - a.lapsCompleted || a.totalMs - b.totalMs);
    out.forEach((r, i) => { r.position = i + 1; });
    return out;
  }

  function logRace(track, racers) {
    const series = getSeries();
    if (!series) return { ok: false, msg: 'No series set up yet — open the Steward tab.' };
    if (!series.tracks.some(t => t.name.toLowerCase() === track.toLowerCase())) {
      return { ok: false, msg: `"${track}" isn't in this series' track list.` };
    }

    const results = getResults();
    const key = `${track}::${racers.map(r => r.name).sort().join(',')}`;
    if (results.some(r => r.key === key)) return { ok: false, msg: 'This race is already logged.' };

    const roster = getRoster().members;
    const teams = getTeams();
    const byName = n => roster.find(m => m.name.toLowerCase() === n.toLowerCase());
    const teamOf = n => teams.find(t => t.members.some(m => m.name.toLowerCase() === n.toLowerCase()));
    const pts = series.pointsTable;

    const standings = racers.map(r => {
      const member = byName(r.name);
      const bracket = member ? bracketOf(member.skill, series.brackets) : 'Unranked';
      const team = teamOf(r.name);
      return {
        name: r.name, position: r.position, totalMs: r.totalMs,
        points: pts[r.position - 1] ?? 0, bracket,
        teamId: team ? team.id : null,
      };
    });

    results.push({ id: uid(), key, track, capturedAt: Date.now(), standings });
    saveResults(results);
    return { ok: true, count: standings.length };
  }

  /* ============================================================
     STANDINGS
     ============================================================ */
  function standings() {
    const results = getResults();
    const teams = getTeams();
    const drivers = {}, teamPts = {};
    teams.forEach(t => { teamPts[t.id] = 0; });

    results.forEach(race => {
      race.standings.forEach(s => {
        if (!drivers[s.name]) drivers[s.name] = { name: s.name, bracket: s.bracket, points: 0, races: 0 };
        drivers[s.name].points += s.points;
        drivers[s.name].races += 1;
        if (s.teamId && teamPts[s.teamId] !== undefined) teamPts[s.teamId] += s.points;
      });
    });

    const driverList = Object.values(drivers).sort((a, b) => b.points - a.points);
    const teamList = teams.map(t => ({ ...t, points: teamPts[t.id] || 0 })).sort((a, b) => b.points - a.points);
    return { driverList, teamList };
  }

  function fmtMs(ms) {
    const m = Math.floor(ms / 60000);
    const s = Math.floor((ms % 60000) / 1000);
    const cs = Math.floor((ms % 1000) / 10);
    return `${m}m ${String(s).padStart(2,'0')}.${String(cs).padStart(2,'0')}s`;
  }

  function downloadCsv(csv, name) {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(new Blob([csv], { type: 'text/csv' }));
    a.download = name; a.click();
  }

