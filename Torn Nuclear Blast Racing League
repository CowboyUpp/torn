      </div>`;
      document.getElementById('trl-pass-go').addEventListener('click', async () => {
        const pass = document.getElementById('trl-pass').value;
        if (!pass) return;
        const r = await trySetOrCheckSteward(pass);
        if (r.ok) renderStewardTab(body); else alert('Wrong passphrase.');
      });
      return;
    }

    const roster = getRosterCache();
    const series = getSeries();
    const workerCfg = getWorkerConfig();

    let html = `<div class="trl-card"><b>League server connection</b>${tip("This is what makes the Sign Up tab live across everyone's browsers, and what makes the steward gate a real server-enforced secret. The URL is safe to share with the whole faction — the admin token is not, keep that steward-only.")}<br><br>
      Worker URL: <input id="trl-worker-url" class="trl-input" value="${escapeHtml(workerCfg.url || '')}" style="width:280px;" placeholder="https://your-worker.workers.dev">
      Admin token: <input id="trl-worker-token" class="trl-input" type="password" value="${escapeHtml(workerCfg.adminToken || '')}" style="width:200px;">
      <button class="trl-btn primary" id="trl-worker-save">Save</button>
    </div>`;

    html += `<div class="trl-card">
      <b>Faction roster</b>${tip('Pulls every faction member\'s Racing Skill stat via the Torn API so the script can sort people into Rookie/Skilled/Pro. Re-run this occasionally — skill changes as people race.')} — ${roster.members.length} members cached (${roster.time ? new Date(roster.time).toLocaleString() : 'never'})
      <br><br>
      <input id="trl-api-key" class="trl-input" placeholder="Torn API key (limited access)" style="width:220px;" value="${escapeHtml(GM_getValue(K_API_KEY, ''))}">
      <input id="trl-faction-id" class="trl-input" placeholder="Faction ID" style="width:100px;" value="${escapeHtml(GM_getValue(K_FACTION_ID, ''))}">
      <button class="trl-btn primary" id="trl-refresh-roster">🔄 Refresh roster + skill</button>
      <div id="trl-roster-progress" style="font-size:11px; color:#9ca3af; margin-top:6px;"></div>
    </div>`;

    html += `<div class="trl-card"><b>Create a series</b>${tip('A "series" is one league: a list of tracks, the skill cutoffs for brackets, and how teams get built.')}<br><br>
      <input id="trl-new-name" class="trl-input" placeholder="Series name" style="width:200px;"><br><br>
      <textarea id="trl-new-tracks" class="trl-input" style="width:100%; height:70px;" placeholder="One track per line, format: Track Name, 50"></textarea>${tip("One line per track. Add a comma and a number to set custom laps, e.g. 'Uptown, 30'. Leave the number off for the default of 50.")}
      <div style="font-size:11px; color:#9ca3af; margin:4px 0;">Laps default to 50 per track if omitted.</div>
      Rookie max skill: <input id="trl-new-rookiemax" class="trl-input" type="number" value="11" style="width:60px;">${tip('Anyone with a Racing Skill below this number is bracketed as Rookie.')}
      Skilled max skill: <input id="trl-new-skilledmax" class="trl-input" type="number" value="24" style="width:60px;">${tip('Anyone between the Rookie cutoff and this number is Skilled; anyone above it is Pro.')}<br><br>
      Team mode:
      <label style="margin-left:6px;"><input type="radio" name="trl-mode" value="locked" checked> Steward-assigned</label>
      <label style="margin-left:10px;"><input type="radio" name="trl-mode" value="open"> Open sign-up</label>${tip('Steward-assigned: you run a snake draft and assign everyone yourself. Open sign-up: you just define empty seats per bracket, and members claim their own from the Sign Up tab.')}
      <br><br>
      Join password (the real Torn private-race password): <input id="trl-new-pass" class="trl-input" style="width:160px;">${tip('This is just a label shown to members — you still have to set this same password when you create the actual private race inside Torn.')}<br><br>
      <button class="trl-btn primary" id="trl-create-series">Create series</button>
    </div>`;

    if (currentSeriesId && series[currentSeriesId]) {
      const s = series[currentSeriesId];
      if (s.signupMode === 'open') {
        html += `<div class="trl-card"><b>Open sign-up team shapes — ${escapeHtml(s.name)}</b>${tip('Defines how many seats of each bracket every team has. Members then claim their own seat from the Sign Up tab.')}<br><br>
          Number of teams: <input id="trl-open-teamcount" class="trl-input" type="number" value="16" style="width:60px;">
          Pro seats/team: <input id="trl-open-pro" class="trl-input" type="number" value="2" style="width:50px;">
          Skilled seats/team: <input id="trl-open-skilled" class="trl-input" type="number" value="2" style="width:50px;">
          Rookie seats/team: <input id="trl-open-rookie" class="trl-input" type="number" value="2" style="width:50px;"><br><br>
          <button class="trl-btn primary" id="trl-create-open-teams">🪑 Create empty teams for sign-up</button>
          <div style="font-size:11px; color:#9ca3af; margin-top:6px;">Replaces any existing teams for this series.</div>
        </div>`;
      } else {
        html += `<div class="trl-card"><b>Team builder — ${escapeHtml(s.name)}</b>${tip('Sorts everyone into Pro/Skilled/Rookie, then deals them out across teams alternating direction each pass so no team stacks the top of a bracket.')}<br><br>
          Number of teams: <input id="trl-team-count" class="trl-input" type="number" value="2" style="width:60px;">
          Team size: <input id="trl-team-size" class="trl-input" type="number" value="6" style="width:60px;">
          <button class="trl-btn primary" id="trl-run-draft">🧩 Run Snake Draft</button>
        </div>`;
      }

      html += `<div class="trl-card"><b>Publish to the league server</b>${tip('Pushes this series\' settings, the cached roster, and current teams up to the Worker, and registers it so other players can find it via 🔌 Connect. Useful after editing things locally, or for a series created before the server was connected.')}<br><br>
        <button class="trl-btn primary" id="trl-publish-series">📡 Publish this series</button>
        <div id="trl-publish-msg" style="font-size:11px; margin-top:6px;"></div>
      </div>`;

      html += `<div class="trl-card"><b>Manual race capture</b>${tip("If automatic capture didn't trigger (or you missed the banner), this grabs whatever race data the current page last reported, as long as you're on a finished race.")}<br><br>
        <button class="trl-btn primary" id="trl-manual-capture">📥 Capture current race page</button>
        <div id="trl-manual-capture-msg" style="font-size:11px; margin-top:6px;"></div>
      </div>`;

      html += `<div class="trl-card"><b style="color:#ef4444;">Danger zone</b><br><br>
        <button class="trl-btn danger" id="trl-clear-series">Delete this series (and its teams/results)</button>
      </div>`;
    }

    body.innerHTML = html;

    document.getElementById('trl-worker-save').addEventListener('click', () => {
      saveWorkerConfig({
        url: document.getElementById('trl-worker-url').value.trim().replace(/\/+$/, ''),
        adminToken: document.getElementById('trl-worker-token').value.trim(),
      });
      alert('Saved.');
      renderStewardTab(body);
    });

    document.getElementById('trl-refresh-roster').addEventListener('click', async () => {
      const apiKey = document.getElementById('trl-api-key').value.trim();
      const factionId = document.getElementById('trl-faction-id').value.trim();
      if (!apiKey || !factionId) { alert('Need both an API key and faction ID.'); return; }
      GM_setValue(K_API_KEY, apiKey); GM_setValue(K_FACTION_ID, factionId);
      const prog = document.getElementById('trl-roster-progress');
      const res = await refreshRoster(apiKey, factionId, (done, total) => { prog.textContent = `Fetching skill data… ${done}/${total}`; });
      if (res.error) { prog.textContent = 'Failed: ' + res.message; return; }
      prog.textContent = `Done — ${res.members.length} members cached.`;

      const cfg = getWorkerConfig();
      if (cfg.url && cfg.adminToken && currentSeriesId) {
        const s = getSeries()[currentSeriesId];
        if (s) {
          const r = await apiSetRoster(currentSeriesId, res.members, s.brackets);
          prog.textContent = r.ok
            ? `Done — ${res.members.length} members cached and synced to the server.`
            : `Cached locally, but server push failed: ${r.message}`;
        }
      }
      renderStewardTab(body);
    });

    document.getElementById('trl-create-series').addEventListener('click', async () => {
      const name = document.getElementById('trl-new-name').value.trim();
      if (!name) { alert('Series needs a name.'); return; }
      const lines = document.getElementById('trl-new-tracks').value.split('\n').map(l => l.trim()).filter(Boolean);
      const tracks = lines.map(l => {
        const [tName, laps] = l.split(',').map(s => s.trim());
        return { name: tName, laps: parseInt(laps, 10) || 50 };
      });
      if (!tracks.length) { alert('Add at least one track.'); return; }
      const signupMode = document.querySelector('input[name="trl-mode"]:checked').value;

      const id = uid('series');
      const all = getSeries();
      all[id] = {
        id, name, createdAt: Date.now(), active: true, signupMode,
        tracks,
        pointsTable: DEFAULT_POINTS.slice(),
        brackets: {
          rookieMax: parseInt(document.getElementById('trl-new-rookiemax').value, 10) || 11,
          skilledMax: parseInt(document.getElementById('trl-new-skilledmax').value, 10) || 24,
        },
        password: document.getElementById('trl-new-pass').value.trim(),
      };
      saveSeries(all);
      currentSeriesId = id;

      const cfg = getWorkerConfig();
      if (cfg.url && cfg.adminToken) {
        await apiSetSeries(id, all[id]);
        await apiRegistryReg(id, name, true);
        const r = getRosterCache();
        if (r.members.length) await apiSetRoster(id, r.members, all[id].brackets);
      }

      await populateSeriesSelect();
      renderStewardTab(body);
    });

    document.getElementById('trl-create-open-teams')?.addEventListener('click', async () => {
      const teamCount = parseInt(document.getElementById('trl-open-teamcount').value, 10) || 2;
      const slotShape = {
        Pro: parseInt(document.getElementById('trl-open-pro').value, 10) || 0,
        Skilled: parseInt(document.getElementById('trl-open-skilled').value, 10) || 0,
        Rookie: parseInt(document.getElementById('trl-open-rookie').value, 10) || 0,
      };
      if (!confirm('This replaces any existing teams for this series with empty sign-up slots. Continue?')) return;
      const all = getTeams();
      all[currentSeriesId] = createOpenTeams(teamCount, slotShape);
      saveTeams(all);
      const cfg = getWorkerConfig();
      if (cfg.url && cfg.adminToken) await apiSetTeams(currentSeriesId, all[currentSeriesId]);
      alert('Empty teams created — members can now sign up from the Sign Up tab.');
    });

    document.getElementById('trl-run-draft')?.addEventListener('click', async () => {
      const rosterMembers = getRosterCache().members;
      if (!rosterMembers.length) { alert('Refresh the roster first.'); return; }
      const s = getSeries()[currentSeriesId];
      const teamCount = parseInt(document.getElementById('trl-team-count').value, 10) || 2;
      const teamSize = parseInt(document.getElementById('trl-team-size').value, 10) || 5;
      if (!confirm(`This will overwrite any existing teams for "${s.name}". Continue?`)) return;
      const newTeams = buildTeams(rosterMembers, teamCount, teamSize, s.brackets);
      const all = getTeams();
      all[currentSeriesId] = newTeams;
      saveTeams(all);
      const cfg = getWorkerConfig();
      if (cfg.url && cfg.adminToken) await apiSetTeams(currentSeriesId, all[currentSeriesId]);
      alert('Teams built — check the Teams tab.');
    });

    document.getElementById('trl-publish-series')?.addEventListener('click', async () => {
      const cfg = getWorkerConfig();
      const msg = document.getElementById('trl-publish-msg');
      if (!cfg.url || !cfg.adminToken) { msg.textContent = 'Set the Worker URL and admin token above first.'; return; }
      const s = getSeries()[currentSeriesId];
      const r = getRosterCache();
      const t = getTeams()[currentSeriesId] || [];
      await apiSetSeries(currentSeriesId, s);
      await apiRegistryReg(currentSeriesId, s.name, true);
      if (r.members.length) await apiSetRoster(currentSeriesId, r.members, s.brackets);
      await apiSetTeams(currentSeriesId, t);
      msg.textContent = 'Published series, roster, and teams to the server.';
    });

    document.getElementById('trl-manual-capture')?.addEventListener('click', () => {
      const snap = window.__trlLastSnapshot;
      const msg = document.getElementById('trl-manual-capture-msg');
      if (!snap) { msg.textContent = 'No race data seen on this page yet.'; return; }
      const matches = findMatchingSeries(snap.track);
      const target = matches.find(s => s.id === currentSeriesId) || matches[0];
      if (!target) { msg.textContent = `Track "${snap.track}" isn't in any active series.`; return; }
      const r = captureRace(target.id, snap.track, snap.racers);
      msg.textContent = r.ok ? `Logged ${r.count} drivers to "${target.name}".` : r.message;
    });

    document.getElementById('trl-clear-series')?.addEventListener('click', async () => {
      if (!confirm('Delete this entire series, its teams and all logged race results?')) return;
      const cfg = getWorkerConfig();
      if (cfg.url && cfg.adminToken) await apiRegistryRemove(currentSeriesId);
      const all = getSeries(); delete all[currentSeriesId]; saveSeries(all);
      const t = getTeams(); delete t[currentSeriesId]; saveTeams(t);
      const r = getResults(); delete r[currentSeriesId]; saveResults(r);
      currentSeriesId = null;
      await populateSeriesSelect();
      renderTab();
    });
  }

  /* ============================================================
     LIVE CAPTURE BANNER
     ============================================================ */
  function showCaptureBanner(track, racers) {
    let el = document.getElementById('trl-capture-banner');
    const matches = findMatchingSeries(track);
    if (!matches.length) { if (el) el.remove(); return; }

    if (!el) {
      el = document.createElement('div');
      el.id = 'trl-capture-banner';
      document.body.appendChild(el);
    }
    el.innerHTML = `
      <div><b>${escapeHtml(track)}</b></div>
      <div style="margin:4px 0;">${racers.length} drivers seen — matches: ${matches.map(s => escapeHtml(s.name)).join(', ')}</div>
      <select id="trl-banner-series" class="trl-select" style="width:100%; margin-bottom:6px;">
        ${matches.map(s => `<option value="${s.id}">${escapeHtml(s.name)}</option>`).join('')}
      </select>
      <button class="trl-btn primary" id="trl-banner-go" style="width:100%;">📥 Log this race</button>
      <div id="trl-banner-msg" style="font-size:11px; margin-top:4px;"></div>
    `;
    document.getElementById('trl-banner-go').onclick = () => {
      const seriesId = document.getElementById('trl-banner-series').value;
      const r = captureRace(seriesId, track, racers);
      document.getElementById('trl-banner-msg').textContent = r.ok ? `Logged ${r.count} drivers ✓` : r.message;
    };
  }

  /* ============================================================
     AJAX HOOK
     ============================================================ */
  function hookRacingAjax() {
    if (!$) return;
    $(document).ajaxComplete((event, xhr, settings) => {
      if (xhr.readyState > 3 && xhr.status === 200 && settings.url && settings.url.includes('sid=racing')) {
        try {
          const data = JSON.parse(xhr.responseText);
          if (!data || !data.timeData || data.timeData.status < 3) return;
          const titleEl = document.querySelector('div.title-black.t-overflow');
          const titleText = data.raceData?.title || (titleEl ? titleEl.textContent.trim() : '');
          const track = normalizeTrackName(titleText);
          const racers = decodeAllRacers(data);
          if (!track || racers.length < 2) return;
          window.__trlLastSnapshot = { track, racers };
          showCaptureBanner(track, racers);
        } catch (e) { /* ignore malformed payloads */ }
      }
    });
  }

  /* ============================================================
     INIT
     ============================================================ */
  function init() {
    if (isRacingPage()) injectButton();
    hookRacingAjax();
  }

  const observer = new MutationObserver(() => {
    if (!isRacingPage()) return;
    if (document.getElementById('trl-btn')) { observer.disconnect(); return; }
    injectButton();
  });
  observer.observe(document.documentElement, { childList: true, subtree: true });

  init();
})();
