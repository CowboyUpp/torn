    #trl-modal { width: 94vw; max-width: 920px; height: 82vh; max-height: 660px; background: #1a2236; color: #f8fafc; border-radius: 12px; box-shadow: 0 12px 36px rgba(0,0,0,.6); display: flex; flex-direction: column; font-family: Arial, sans-serif; font-size: 13px; overflow: hidden; }
