  /* ============================================================
     TOOLTIP BUBBLE (JS-positioned, viewport-clamped)
     The old pure-CSS hover tooltip got clipped by the modal's own
     scroll/overflow rules whenever a tip icon was near an edge.
     This appends one shared bubble to <body> instead, so it's never
     trapped by any ancestor's overflow, and clamps its position to
     stay fully on-screen, flipping above/below as needed.
     ============================================================ */
  let tooltipEl = null;
  function ensureTooltipEl() {
    if (tooltipEl) return tooltipEl;
    tooltipEl = document.createElement('div');
    tooltipEl.id = 'trl-tooltip-bubble';
    document.body.appendChild(tooltipEl);
    return tooltipEl;
  }

  function showTooltip(target) {
    const text = target.getAttribute('data-tooltip');
    if (!text) return;
    const el = ensureTooltipEl();
    el.textContent = text;
    el.style.width = '220px';
    el.style.display = 'block';

    const rect = target.getBoundingClientRect();
    const margin = 8;
    let left = rect.left + rect.width / 2 - 110;
    if (left < margin) left = margin;
    if (left + 220 > window.innerWidth - margin) left = window.innerWidth - margin - 220;

    const bubbleHeight = el.offsetHeight;
    const placeAbove = rect.top - bubbleHeight - 14 >= margin;
    const top = placeAbove ? rect.top - bubbleHeight - 10 : rect.bottom + 10;
    el.dataset.arrow = placeAbove ? 'bottom' : 'top';

    el.style.left = left + 'px';
    el.style.top = top + 'px';

    const arrowLeft = Math.max(12, Math.min(220 - 12, rect.left + rect.width / 2 - left));
    el.style.setProperty('--arrow-left', arrowLeft + 'px');
  }

  function hideTooltip() { if (tooltipEl) tooltipEl.style.display = 'none'; }

  document.addEventListener('mouseover', (e) => {
    const t = e.target.closest && e.target.closest('.trl-tip');
    if (t) showTooltip(t);
  });
  document.addEventListener('mouseout', (e) => {
    const t = e.target.closest && e.target.closest('.trl-tip');
    if (t) hideTooltip();
  });

  /* ============================================================
     MODAL UI
     ============================================================ */
  let activeTab = 'standings';
  let currentSeriesId = null;

  /**
   * Only the racing area should ever get this button — page.php?sid=racing
   * and its subpages, nothing else on torn.com.
   */
  function isRacingPage() {
    try {
      const url = new URL(location.href);
      return url.pathname.includes('page.php') && /sid=racing/i.test(url.search);
    } catch (e) {
      return /page\.php/i.test(location.href) && /sid=racing/i.test(location.href);
    }
  }

  /**
   * Best-guess selectors for Torn's racing-page title ("Torn City
   * Raceway" etc.) — I can't browse a live Torn session to confirm
   * the exact markup, so this tries a few likely candidates and
   * falls back to a text-content search. If the icon lands in the
   * wrong spot, right-click → Inspect on the header text and send
   * over the element/class so this can be hard-coded precisely.
   */
  function findRacingHeader() {
    const candidates = ['.content-title h4', '.content-title h1', 'h1.title-black', '#skip-to-content-link + div h4'];
    for (const sel of candidates) {
      const el = document.querySelector(sel);
      if (el && el.textContent.trim().length) return el;
    }
    const heads = document.querySelectorAll('h1, h2, h3, h4');
    for (const h of heads) {
      if (/raceway|racing/i.test(h.textContent)) return h;
    }
    return null;
  }

  function injectButton() {
    if (!isRacingPage()) return;
    if (document.getElementById('trl-btn')) return;
    const header = findRacingHeader();
    if (!header) return; // header not rendered yet — the observer below will retry

    const btn = document.createElement('span');
    btn.id = 'trl-btn';
    btn.title = 'Faction Racing League';
    btn.textContent = '🏁';
    header.appendChild(btn);
    btn.addEventListener('click', () => {
      if (document.getElementById('trl-backdrop')) { stopSignupPolling(); document.getElementById('trl-backdrop').remove(); }
      else openModal();
    });
  }

  function openModal() {
    const cfg = getWorkerConfig();
    const backdrop = document.createElement('div');
    backdrop.id = 'trl-backdrop';
    backdrop.innerHTML = `
      <div id="trl-modal">
        <div id="trl-head">
          <span style="font-weight:700;">🏆 Faction Racing League</span>${tip('Tracks a multi-race series: skill-bracket teams, captured race results, and points standings for your faction.')}
          <select id="trl-series-select" class="trl-select" style="margin-left:8px;"></select>
          <div style="margin-left:auto; display:flex; gap:6px;">
            <button class="trl-btn" id="trl-connect-btn">🔌 ${cfg.url ? 'Connected' : 'Connect'}</button>
            <button class="trl-btn" id="trl-key-btn">🔑 Setup</button>
            <button id="trl-close">✕</button>
          </div>
        </div>
        <div id="trl-tabs">
          <div class="trl-tab" data-tab="standings">Standings</div>
          <div class="trl-tab" data-tab="teams">Teams</div>
          <div class="trl-tab" data-tab="signup">Sign Up</div>
          <div class="trl-tab" data-tab="races">Races</div>
          <div class="trl-tab" data-tab="steward">Steward</div>
        </div>
        <div id="trl-body"></div>
      </div>
    `;
    document.body.appendChild(backdrop);
    backdrop.addEventListener('click', e => { if (e.target === backdrop) { stopSignupPolling(); backdrop.remove(); } });
    document.getElementById('trl-close').addEventListener('click', () => { stopSignupPolling(); backdrop.remove(); });
    document.getElementById('trl-key-btn').addEventListener('click', () => { activeTab = 'steward'; renderTab(); });
    document.getElementById('trl-connect-btn').addEventListener('click', connectToBackend);

    document.getElementById('trl-series-select').addEventListener('change', async (e) => {
      currentSeriesId = e.target.value;
      await loadSeriesFromBackend(currentSeriesId);
      renderTab();
    });

    document.querySelectorAll('.trl-tab').forEach(tab => {
      tab.addEventListener('click', () => { activeTab = tab.dataset.tab; renderTab(); });
    });

    populateSeriesSelect().then(() => renderTab());
  }

  async function populateSeriesSelect() {
    const sel = document.getElementById('trl-series-select');
    if (!sel) return;

    const cfg = getWorkerConfig();
    if (cfg.url) {
      const reg = await apiRegistryList();
      if (reg && reg.length) {
        const local = getSeries();
        let changed = false;
        reg.forEach(r => {
          if (!local[r.id]) {
            local[r.id] = {
              id: r.id, name: r.name, createdAt: Date.now(), active: r.active !== false,
              signupMode: 'open', tracks: [], pointsTable: DEFAULT_POINTS.slice(),
              brackets: { rookieMax: 11, skilledMax: 24 }, password: '',
            };
            changed = true;
          }
        });
        if (changed) saveSeries(local);
      }
    }

    const series = getSeries();
    const ids = Object.keys(series);
    sel.innerHTML = ids.length
      ? ids.map(id => `<option value="${id}">${escapeHtml(series[id].name)}</option>`).join('')
      : '<option value="">No series yet — open Steward tab</option>';
    if (!currentSeriesId || !series[currentSeriesId]) currentSeriesId = ids[0] || null;
    if (currentSeriesId) sel.value = currentSeriesId;

    if (currentSeriesId) await loadSeriesFromBackend(currentSeriesId);
  }

  function renderTab() {
    if (activeTab !== 'signup') stopSignupPolling();
    document.querySelectorAll('.trl-tab').forEach(t => t.classList.toggle('active', t.dataset.tab === activeTab));
    const body = document.getElementById('trl-body');
    if (!body) return;
    if (activeTab === 'standings') return renderStandingsTab(body);
    if (activeTab === 'teams') return renderTeamsTab(body);
    if (activeTab === 'signup') return renderSignUpTab(body);
    if (activeTab === 'races') return renderRacesTab(body);
    if (activeTab === 'steward') return renderStewardTab(body);
  }

  /* ---------- Standings tab ---------- */
  function renderStandingsTab(body) {
    if (!currentSeriesId) { body.innerHTML = '<p>No series selected yet. Ask your steward to create one, or 🔌 Connect to the league server.</p>'; return; }
    const series = getSeries()[currentSeriesId];
    const { indivList, teamList, raceCount } = computeStandings(currentSeriesId);

    let html = `<div class="trl-card">
      <div style="display:flex; justify-content:space-between; flex-wrap:wrap; gap:6px;">
        <div><b>${escapeHtml(series.name)}</b> — ${series.tracks.length} tracks × ${series.tracks[0]?.laps ?? 50} laps · ${raceCount} race(s) logged in this browser</div>
        <div>Join password: <code>${escapeHtml(series.password || '—')}</code>${tip("This must match the password you set when creating the actual private race in Torn — the script can't create races for you, it only tracks results.")}</div>
      </div>
    </div>`;

    html += `<div class="trl-card"><b>Team Standings</b>${renderTeamTable(teamList)}
      <button class="trl-btn" id="trl-export-team-csv" style="margin-top:8px;">⬇ Export Team CSV</button></div>`;

    ['Pro', 'Skilled', 'Rookie'].forEach(bracket => {
      const list = indivList.filter(p => p.bracket === bracket);
      html += `<div class="trl-card"><b style="color:${BRACKET_COLOR[bracket]}">${bracket} Standings</b>${renderIndivTable(list)}</div>`;
    });
    const unranked = indivList.filter(p => p.bracket === 'Unranked');
    if (unranked.length) html += `<div class="trl-card"><b style="color:#9ca3af;">Unranked (not in cached roster — refresh roster in Steward tab)</b>${renderIndivTable(unranked)}</div>`;

    body.innerHTML = html;
    document.getElementById('trl-export-team-csv')?.addEventListener('click', () => exportTeamCsv(currentSeriesId));
  }

  function renderTeamTable(teamList) {
    if (!teamList.length) return '<p style="color:#9ca3af;">No teams yet.</p>';
    return `<table class="trl-table"><thead><tr><th>#</th><th>Team</th><th>Members</th><th>Points</th></tr></thead><tbody>
      ${teamList.map((t, i) => `<tr><td>${i + 1}</td><td>${escapeHtml(t.name)}</td><td>${t.members.map(m => `<span class="trl-badge" style="background:${BRACKET_COLOR[m.bracket]}">${escapeHtml(m.name)}</span>`).join(' ')}</td><td><b>${t.points}</b></td></tr>`).join('')}
    </tbody></table>`;
  }

  function renderIndivTable(list) {
    if (!list.length) return '<p style="color:#9ca3af;">No results yet.</p>';
    return `<table class="trl-table"><thead><tr><th>#</th><th>Driver</th><th>Races</th><th>Points</th></tr></thead><tbody>
      ${list.map((p, i) => `<tr><td>${i + 1}</td><td>${escapeHtml(p.name)}</td><td>${p.races}</td><td><b>${p.points}</b></td></tr>`).join('')}
    </tbody></table>`;
  }

  function exportTeamCsv(seriesId) {
    const { teamList } = computeStandings(seriesId);
    let csv = 'Rank,Team,Members,Points\n';
    teamList.forEach((t, i) => {
      csv += `${i + 1},"${t.name}","${t.members.map(m => m.name + ' (' + m.bracket + ')').join('; ')}",${t.points}\n`;
    });
    downloadCsv(csv, 'league_team_standings.csv');
  }

  function downloadCsv(csv, filename) {
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = filename; a.click();
    URL.revokeObjectURL(url);
  }

  /* ---------- Teams tab (read-only summary, both modes) ---------- */
  function renderTeamsTab(body) {
    if (!currentSeriesId) { body.innerHTML = '<p>No series selected.</p>'; return; }
    const teams = (getTeams()[currentSeriesId] || []);
    if (!teams.length) { body.innerHTML = '<p style="color:#9ca3af;">No teams yet — build them from the Steward tab.</p>'; return; }

    let html = teams.map(t => {
      if (t.slotShape) {
        const rows = ['Pro', 'Skilled', 'Rookie'].map(b => {
          const cap = t.slotShape[b] || 0;
          if (!cap) return '';
          const filled = t.members.filter(m => m.bracket === b);
          return `<tr><td><span class="trl-badge" style="background:${BRACKET_COLOR[b]}">${b}</span></td><td>${filled.length}/${cap}</td><td>${filled.map(m => escapeHtml(m.name)).join(', ') || '<span style="color:#6b7280;">— open —</span>'}</td></tr>`;
        }).join('');
        return `<div class="trl-card"><b>${escapeHtml(t.name)}</b> <span style="color:#9ca3af; font-size:11px;">(open sign-up)</span>
          <table class="trl-table"><thead><tr><th>Bracket</th><th>Filled</th><th>Members</th></tr></thead><tbody>${rows}</tbody></table>
        </div>`;
      }
      return `<div class="trl-card"><b>${escapeHtml(t.name)}</b>
        <table class="trl-table"><thead><tr><th>Driver</th><th>Bracket</th><th>Skill</th></tr></thead><tbody>
          ${t.members.map(m => `<tr><td>${escapeHtml(m.name)}</td><td><span class="trl-badge" style="background:${BRACKET_COLOR[m.bracket]}">${m.bracket}</span></td><td>${m.skill.toFixed(2)}</td></tr>`).join('')}
        </tbody></table>
      </div>`;
    }).join('');

    html += `<div class="trl-card">
      <b>Swap two members</b>${tip('Steward override — moves anyone between teams regardless of slot quotas. Use for manual fixes, e.g. a no-show. Requires the admin token (Steward tab) if a league server is connected.')}<br><br>
      <select id="trl-swap-a" class="trl-select"></select> ⇄ <select id="trl-swap-b" class="trl-select"></select>
      <button class="trl-btn primary" id="trl-swap-go" style="margin-left:8px;">Swap</button>
    </div>`;

    body.innerHTML = html;

    const allMembers = [];
    teams.forEach(t => t.members.forEach(m => allMembers.push({ teamId: t.id, name: m.name })));
    const opts = allMembers.map(m => `<option value="${m.teamId}::${escapeHtml(m.name)}">${escapeHtml(m.name)} (${teams.find(t => t.id === m.teamId).name})</option>`).join('');
    const a = document.getElementById('trl-swap-a'), b = document.getElementById('trl-swap-b');
    if (a) a.innerHTML = opts;
    if (b) b.innerHTML = opts;

    document.getElementById('trl-swap-go')?.addEventListener('click', async () => {
      const [teamIdA, nameA] = document.getElementById('trl-swap-a').value.split('::');
      const [teamIdB, nameB] = document.getElementById('trl-swap-b').value.split('::');
      if (teamIdA === teamIdB && nameA === nameB) return;
      const allTeams = getTeams();
      const list = allTeams[currentSeriesId];
      const teamA = list.find(t => t.id === teamIdA);
      const teamB = list.find(t => t.id === teamIdB);
      const idxA = teamA.members.findIndex(m => m.name === nameA);
      const idxB = teamB.members.findIndex(m => m.name === nameB);
      if (idxA === -1 || idxB === -1) return;
      const memA = teamA.members[idxA], memB = teamB.members[idxB];
      teamA.members[idxA] = memB; teamB.members[idxB] = memA;
      saveTeams(allTeams);
      const cfg = getWorkerConfig();
      if (cfg.url && cfg.adminToken) await apiSetTeams(currentSeriesId, allTeams[currentSeriesId]);
      renderTeamsTab(body);
    });
  }

  /* ---------- Sign Up tab ---------- */
  function renderSignUpTab(body) {
    if (!currentSeriesId) { body.innerHTML = '<p>No series selected.</p>'; return; }
    const series = getSeries()[currentSeriesId];
    const teams = (getTeams()[currentSeriesId] || []);
    const openTeams = teams.filter(t => t.slotShape);
    const myName = GM_getValue(K_MY_NAME, '');

    let html = `<div class="trl-card">
      <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px;">
        <div>👤 You are: <b>${myName ? escapeHtml(myName) : '— not set —'}</b> <a href="#" id="trl-change-me" style="color:#60a5fa;">change</a>${tip("Pick your own name once so the script knows which bracket you're in and can validate your slot claims. Stored only in this browser.")}</div>
        <button class="trl-btn" id="trl-signup-refresh">🔄 Refresh${tip("Pulls the latest claims from the league server if you're connected, otherwise just re-reads this browser's local data.")}</button>
      </div>
    </div>`;

    if (!openTeams.length) {
      html += `<p style="color:#9ca3af;">This series doesn't have open sign-up teams yet — your steward either hasn't created them, or is using steward-assigned teams for this event.</p>`;
      body.innerHTML = html;
      document.getElementById('trl-change-me')?.addEventListener('click', e => { e.preventDefault(); pickIdentity(() => renderSignUpTab(body)); });
      return;
    }

    const cfg = getWorkerConfig();
    if (!cfg.url) {
      html += `<div class="trl-card" style="border-color:#92400e; background:#3f2d12;">⚠️ Not connected to a league server — slot claims only save to <i>this</i> browser. Click 🔌 Connect at the top and paste the URL your steward shared, or ask them for it.</div>`;
    }

    const rosterMember = getRosterCache().members.find(m => m.name.toLowerCase() === myName.toLowerCase());
    const myBracket = rosterMember ? bracketOf(rosterMember.skill, series.brackets) : null;
    const myTeam = openTeams.find(t => t.members.some(m => m.name.toLowerCase() === myName.toLowerCase()));

    html += openTeams.map(t => {
      const rows = ['Pro', 'Skilled', 'Rookie'].map(bracket => {
        const cap = t.slotShape[bracket] || 0;
        if (!cap) return '';
        const filled = t.members.filter(m => m.bracket === bracket);
        const slots = [];
        for (let i = 0; i < cap; i++) {
          if (filled[i]) {
            const isMe = filled[i].name.toLowerCase() === myName.toLowerCase();
            slots.push(`<div style="padding:5px 8px; background:${isMe ? '#14532d' : '#111827'}; border:1px solid ${BRACKET_COLOR[bracket]}; border-radius:6px; margin-bottom:4px; display:flex; justify-content:space-between; align-items:center;">
              <span>${escapeHtml(filled[i].name)}${isMe ? ' (you)' : ''}</span>
              ${isMe ? `<button class="trl-btn danger" data-release="${t.id}" style="padding:2px 8px; font-size:10px;">Leave</button>` : ''}
            </div>`);
          } else {
            const canClaim = !myTeam && myBracket === bracket && myName;
            slots.push(`<div style="padding:5px 8px; background:#1f2937; border:1px dashed #4b5563; border-radius:6px; margin-bottom:4px; display:flex; justify-content:space-between; align-items:center; color:#6b7280;">
              <span>Open ${bracket} slot</span>
              ${canClaim ? `<button class="trl-btn primary" data-claim="${t.id}::${bracket}" style="padding:2px 8px; font-size:10px;">Claim</button>` : ''}
            </div>`);
          }
        }
        return `<div style="margin-bottom:6px;"><span class="trl-badge" style="background:${BRACKET_COLOR[bracket]}">${bracket}</span></div>${slots.join('')}`;
      }).join('');
      return `<div class="trl-card"><b>${escapeHtml(t.name)}</b><div style="margin-top:6px;">${rows}</div></div>`;
    }).join('');

    body.innerHTML = html;

    document.getElementById('trl-change-me')?.addEventListener('click', e => { e.preventDefault(); pickIdentity(() => renderSignUpTab(body)); });
    document.getElementById('trl-signup-refresh')?.addEventListener('click', async () => { await loadSeriesFromBackend(currentSeriesId); renderSignUpTab(body); });

    body.querySelectorAll('[data-claim]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const [teamId, bracket] = btn.dataset.claim.split('::');
        const workerCfg = getWorkerConfig();
        if (workerCfg.url) {
          const r = await apiClaim(currentSeriesId, GM_getValue(K_MY_NAME, ''), teamId, bracket);
          if (!r.ok) { alert(r.message); return; }
          if (r.data && r.data.teams) { const all = getTeams(); all[currentSeriesId] = r.data.teams; saveTeams(all); }
        } else {
          const r = claimSlotLocal(currentSeriesId, teamId, bracket);
          if (!r.ok) { alert(r.message); return; }
        }
        renderSignUpTab(body);
      });
    });
    body.querySelectorAll('[data-release]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const workerCfg = getWorkerConfig();
        if (workerCfg.url) {
          const r = await apiRelease(currentSeriesId, GM_getValue(K_MY_NAME, ''), btn.dataset.release);
          if (r.ok && r.data && r.data.teams) { const all = getTeams(); all[currentSeriesId] = r.data.teams; saveTeams(all); }
        } else {
          releaseSlotLocal(currentSeriesId, btn.dataset.release);
        }
        renderSignUpTab(body);
      });
    });

    startSignupPolling(body);
  }

  /* ---------- Races tab ---------- */
  function renderRacesTab(body) {
    if (!currentSeriesId) { body.innerHTML = '<p>No series selected.</p>'; return; }
    const races = (getResults()[currentSeriesId] || []).slice().sort((a, b) => b.capturedAt - a.capturedAt);
    if (!races.length) {
      body.innerHTML = '<p style="color:#9ca3af;">No races logged yet in this browser. Once a race on one of this series\' tracks finishes, a capture banner appears in the corner — or use the manual button in the Steward tab if you\'re already on a finished race page.</p>';
      return;
    }
    body.innerHTML = races.map(r => `
      <div class="trl-card">
        <div style="display:flex; justify-content:space-between;">
          <b>${escapeHtml(r.track)}</b>
          <span style="color:#9ca3af;">${new Date(r.capturedAt).toLocaleString()}</span>
        </div>
        <table class="trl-table"><thead><tr><th>Pos</th><th>Driver</th><th>Bracket</th><th>Time</th><th>Pts</th></tr></thead><tbody>
          ${r.standings.map(s => `<tr><td>${s.position}</td><td>${escapeHtml(s.name)}</td><td><span class="trl-badge" style="background:${BRACKET_COLOR[s.bracket] || '#4b5563'}">${s.bracket}</span></td><td>${formatMs(s.totalMs)}</td><td>${s.points}</td></tr>`).join('')}
        </tbody></table>
        <button class="trl-btn danger" data-race="${r.id}" style="margin-top:6px;">Remove this race</button>
      </div>`).join('');

    body.querySelectorAll('button[data-race]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (!confirm('Remove this race from the series?')) return;
        const results = getResults();
        results[currentSeriesId] = results[currentSeriesId].filter(r => r.id !== btn.dataset.race);
        saveResults(results);
        renderRacesTab(body);
      });
    });
  }

  function formatMs(ms) {
    const m = Math.floor(ms / 60000), s = Math.floor((ms % 60000) / 1000), cs = Math.floor((ms % 1000) / 10);
    return `${m}m ${String(s).padStart(2, '0')}.${String(cs).padStart(2, '0')}s`;
  }

  /* ---------- Steward tab ---------- */
  function renderStewardTab(body) {
    if (!stewardUnlocked) {
      const hasHash = !!GM_getValue(K_STEWARD_HASH, '');
      body.innerHTML = `<div class="trl-card">
        <p>${hasHash ? 'Enter the steward passphrase to manage series, teams and roster.' : 'No steward passphrase set yet. Pick one now — anyone who knows it can manage events.'}</p>
        <input type="password" id="trl-pass" class="trl-input" placeholder="Steward passphrase" style="width:220px;">
        <button class="trl-btn primary" id="trl-pass-go">${hasHash ? 'Unlock' : 'Set passphrase'}</button>
