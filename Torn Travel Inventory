        --tti-card: #202327;
        --tti-card-hover: #262a2f;
        --tti-line: rgba(255,255,255,.09);
        --tti-muted: #8f969f;
        --tti-text: #eef0f2;
        --tti-success: #69ba84;
      }
      html.${APP_ID}-no-scroll { overflow: hidden !important; }
      #${APP_ID}-root, #${APP_ID}-root * { box-sizing: border-box; }
