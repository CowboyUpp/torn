          width: min(480px, calc(100% - 8px));
          height: min(420px, calc(100vh - 24px));
        }
      }

      /* Content-sized utility window: no empty full-height canvas. */
      #${APP_ID}-root .${APP_ID}-panel {
        padding: 54px 12px 12px;
        align-items: start;
        background: rgba(0, 0, 0, .18);
      }
      #${APP_ID}-root .${APP_ID}-shell {
        width: min(460px, calc(100% - 24px));
        height: auto;
        max-height: calc(100vh - 66px);
      }
      #${APP_ID}-root .${APP_ID}-content {
        flex: 0 1 auto;
        max-height: 310px;
        overflow: auto;
      }
      #${APP_ID}-root .${APP_ID}-empty { min-height: 115px; }
      #${APP_ID}-root .${APP_ID}-settings-shell {
        width: min(420px, calc(100% - 24px));
        height: auto;
        max-height: calc(100vh - 66px);
        overflow: auto;
      }
      #${APP_ID}-root .${APP_ID}-settings {
        position: static;
        inset: auto;
        overflow: visible;
        padding: 10px;
        animation: none;
      }
      #${APP_ID}-root .${APP_ID}-settings-head { margin: -10px -10px 8px; }
      #${APP_ID}-root .${APP_ID}-settings-intro {
        max-width: none;
        line-height: 1.4;
      }
      #${APP_ID}-root .${APP_ID}-privacy {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      @media (max-width: 520px) {
        #${APP_ID}-root .${APP_ID}-panel { padding: 12px 6px; }
        #${APP_ID}-root .${APP_ID}-shell,
        #${APP_ID}-root .${APP_ID}-settings-shell {
          width: min(400px, calc(100% - 8px));
          height: auto;
          max-height: calc(100vh - 24px);
        }
        #${APP_ID}-root .${APP_ID}-toolbar {
          grid-template-columns: minmax(130px, 1fr) 120px auto;
        }
        #${APP_ID}-root .${APP_ID}-grid { grid-template-columns: 1fr; }
        #${APP_ID}-root .${APP_ID}-content { max-height: 300px; }
      }

      /* Torn control finish: sampling can report a square radius on some
         pages, so interactive controls use a stable radius of their own. */
      #${APP_ID}-root button,
      #${APP_ID}-root select,
      #${APP_ID}-root .${APP_ID}-create-key,
      #${APP_ID}-root .${APP_ID}-key-row {
        border-radius: 5px !important;
      }
      #${APP_ID}-root button,
      #${APP_ID}-root .${APP_ID}-create-key {
        text-shadow: none !important;
      }
      #${APP_ID}-root .${APP_ID}-danger {
        color: #8b3030 !important;
        background: #f7eaea !important;
        border: 1px solid #d8aaaa !important;
        box-shadow: none !important;
        text-decoration: none !important;
      }
      #${APP_ID}-root.${APP_ID}-theme-dark .${APP_ID}-danger {
        color: #e1a0a0 !important;
        background: #352525 !important;
        border-color: #734141 !important;
      }
      #${APP_ID}-root .${APP_ID}-primary {
        text-shadow: none !important;
      }

      /* Stable typography and real Torn item artwork. */
      #${APP_ID}-root,
      #${APP_ID}-root * {
        font-family: Arial, Helvetica, sans-serif !important;
        font-style: normal;
      }
      #${APP_ID}-root button,
      #${APP_ID}-root input,
      #${APP_ID}-root select {
        font-size: 11px !important;
        font-weight: 400 !important;
        letter-spacing: 0;
      }
      #${APP_ID}-root .${APP_ID}-primary,
      #${APP_ID}-root .${APP_ID}-create-key {
        font-weight: 700 !important;
      }
      #${APP_ID}-root.${APP_ID}-theme-light .${APP_ID}-category-select {
        color: #444 !important;
        background: linear-gradient(#fff, #e4e4e4) !important;
        border-color: #aaa !important;
      }
      #${APP_ID}-root.${APP_ID}-theme-dark .${APP_ID}-category-select {
        color: #d5d5d5 !important;
        background: linear-gradient(#3b3b3b, #292929) !important;
        border-color: #151515 !important;
      }
      #${APP_ID}-root .${APP_ID}-item-icon {
        overflow: hidden;
        padding: 2px;
      }
      #${APP_ID}-root .${APP_ID}-item-icon img {
        display: block;
        width: 100%;
        height: 100%;
        padding: 0;
        border: 0;
        border-radius: 0 !important;
        object-fit: contain;
      }
      #${APP_ID}-root .${APP_ID}-item-icon.is-missing {
        background: transparent;
      }
      #${APP_ID}-root .${APP_ID}-version {
        margin-left: 6px;
        color: #888;
        font-size: 9px;
        white-space: nowrap;
      }
      #${APP_ID}-root .${APP_ID}-pager button {
        min-width: 82px;
      }
    `;
    document.head.appendChild(nativeStyle);
  }

  function isOfficialItemsLink(anchor) {
    if (!anchor || anchor.closest(`#${APP_ID}-root`) || anchor.closest(`.${APP_ID}-native-nav`)) {
      return false;
    }
    try {
      const url = new URL(anchor.href, location.href);
      const path = url.pathname.toLowerCase();
      const labels = [
        anchor.textContent,
        anchor.getAttribute("aria-label"),
        anchor.getAttribute("title"),
        anchor.querySelector("img")?.getAttribute("alt"),
      ]
        .filter(Boolean)
        .map((label) => String(label).replace(/\s+/g, " ").trim());
      const isNavigationLabel = labels.some((label) => /^items$/i.test(label));
      return (
        url.origin === location.origin &&
        isNavigationLabel &&
        (path.endsWith("/item.php") ||
          path.endsWith("/items.php") ||
          path.endsWith("/inventory.php"))
      );
    } catch {
      return false;
    }
  }

  function replaceNavigationLabel(anchor) {
    const walker = document.createTreeWalker(anchor, NodeFilter.SHOW_TEXT);
    let replaced = false;
    let node;
    while ((node = walker.nextNode())) {
      if (/\bitems\b/i.test(node.nodeValue || "")) {
        node.nodeValue = node.nodeValue.replace(/\bitems\b/i, "Inventory");
        replaced = true;
      }
    }

    if (!replaced) {
      const label = [...anchor.querySelectorAll("span, div")].find(
        (element) => element.children.length === 0 && /^items$/i.test(element.textContent.trim()),
      );
      if (label) {
        label.textContent = "Inventory";
        replaced = true;
      }
    }

    if (!replaced) {
      const label = document.createElement("span");
      label.textContent = "Inventory";
      anchor.appendChild(label);
    }

    anchor.setAttribute("aria-label", "Open travel inventory");
    anchor.setAttribute("title", "Inventory");
  }

  function installNavigationButton() {
    const itemLinks = [...document.querySelectorAll("a[href]")].filter(isOfficialItemsLink);

    for (const itemLink of itemLinks) {
      const sourceNode = itemLink.parentElement?.tagName === "LI" ? itemLink.parentElement : itemLink;
      if (sourceNode.nextElementSibling?.classList.contains(`${APP_ID}-native-nav`)) continue;

      const clone = sourceNode.cloneNode(true);
      clone.classList.add(`${APP_ID}-native-nav`);
      clone.querySelectorAll("[id]").forEach((element) => element.removeAttribute("id"));
      clone.querySelectorAll("img").forEach((image) => {
        image.alt = "";
        image.setAttribute("aria-hidden", "true");
      });
      clone.removeAttribute("id");

      const anchor = clone.matches("a[href]") ? clone : clone.querySelector("a[href]");
      if (!anchor) continue;

      anchor.href = `#${APP_ID}-inventory`;
      anchor.removeAttribute("target");
      anchor.removeAttribute("rel");
      replaceNavigationLabel(anchor);
      anchor.addEventListener("click", (event) => {
        event.preventDefault();
        event.stopPropagation();
        openPanel();
      });

      sourceNode.insertAdjacentElement("afterend", clone);
    }
  }

  function install() {
    if (document.getElementById(`${APP_ID}-root`)) return;

    installStyles();
    root = document.createElement("div");
    root.id = `${APP_ID}-root`;
    root.innerHTML = `
      <section class="${APP_ID}-panel" role="dialog" aria-modal="true" aria-label="Personal Inventory" aria-hidden="true"></section>
    `;
    document.body.appendChild(root);
    syncTheme();

    panel = root.querySelector(`.${APP_ID}-panel`);
    panel.addEventListener("click", (event) => {
      if (event.target === panel) {
        closePanel();
        return;
      }
      handleClick(event);
    });
    panel.addEventListener("input", (event) => {
      if (event.target.matches(`.${APP_ID}-search input`)) {
        state.query = event.target.value;
        render();
        requestAnimationFrame(() => {
          const input = panel.querySelector(`.${APP_ID}-search input`);
          input?.focus();
          input?.setSelectionRange(state.query.length, state.query.length);
        });
      }
    });
    panel.addEventListener("change", (event) => {
      if (!event.target.matches(`.${APP_ID}-category-select`)) return;
      state.category = event.target.value;
      state.offset = 0;
      state.query = "";
      state.items = [];
      state.total = 0;
      loadInventory();
    });
    panel.addEventListener(
      "error",
      (event) => {
        if (!event.target.matches(`.${APP_ID}-item-icon img`)) return;
        const holder = event.target.closest(`.${APP_ID}-item-icon`);
        holder?.classList.add("is-missing");
        event.target.remove();
      },
      true,
    );

    document.addEventListener("keydown", (event) => {
      if (!state.open && event.altKey && event.key.toLowerCase() === "i") {
        event.preventDefault();
        openPanel();
        return;
      }
      if (!state.open) return;
      if (event.key === "Escape") {
        if (state.settingsOpen && getApiKey()) {
          state.settingsOpen = false;
          render();
        } else {
          closePanel();
        }
      } else if (
        event.key === "/" &&
        !state.settingsOpen &&
        !["INPUT", "TEXTAREA"].includes(document.activeElement?.tagName)
      ) {
        event.preventDefault();
        panel.querySelector(`.${APP_ID}-search input`)?.focus();
      }
    });

    installNavigationButton();

    navigationObserver = new MutationObserver(() => {
      clearTimeout(navigationTimer);
      navigationTimer = setTimeout(() => {
        installNavigationButton();
        syncTheme();
      }, 120);
    });
    navigationObserver.observe(document.documentElement, {
      childList: true,
      subtree: true,
    });

    if (typeof GM_registerMenuCommand === "function") {
      GM_registerMenuCommand("View travel inventory", openPanel);
    }

    render();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", install, { once: true });
  } else {
    install();
  }
})();
