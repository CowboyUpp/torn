// ==UserScript==
// @name         Torn: Travel Inventory
// @namespace    https://greasyfork.org/users/cowboyup
// @version      1.4.0
// @description  View a compact, read-only personal inventory through Torn API v2 while travelling.
// @author       cowboyup [1496324]
// @license      MIT
// @match        https://www.torn.com/*
// @connect      api.torn.com
// @grant        GM_xmlhttpRequest
// @grant        GM_getValue
// @grant        GM_setValue
// @grant        GM_deleteValue
// @grant        GM_registerMenuCommand
// @run-at       document-idle
// ==/UserScript==

(() => {
  "use strict";

  const APP_ID = "tti";
  const SCRIPT_VERSION = "1.4.0";
  const API_URL = "https://api.torn.com/v2/user/inventory";
  const API_COMMENT = "TornTravelInventory";
  const KEY_STORE = "tti_api_key";
  const THEME_STORE = "tti_theme";
  const API_KEY_URL =
    "https://www.torn.com/preferences.php#tab=api?step=addNewKey&title=Travel%20Inventory&user=inventory";
  const PAGE_SIZE = 250;
  const DEFAULT_CATEGORY = "Medical";

  const CATEGORIES = [
    "Medical",
    "Drug",
    "Booster",
    "Energy Drink",
    "Candy",
    "Alcohol",
    "Temporary",
    "Primary",
    "Secondary",
    "Melee",
    "Defensive",
    "Clothing",
    "Flower",
    "Plushie",
    "Supply Pack",
    "Enhancer",
    "Book",
    "Special",
    "Tool",
    "Material",
    "Car",
    "Jewelry",
    "Artifact",
    "Collectible",
    "Other",
  ];

  const CATEGORY_ICONS = {
    Medical: "✚",
    Drug: "◆",
    Booster: "▲",
    "Energy Drink": "ϟ",
    Candy: "●",
    Alcohol: "♜",
    Temporary: "◈",
    Primary: "▰",
    Secondary: "▪",
    Melee: "†",
    Defensive: "⬟",
    Clothing: "♟",
    Flower: "✿",
    Plushie: "★",
    "Supply Pack": "▣",
    Enhancer: "↑",
    Book: "▤",
    Special: "✦",
    Tool: "⌁",
    Material: "▧",
    Car: "▱",
    Jewelry: "◇",
    Artifact: "♢",
    Collectible: "◉",
    Other: "•••",
  };

  const state = {
    open: false,
    settingsOpen: false,
    category: DEFAULT_CATEGORY,
    offset: 0,
    items: [],
    total: 0,
    timestamp: null,
    loading: false,
    error: "",
    query: "",
    requestToken: 0,
    theme: String(gmGet(THEME_STORE, "light")) === "dark" ? "dark" : "light",
  };

  let root;
  let panel;
  let keyInput;
  let navigationObserver;
  let navigationTimer;

  function gmGet(key, fallback = "") {
    try {
      if (typeof GM_getValue === "function") return GM_getValue(key, fallback);
      return localStorage.getItem(key) ?? fallback;
    } catch {
      return fallback;
    }
  }

  function gmSet(key, value) {
    try {
      if (typeof GM_setValue === "function") GM_setValue(key, value);
      else localStorage.setItem(key, value);
    } catch {
      // Storage errors are reported when the saved value is read back.
    }
  }

  function gmDelete(key) {
    try {
      if (typeof GM_deleteValue === "function") GM_deleteValue(key);
      else localStorage.removeItem(key);
    } catch {
      // The user can overwrite an inaccessible value with a new key.
    }
  }

  function getApiKey() {
    return String(gmGet(KEY_STORE, "")).trim();
  }

  function detectDarkTheme() {
    const themeClasses = `${document.documentElement.className} ${document.body?.className || ""}`.toLowerCase();
    if (/(^|\s|[-_])(dark|night)(\s|[-_]|$)/.test(themeClasses)) return true;
    if (/(^|\s|[-_])light(\s|[-_]|$)/.test(themeClasses)) return false;

    const candidates = [
      document.querySelector("#mainContainer"),
      document.querySelector('[class*="content-wrapper"]'),
      document.querySelector("main"),
      document.body,
      document.documentElement,
    ].filter(Boolean);

    for (const element of candidates) {
      const color = getComputedStyle(element).backgroundColor;
      const match = color.match(/rgba?\(([\d.]+)[,\s]+([\d.]+)[,\s]+([\d.]+)/i);
      if (!match || color.endsWith(", 0)") || color.endsWith("/ 0)")) continue;
      const [, red, green, blue] = match.map(Number);
      const luminance = (0.2126 * red + 0.7152 * green + 0.0722 * blue) / 255;
      return luminance < 0.48;
    }

    return window.matchMedia?.("(prefers-color-scheme: dark)").matches ?? false;
  }

  function syncTheme() {
    if (!root) return;
    const dark = state.theme === "dark";
    root.classList.toggle(`${APP_ID}-theme-dark`, dark);
    root.classList.toggle(`${APP_ID}-theme-light`, !dark);
  }

  function syncNativeControlStyle() {
    const pageTheme = detectDarkTheme() ? "dark" : "light";
    const properties = [
      "--tti-native-height",
      "--tti-native-font-family",
      "--tti-native-radius",
    ];
    if (!root || state.theme !== pageTheme) {
      properties.forEach((property) => root?.style.removeProperty(property));
      return;
    }

    const sample = [...document.querySelectorAll("button, a[role='button'], [role='button']")]
      .filter((element) => {
        if (element.closest(`#${APP_ID}-root`)) return false;
        const rect = element.getBoundingClientRect();
        return rect.width >= 55 && rect.height >= 26 && rect.height <= 48 && getComputedStyle(element).display !== "none";
      })
      .sort((first, second) => {
        const a = first.getBoundingClientRect();
        const b = second.getBoundingClientRect();
        return a.width * a.height - b.width * b.height;
      })[0];
    if (!sample) return;

    const style = getComputedStyle(sample);
    const rect = sample.getBoundingClientRect();
    root.style.setProperty("--tti-native-height", `${Math.round(rect.height)}px`);
    root.style.setProperty("--tti-native-font-family", style.fontFamily);
    root.style.setProperty("--tti-native-radius", style.borderRadius);
  }

  function escapeHtml(value) {
    return String(value)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  function formatNumber(value) {
    return new Intl.NumberFormat().format(Number(value) || 0);
  }

  function formatTime(timestamp) {
    if (!timestamp) return "Not loaded";
    return new Intl.DateTimeFormat(undefined, {
      hour: "2-digit",
      minute: "2-digit",
      day: "2-digit",
      month: "short",
    }).format(new Date(timestamp * 1000));
  }

  function apiRequest(url, apiKey) {
    return new Promise((resolve, reject) => {
      const headers = {
        Authorization: `ApiKey ${apiKey}`,
        Accept: "application/json",
      };

      if (typeof GM_xmlhttpRequest === "function") {
        GM_xmlhttpRequest({
          method: "GET",
          url,
          headers,
          timeout: 20000,
          onload: (response) => {
            try {
              resolve(JSON.parse(response.responseText));
            } catch {
              reject(new Error("Torn returned an unreadable response."));
            }
          },
          onerror: () => reject(new Error("Could not reach the Torn API.")),
          ontimeout: () => reject(new Error("The Torn API request timed out.")),
        });
        return;
      }

      fetch(url, { headers })
        .then((response) => response.json())
        .then(resolve)
        .catch(() => reject(new Error("Could not reach the Torn API.")));
    });
  }

  async function loadInventory({ force = false } = {}) {
    const apiKey = getApiKey();
    if (!apiKey) {
      state.settingsOpen = true;
      state.error = "";
      render();
      setTimeout(() => keyInput?.focus(), 0);
      return;
    }

    const token = ++state.requestToken;
    state.loading = true;
    state.error = "";
    render();

    const params = new URLSearchParams({
      cat: state.category,
      limit: String(PAGE_SIZE),
      offset: String(state.offset),
      comment: API_COMMENT,
    });
    if (force) params.set("timestamp", String(Math.floor(Date.now() / 1000)));

    try {
      const data = await apiRequest(`${API_URL}?${params}`, apiKey);
      if (token !== state.requestToken) return;

      if (data?.error) {
        const code = data.error.code ? ` (${data.error.code})` : "";
        throw new Error(`${data.error.error || "Torn API error"}${code}`);
      }

      const inventory = data?.inventory;
      if (!inventory || !Array.isArray(inventory.items)) {
        throw new Error("The inventory response did not have the expected format.");
      }

      state.items = inventory.items;
      state.timestamp = inventory.timestamp || null;
      state.total = Number(data?._metadata?.total ?? inventory.items.length);
    } catch (error) {
      if (token !== state.requestToken) return;
      state.items = [];
      state.total = 0;
      state.timestamp = null;
      state.error = error instanceof Error ? error.message : "Could not load inventory.";
    } finally {
      if (token === state.requestToken) {
        state.loading = false;
        render();
      }
    }
  }

  function filteredItems() {
    const query = state.query.trim().toLowerCase();
    if (!query) return state.items;
    return state.items.filter((item) =>
      `${item.name} ${item.id} ${item.uid ?? ""}`.toLowerCase().includes(query),
    );
  }

  function renderCategoryOptions() {
    return CATEGORIES.map(
      (category) =>
        `<option value="${escapeHtml(category)}"${category === state.category ? " selected" : ""}>${escapeHtml(category)}</option>`,
    ).join("");
  }

  function renderCards() {
    if (state.loading) {
      return Array.from(
        { length: 8 },
        (_, index) => `
          <div class="${APP_ID}-card ${APP_ID}-skeleton" style="--delay:${index * 45}ms">
            <span></span><span></span><span></span>
          </div>`,
      ).join("");
    }

    if (state.error) {
      return `
        <div class="${APP_ID}-empty ${APP_ID}-error">
          <div class="${APP_ID}-empty-icon">!</div>
          <h3>Inventory unavailable</h3>
          <p>${escapeHtml(state.error)}</p>
          <button type="button" class="${APP_ID}-primary" data-action="retry">Try again</button>
        </div>`;
    }

    const items = filteredItems();
    if (!items.length) {
      return `
        <div class="${APP_ID}-empty">
          <div class="${APP_ID}-empty-icon">${state.query ? "⌕" : CATEGORY_ICONS[state.category]}</div>
          <h3>${state.query ? "No matching items" : `No ${escapeHtml(state.category)} items`}</h3>
          <p>${state.query ? "Try a different name or item ID." : "Nothing in this category was returned by the API."}</p>
        </div>`;
    }

    return items
      .map((item) => {
        const badges = [
          item.equipped ? `<span class="${APP_ID}-badge is-equipped">Equipped</span>` : "",
          item.faction_owned ? `<span class="${APP_ID}-badge">Faction</span>` : "",
        ].join("");
        const itemRef = item.uid ? `UID ${formatNumber(item.uid)}` : `ID ${formatNumber(item.id)}`;

        return `
          <article class="${APP_ID}-card">
            <div class="${APP_ID}-item-icon">
              <img
                src="https://www.torn.com/images/items/${encodeURIComponent(item.id)}/large.png"
                alt=""
                loading="lazy"
                referrerpolicy="same-origin"
              />
            </div>
            <div class="${APP_ID}-item-copy">
              <h3 title="${escapeHtml(item.name)}">${escapeHtml(item.name)}</h3>
              <div class="${APP_ID}-item-meta">
                <span>${itemRef}</span>
                ${badges}
              </div>
            </div>
            <div class="${APP_ID}-amount" title="Quantity">
              <small>QTY</small>
              <strong>${formatNumber(item.amount)}</strong>
            </div>
          </article>`;
      })
      .join("");
  }

  function renderSettings() {
    if (!state.settingsOpen) return "";
    const hasKey = Boolean(getApiKey());

    return `
      <div class="${APP_ID}-settings" role="region" aria-label="API settings">
        <div class="${APP_ID}-settings-head">
          <div>
            <span class="${APP_ID}-eyebrow">PRIVATE CONNECTION</span>
            <div class="${APP_ID}-settings-title">Connect your Torn API key</div>
          </div>
          ${hasKey ? `<button class="${APP_ID}-icon-button" type="button" data-action="close-settings" aria-label="Close settings">×</button>` : ""}
        </div>
        <p class="${APP_ID}-settings-intro">
          Create a <strong>Limited</strong> key, or a custom key with access only to
          <strong>User → Inventory</strong>. Never enter your Torn password here.
        </p>
        <a class="${APP_ID}-create-key ${APP_ID}-primary" href="${API_KEY_URL}" target="_blank" rel="noopener noreferrer">
          + Create custom Inventory API key
        </a>
        <label class="${APP_ID}-key-label" for="${APP_ID}-key-input">API key</label>
        <div class="${APP_ID}-key-row">
          <input
            id="${APP_ID}-key-input"
            type="password"
            inputmode="text"
            autocomplete="off"
            spellcheck="false"
            placeholder="Paste your API key"
            value="${escapeHtml(getApiKey())}"
          />
          <button class="${APP_ID}-reveal" type="button" data-action="reveal-key">Show</button>
        </div>
        <div class="${APP_ID}-privacy">
          <div><span>Storage</span><strong>API key: this browser only</strong></div>
          <div><span>Sharing</span><strong>Nobody</strong></div>
          <div><span>Purpose</span><strong>Read-only personal inventory</strong></div>
          <div><span>Sent to</span><strong>api.torn.com only</strong></div>
        </div>
        <div class="${APP_ID}-settings-actions">
          ${hasKey ? `<button class="${APP_ID}-danger" type="button" data-action="remove-key">Remove key</button>` : "<span></span>"}
          <button class="${APP_ID}-primary" type="button" data-action="save-key">Save and connect</button>
        </div>
      </div>`;
  }

  function render() {
    if (!panel) return;
    const items = filteredItems();
    const pageStart = state.total ? state.offset + 1 : 0;
    const pageEnd = Math.min(state.offset + state.items.length, state.total);
    const totalQuantity = items.reduce((sum, item) => sum + (Number(item.amount) || 0), 0);
    const hasPrevious = state.offset > 0;
    const hasNext = state.offset + state.items.length < state.total;
    const hasPagination = hasPrevious || hasNext;

    panel.classList.toggle("is-open", state.open);
    panel.setAttribute("aria-hidden", String(!state.open));

    if (state.settingsOpen) {
      panel.innerHTML = `
        <div class="${APP_ID}-shell ${APP_ID}-settings-shell">
          ${renderSettings()}
        </div>`;
      keyInput = panel.querySelector(`#${APP_ID}-key-input`);
      return;
    }

    panel.innerHTML = `
      <div class="${APP_ID}-shell">
        <header class="${APP_ID}-header">
          <div class="${APP_ID}-brand">
            <div class="${APP_ID}-mark" aria-hidden="true">T</div>
            <div>
              <span class="${APP_ID}-eyebrow">TRAVEL COMPANION</span>
              <div class="${APP_ID}-title">Personal Inventory</div>
            </div>
          </div>
          <div class="${APP_ID}-header-actions">
            <span class="${APP_ID}-readonly"><i></i> Read-only</span>
            <button class="${APP_ID}-icon-button ${APP_ID}-theme-button" type="button" data-action="theme" aria-label="${state.theme === "dark" ? "Use light interface" : "Use dark interface"}" title="${state.theme === "dark" ? "Use light interface" : "Use dark interface"}">${state.theme === "dark" ? "☀" : "☾"}</button>
            <button class="${APP_ID}-icon-button" type="button" data-action="settings" aria-label="API settings">⚙</button>
            <button class="${APP_ID}-icon-button" type="button" data-action="close" aria-label="Close inventory">×</button>
          </div>
        </header>

        <section class="${APP_ID}-toolbar">
          <label class="${APP_ID}-search">
            <span aria-hidden="true">⌕</span>
            <input type="search" placeholder="Search this category…" value="${escapeHtml(state.query)}" />
            <kbd>/</kbd>
          </label>
          <label class="${APP_ID}-category-control">
            <span class="${APP_ID}-sr-only">Item category</span>
            <select class="${APP_ID}-category-select" aria-label="Item category">
              ${renderCategoryOptions()}
            </select>
          </label>
          <button class="${APP_ID}-refresh" type="button" data-action="refresh" ${state.loading ? "disabled" : ""}>
            <span class="${state.loading ? "is-spinning" : ""}" aria-hidden="true">↻</span>
            Refresh
          </button>
        </section>

        <section class="${APP_ID}-status" aria-live="polite">
          <div>
            <strong>${escapeHtml(state.category)}</strong>
            <span>${state.loading ? "Loading inventory…" : `${formatNumber(items.length)} entries · ${formatNumber(totalQuantity)} items shown`}</span>
          </div>
          <div class="${APP_ID}-cache">
            <span>API snapshot</span>
            <strong>${formatTime(state.timestamp)}</strong>
          </div>
        </section>

        <main class="${APP_ID}-content">
          <div class="${APP_ID}-grid">${renderCards()}</div>
        </main>

        <footer class="${APP_ID}-footer">
          <span>
            ${state.total ? `Showing ${formatNumber(pageStart)}–${formatNumber(pageEnd)} of ${formatNumber(state.total)}` : "Official Torn API v2"}
            <small class="${APP_ID}-version">v${SCRIPT_VERSION} · cowboyup [1496324]</small>
          </span>
          ${
            hasPagination
              ? `<div class="${APP_ID}-pager" aria-label="Inventory pages">
                  <button type="button" data-action="previous" ${!hasPrevious || state.loading ? "disabled" : ""}>← Previous 250</button>
                  <button type="button" data-action="next" ${!hasNext || state.loading ? "disabled" : ""}>Next 250 →</button>
                </div>`
              : ""
          }
        </footer>
      </div>`;

    keyInput = panel.querySelector(`#${APP_ID}-key-input`);
  }

  function openPanel() {
    syncTheme();
    syncNativeControlStyle();
    state.open = true;
    document.documentElement.classList.add(`${APP_ID}-no-scroll`);
    render();
    if (!getApiKey()) {
      state.settingsOpen = true;
      render();
      setTimeout(() => keyInput?.focus(), 0);
    } else if (!state.items.length && !state.loading && !state.error) {
      loadInventory();
    }
  }

  function closePanel() {
    state.open = false;
    state.settingsOpen = false;
    document.documentElement.classList.remove(`${APP_ID}-no-scroll`);
    render();
  }

  function handleClick(event) {
    const target = event.target.closest("[data-action], [data-category]");
    if (!target) return;

    if (target.dataset.category) {
      state.category = target.dataset.category;
      state.offset = 0;
      state.query = "";
      state.items = [];
      state.total = 0;
      loadInventory();
      return;
    }

    switch (target.dataset.action) {
      case "close":
        closePanel();
        break;
      case "settings":
        state.settingsOpen = true;
        render();
        setTimeout(() => keyInput?.focus(), 0);
        break;
      case "theme":
        state.theme = state.theme === "dark" ? "light" : "dark";
        gmSet(THEME_STORE, state.theme);
        syncTheme();
        syncNativeControlStyle();
        render();
        break;
      case "close-settings":
        state.settingsOpen = false;
        render();
        break;
      case "reveal-key":
        if (keyInput) {
          keyInput.type = keyInput.type === "password" ? "text" : "password";
          target.textContent = keyInput.type === "password" ? "Show" : "Hide";
        }
        break;
      case "save-key": {
        const value = keyInput?.value.trim() || "";
        if (value.length < 8) {
          keyInput?.setCustomValidity("Please enter a valid Torn API key.");
          keyInput?.reportValidity();
          return;
        }
        keyInput?.setCustomValidity("");
        gmSet(KEY_STORE, value);
        state.settingsOpen = false;
        state.offset = 0;
        state.items = [];
        state.error = "";
        loadInventory();
        break;
      }
      case "remove-key":
        gmDelete(KEY_STORE);
        state.items = [];
        state.total = 0;
        state.timestamp = null;
        state.error = "";
        render();
        setTimeout(() => keyInput?.focus(), 0);
        break;
      case "refresh":
      case "retry":
        loadInventory({ force: true });
        break;
      case "previous":
        state.offset = Math.max(0, state.offset - PAGE_SIZE);
        state.query = "";
        loadInventory();
        break;
      case "next":
        state.offset += PAGE_SIZE;
        state.query = "";
        loadInventory();
        break;
      default:
        break;
    }
  }

  function installStyles() {
    const style = document.createElement("style");
    style.textContent = `
