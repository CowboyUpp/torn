        position: fixed;
        inset: 0;
        z-index: 2147483646;
        pointer-events: none;
        color: var(--tti-text);
        font-family: Inter, "Segoe UI", Arial, sans-serif;
      }
      .${APP_ID}-launcher {
        pointer-events: auto;
        position: fixed;
        right: max(18px, env(safe-area-inset-right));
        bottom: max(18px, env(safe-area-inset-bottom));
        display: flex;
        align-items: center;
        gap: 9px;
        min-height: 46px;
        padding: 0 17px 0 12px;
        border: 1px solid rgba(255,255,255,.16);
        border-radius: 8px;
        color: #fff;
        background: linear-gradient(145deg, #b52828, #8d1e1e);
        box-shadow: 0 9px 24px rgba(0,0,0,.36), inset 0 1px rgba(255,255,255,.12);
        cursor: pointer;
        font: 700 13px/1 Inter, "Segoe UI", sans-serif;
        letter-spacing: .02em;
        transition: transform .18s ease, filter .18s ease, box-shadow .18s ease;
      }
      .${APP_ID}-launcher:hover {
        transform: translateY(-2px);
        filter: brightness(1.1);
        box-shadow: 0 12px 28px rgba(0,0,0,.42), inset 0 1px rgba(255,255,255,.12);
      }
      .${APP_ID}-launcher:active { transform: translateY(0); }
      .${APP_ID}-launcher-icon {
        display: grid;
        place-items: center;
        width: 25px;
        height: 25px;
        border-radius: 5px;
        background: rgba(0,0,0,.22);
        font-size: 16px;
      }
      .${APP_ID}-panel {
        pointer-events: none;
        position: absolute;
        inset: 0;
        padding: clamp(8px, 2vw, 24px);
        display: grid;
        place-items: center;
        background: rgba(4,5,6,.74);
        backdrop-filter: blur(10px);
        opacity: 0;
        visibility: hidden;
        transition: opacity .22s ease, visibility .22s;
      }
      .${APP_ID}-panel.is-open {
        pointer-events: auto;
        opacity: 1;
        visibility: visible;
      }
      .${APP_ID}-shell {
        position: relative;
        display: flex;
        flex-direction: column;
        width: min(1180px, 100%);
        height: min(850px, calc(100vh - clamp(16px, 4vw, 48px)));
        max-height: 100%;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,.12);
        border-radius: 12px;
        background:
