    // ─── API fetch ───────────────────────────────────────────────────────────────

    async function fetchCarsFromApi(apiKey) {
        const url = `https://api.torn.com/user/?selections=properties&key=${apiKey}&comment=CarSorter`;
        const resp = await fetch(url);
        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
        const json = await resp.json();
        if (json.error) throw Object.assign(new Error(json.error.error), { code: json.error.code });
        return json;
    }

    function parseApiCars(json) {
        const props = json.properties;
        if (!props) return [];

        // properties is an object keyed by property ID
        // We only want type=car (type_id in racing car range)
        const cars = [];
        for (const [propId, prop] of Object.entries(props)) {
            if (!prop || prop.property_type !== 'Enlisted Car') continue;
            // item_id is the car model ID
            const itemId = String(prop.item_id || '');
            const carId  = String(propId); // unique property ID = stable key
            const tornModel   = CAR_NAMES[itemId] || prop.name || 'Unknown';
            const carClass    = CAR_CLASSES[itemId] || 'A';
            const imgSrc      = itemId ? `https://www.torn.com/images/items/${itemId}/large.png` : '';
            cars.push({ carId, itemId, tornModel, carClass, imgSrc, tornCustomName: prop.name || '' });
        }
        return cars;
    }

    // ─── DOM stat extraction (for current page cars only — fills in bar stats) ──

    function extractDomStats() {
        const map = {}; // carId → stats
        const items = [...document.querySelectorAll('ul.enlist-list > li')];
        for (const el of items) {
            const removeLink = el.querySelector('a.enlist-link.remove[id-value]');
            if (!removeLink) continue;
            const carId = removeLink.getAttribute('id-value');

            function getListedStat(keyword) {
                for (const li of el.querySelectorAll('ul.enlisted-stat > li')) {
                    const text = li.textContent;
                    if (text.toLowerCase().includes(keyword.toLowerCase())) {
                        const m = text.match(/:\s*([\d,]+(?:\.\d+)?)/);
                        if (m) return parseFloat(m[1].replace(/,/g, ''));
                    }
                }
                return null;
            }
            function getBarStat(labelText) {
                for (const li of el.querySelectorAll('ul.enlist-bars > li')) {
                    const title = li.querySelector('.title');
                    if (title && title.textContent.trim().toLowerCase() === labelText.toLowerCase()) {
                        const pbWrap = li.querySelector('.progressbar-wrap');
                        if (pbWrap) {
                            const t = pbWrap.getAttribute('title') || '';
                            const m = t.match(/^(\d+)/);
                            if (m) return parseInt(m[1], 10);
                        }
                    }
                }
                return null;
            }

            map[carId] = {
                topSpeedMph:  getListedStat('Top Speed'),
                zeroSixty:    getListedStat('0-60'),
                brakeDist:    getListedStat('Brake Dist'),
                upgrades:     getListedStat('Upgrades'),
                racesWon:     getListedStat('Races won'),
                racesEntered: getListedStat('Races entered'),
                winPct:       getListedStat('Win Percentage'),
                speedPts:     getBarStat('Top Speed'),
                accelPts:     getBarStat('Acceleration'),
                brakingPts:   getBarStat('Braking'),
                handlingPts:  getBarStat('Handling'),
                tornCustomName: (() => {
                    const el2 = el.querySelector('[class*="model-car-name-"]');
                    return el2 ? el2.textContent.trim() : '';
                })(),
            };
        }
        return map;
    }

