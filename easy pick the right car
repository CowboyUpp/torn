// Changelog:
// v1.4.0 - API-powered: fetches ALL cars via user→properties (Minimal Access key).
//          Pretty first-run setup UI with direct key-creation link (pre-selects correct
//          permissions). API key stored in GM storage, gear button to change it.
//          All cars shown in one grid, no pagination. Car data cached for 5 minutes.
//          Merged with DOM extraction as fallback for stat bars (points) not in API.
// v1.3.1 - Fix triple toolbar, fix 0-60 showing as 0s
// v1.3.0 - Complete DOM rewrite with confirmed selectors
// v1.2.0 - Nicknames
// v1.1.0 - Drag to reorder
// v1.0.0 - Initial release

(function () {
    'use strict';

    // ─── Constants ──────────────────────────────────────────────────────────────

    const CLASS_ORDER  = ['A', 'B', 'C', 'D', 'E'];
    const CLASS_COLORS = {
        A: '#ffd700', B: '#c0c0c0', C: '#4ca8ff', D: '#44cc44', E: '#888888',
    };
    const API_KEY_STORAGE   = 'tcs_api_key';
    const NICKNAMES_KEY     = 'tcs_nicknames';
    const CUSTOM_ORDER_KEY  = 'tcs_custom_order';
    const CACHE_KEY         = 'tcs_car_cache';
    const CACHE_TTL_MS      = 5 * 60 * 1000; // 5 minutes

    // Key creation URL — pre-selects user→properties (Minimal Access)
    const KEY_CREATE_URL = 'https://www.torn.com/preferences.php#tab=api?step=addNewKey&title=Car%20Sorter&user=properties';

    // ─── State ───────────────────────────────────────────────────────────────────

    let activeClass = 'ALL';
    let sortKey     = 'speedPts';
    let sortDir     = -1;
    let carData     = [];
    let customOrder = [];
    let nicknames   = {};
    let dragSrcIdx  = null;

    // ─── Storage ─────────────────────────────────────────────────────────────────

    const getApiKey      = ()  => GM_getValue(API_KEY_STORAGE, '');
    const setApiKey      = k   => GM_setValue(API_KEY_STORAGE, k.trim());
    const getNicknames   = ()  => { try { return JSON.parse(GM_getValue(NICKNAMES_KEY, '{}')); } catch (_) { return {}; } };
    const saveNicknames  = ()  => GM_setValue(NICKNAMES_KEY, JSON.stringify(nicknames));
    const getCustomOrder = ()  => { try { return JSON.parse(GM_getValue(CUSTOM_ORDER_KEY, '[]')); } catch (_) { return []; } };
    const saveCustomOrder = () => GM_setValue(CUSTOM_ORDER_KEY, JSON.stringify(customOrder));

    function getCachedCars() {
        try {
            const raw = GM_getValue(CACHE_KEY, null);
            if (!raw) return null;
            const { ts, data } = JSON.parse(raw);
            if (Date.now() - ts > CACHE_TTL_MS) return null;
            return data;
        } catch (_) { return null; }
    }
    function setCachedCars(data) {
        GM_setValue(CACHE_KEY, JSON.stringify({ ts: Date.now(), data }));
    }

