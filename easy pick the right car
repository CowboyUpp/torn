    // ─── Sorting ─────────────────────────────────────────────────────────────────

    function sortedVisible() {
        let list = activeClass === 'ALL'
            ? [...carData]
            : carData.filter(c => c.carClass === activeClass);

        if (sortKey === 'custom') {
            list.sort((a, b) => {
                const ia = customOrder.indexOf(a.carId);
                const ib = customOrder.indexOf(b.carId);
                if (ia === -1 && ib === -1) return 0;
                if (ia === -1) return 1;
                if (ib === -1) return -1;
                return ia - ib;
            });
        } else if (sortKey === 'class') {
            list.sort((a, b) => {
                const ca = CLASS_ORDER.indexOf(a.carClass);
                const cb = CLASS_ORDER.indexOf(b.carClass);
                return sortDir * (ca - cb) || a.tornModel.localeCompare(b.tornModel);
            });
        } else if (sortKey === 'name') {
            list.sort((a, b) => sortDir * a.tornModel.localeCompare(b.tornModel));
        } else {
            list.sort((a, b) => {
                const va = a[sortKey] ?? -Infinity;
                const vb = b[sortKey] ?? -Infinity;
                return sortDir * (vb - va);
            });
        }
        return list;
    }

    // ─── Drag & drop ─────────────────────────────────────────────────────────────

    function enableDrag(card, car, visibleList) {
        card.draggable = true;
        card.addEventListener('dragstart', e => {
            dragSrcIdx = visibleList.indexOf(car);
            card.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
        });
        card.addEventListener('dragend', () => {
            card.classList.remove('dragging');
            document.querySelectorAll('.tcs-car-card').forEach(c => c.classList.remove('drag-over'));
        });
        card.addEventListener('dragover', e => {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            card.classList.add('drag-over');
        });
        card.addEventListener('dragleave', () => card.classList.remove('drag-over'));
        card.addEventListener('drop', e => {
            e.preventDefault();
            card.classList.remove('drag-over');
            const destIdx = visibleList.indexOf(car);
            if (dragSrcIdx === null || dragSrcIdx === destIdx) return;
            const [moved] = visibleList.splice(dragSrcIdx, 1);
            visibleList.splice(destIdx, 0, moved);
            dragSrcIdx = destIdx;
            customOrder = visibleList.map(c => c.carId);
            saveCustomOrder();
            sortKey = 'custom';
            updateSortButtons();
            renderGrid();
        });
    }

    // ─── Render ──────────────────────────────────────────────────────────────────

    function updateSortButtons() {
        document.querySelectorAll('.tcs-sort-btn').forEach(b => {
            const active = b.dataset.sort === sortKey;
            b.classList.toggle('sort-active', active);
            const base = b.dataset.label;
            b.textContent = active && sortKey !== 'custom'
                ? base + (sortDir === -1 ? ' ↓' : ' ↑')
                : base;
        });
    }

    function renderGrid() {
        const grid   = document.getElementById('tcs-grid');
        const status = document.getElementById('tcs-status');
        if (!grid) return;

        const visible = sortedVisible();
        grid.innerHTML = '';

        visible.forEach(car => {
            const card = document.createElement('div');
            card.className = 'tcs-car-card' + (car.speedPts == null ? ' no-dom' : '');
            card.dataset.carId = car.carId;

            const badgeColor = CLASS_COLORS[car.carClass] || '#888';

            // Drag handle
            const handle = document.createElement('span');
            handle.className = 'tcs-drag-handle';
            handle.title = 'Drag to reorder';
            handle.textContent = '⠿';
            card.appendChild(handle);

            // Class badge
            const badge = document.createElement('span');
            badge.className = 'tcs-class-badge';
            badge.textContent = car.carClass;
            badge.style.cssText = `color:${badgeColor};border-color:${badgeColor}55;background:${badgeColor}0f;`;
            card.appendChild(badge);

            // Torn model name
            const modelEl = document.createElement('div');
            modelEl.className = 'tcs-torn-model';
            modelEl.textContent = car.tornModel;
            modelEl.title = car.tornModel;
            card.appendChild(modelEl);

            // Image
            if (car.imgSrc) {
                const img = document.createElement('img');
                img.className = 'tcs-car-img';
                img.src = car.imgSrc;
                img.alt = car.tornModel;
                card.appendChild(img);
            }

            // Nickname
            const nicknameEl = document.createElement('div');
            nicknameEl.className = 'tcs-nickname';
            nicknameEl.textContent = nicknames[car.carId] || car.tornCustomName || '—';
            nicknameEl.title = 'Click ✎ to set nickname';
            card.appendChild(nicknameEl);

            // Stats — bar stats if available (DOM page), text stats always
            const statsEl = document.createElement('div');
            statsEl.className = 'tcs-car-stats';

            const barDefs = [
                { key: 'speedPts',    label: 'Spd', color: '#ff9900' },
                { key: 'accelPts',    label: 'Acc', color: '#00cfff' },
                { key: 'brakingPts',  label: 'Brk', color: '#cc44ff' },
                { key: 'handlingPts', label: 'Hdl', color: '#44cc44' },
            ];

            let hasBarStats = false;
            barDefs.forEach(({ key, label, color }) => {
                const val = car[key];
                if (val == null) return;
                hasBarStats = true;

                const lbl = document.createElement('span');
                lbl.className = 'tcs-stat-label';
                lbl.textContent = label;

                const vWrap = document.createElement('div');
                vWrap.style.cssText = 'display:flex;align-items:center;gap:4px;';

                const vEl = document.createElement('span');
                vEl.className = 'tcs-stat-val' + (key === sortKey ? ' hl' : '');
                vEl.textContent = val;
                vEl.style.minWidth = '24px';

                const barWrap = document.createElement('div');
                barWrap.className = 'tcs-bar-wrap';
                const fill = document.createElement('div');
                fill.className = 'tcs-bar-fill';
                fill.style.cssText = `width:${Math.min(100, val / 120 * 100)}%;background:${color};`;
                barWrap.appendChild(fill);

                vWrap.appendChild(vEl);
                vWrap.appendChild(barWrap);
                statsEl.appendChild(lbl);
                statsEl.appendChild(vWrap);
            });

            // Text stats
            const textStats = [
                ['Speed',    car.topSpeedMph != null ? car.topSpeedMph + ' mph' : null],
                ['0-60',     car.zeroSixty   != null ? car.zeroSixty + 's'      : null],
                ['Upgrades', car.upgrades    != null ? String(car.upgrades)      : null],
                ['W%',       car.winPct      != null ? car.winPct + '%'          : null],
            ];
            textStats.forEach(([label, val]) => {
                if (val == null) return;
                const lbl = document.createElement('span');
                lbl.className = 'tcs-stat-label';
                lbl.textContent = label;
                const vEl = document.createElement('span');
                vEl.className = 'tcs-stat-val' + (
                    (label === 'Upgrades' && sortKey === 'upgrades') ||
                    (label === 'W%'       && sortKey === 'winPct')
                    ? ' hl' : '');
                vEl.textContent = val;
                statsEl.appendChild(lbl);
                statsEl.appendChild(vEl);
            });

            if (!hasBarStats && !textStats.some(([,v]) => v != null)) {
                const note = document.createElement('div');
                note.className = 'tcs-no-stats';
                note.textContent = 'Open Your Cars tab for stats';
                card.appendChild(note);
            } else {
                card.appendChild(statsEl);
            }

            // Click → select in Torn UI if DOM car exists
            card.addEventListener('click', e => {
                if (e.target === handle || e.target.classList.contains('tcs-edit-btn')) return;
                document.querySelectorAll('.tcs-car-card').forEach(c => c.classList.remove('selected'));
                card.classList.add('selected');
                if (car.el) {
                    const clickTarget = car.el.querySelector('input[type="radio"], a.enlist-link:not(.remove), button') || car.el;
                    clickTarget.click();
                }
            });

            // Edit nickname
            const editBtn = document.createElement('span');
            editBtn.className = 'tcs-edit-btn';
            editBtn.textContent = '✎';
            editBtn.title = 'Set nickname';
            editBtn.addEventListener('click', e => {
                e.stopPropagation();
                const input = document.createElement('input');
                input.type = 'text';
                input.className = 'tcs-nickname-input';
                input.value = nicknames[car.carId] || '';
                input.placeholder = 'Nickname…';
                input.maxLength = 22;
                nicknameEl.replaceWith(input);
                input.focus(); input.select();

                function commit() {
                    const val = input.value.trim();
                    if (val) nicknames[car.carId] = val;
                    else delete nicknames[car.carId];
                    saveNicknames();
                    nicknameEl.textContent = val || car.tornCustomName || '—';
                    input.replaceWith(nicknameEl);
                }
                input.addEventListener('blur', commit);
                input.addEventListener('keydown', ev => {
                    if (ev.key === 'Enter')  { ev.preventDefault(); input.blur(); }
                    if (ev.key === 'Escape') { input.value = nicknames[car.carId] || ''; input.blur(); }
                });
            });
            card.appendChild(editBtn);

            enableDrag(card, car, visible);
            grid.appendChild(card);
        });

        if (status) {
            const total = carData.length;
            const shown = visible.length;
            status.textContent = shown === total
                ? `${total} cars  ·  drag ⠿ to reorder  ·  click ✎ to nickname`
                : `${shown} of ${total} cars  ·  class filter active`;
        }
    }

    // ─── Setup UI ────────────────────────────────────────────────────────────────

    function showSetupUI(anchor, onSave) {
        const setup = document.createElement('div');
        setup.id = 'tcs-setup';
        setup.innerHTML = `
            <h2>🏎 Car Sorter — Setup</h2>
            <p>A Torn API key is needed to load all your cars at once.<br>
               Only <strong style="color:#ffd700;">Minimal Access</strong> is required —
               this key can only see your enlisted car list, nothing sensitive.</p>
            <ol class="tcs-setup-steps">
                <li>
                    <span class="tcs-step-num">1</span>
                    <span>Click the button below to open Torn's key creation page.
                    The correct permission (<code>properties</code>) is pre-selected for you.</span>
                </li>
                <li>
                    <span class="tcs-step-num">2</span>
                    <span>Give the key a name (e.g. <em>Car Sorter</em>), then click
                    <strong>Generate</strong>. Copy the key that appears.</span>
                </li>
                <li>
                    <span class="tcs-step-num">3</span>
                    <span>Paste it below and click <strong>Save</strong>.</span>
                </li>
            </ol>
            <a class="tcs-setup-link" href="${KEY_CREATE_URL}" target="_blank">
                🔑 Create API Key on Torn →
            </a>
            <div class="tcs-setup-input-row">
                <input id="tcs-api-input" type="password" placeholder="Paste your API key here…" autocomplete="off" spellcheck="false">
                <button id="tcs-api-save">Save</button>
            </div>
            <div id="tcs-setup-error"></div>
        `;

        anchor.parentNode.insertBefore(setup, anchor);
        anchor.style.display = 'none';

        document.getElementById('tcs-api-save').addEventListener('click', async () => {
            const key = document.getElementById('tcs-api-input').value.trim();
            const err = document.getElementById('tcs-setup-error');
            if (!key) { err.textContent = 'Please enter your API key.'; return; }
            err.textContent = '';
            document.getElementById('tcs-api-save').textContent = 'Checking…';
            try {
                await fetchCarsFromApi(key);
                setApiKey(key);
                setup.remove();
                anchor.style.display = '';
                onSave(key);
            } catch (e) {
                document.getElementById('tcs-api-save').textContent = 'Save';
                err.textContent = e.code === 2
                    ? 'Invalid key — please check and try again.'
                    : e.code === 16
                    ? 'Key doesn\'t have the right permissions. Make sure you selected "properties" when creating it.'
                    : `Error: ${e.message}`;
            }
        });
    }

    // ─── Main widget UI ──────────────────────────────────────────────────────────

    function buildWidget(anchor) {
        if (!document.getElementById('tcs-styles')) {
            const s = document.createElement('style');
            s.id = 'tcs-styles';
            s.textContent = STYLE;
            document.head.appendChild(s);
        }

        const wrapper = document.createElement('div');
        wrapper.id = 'tcs-wrapper';

        // Toolbar
        const toolbar = document.createElement('div');
        toolbar.id = 'tcs-toolbar';

        // Filter group
        const filterGroup = document.createElement('div');
        filterGroup.className = 'tcs-toolbar-group';
        const filterLabel = document.createElement('span');
        filterLabel.className = 'tcs-toolbar-label';
        filterLabel.textContent = 'Class:';
        filterGroup.appendChild(filterLabel);
        ['ALL', ...CLASS_ORDER].forEach(cls => {
            const btn = document.createElement('button');
            btn.className = 'tcs-btn' + (cls === activeClass ? ' active' : '');
            btn.dataset.class = cls;
            btn.textContent = cls;
            btn.addEventListener('click', () => {
                activeClass = cls;
                filterGroup.querySelectorAll('.tcs-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                renderGrid();
            });
            filterGroup.appendChild(btn);
        });

        // Sort group
        const sortGroup = document.createElement('div');
        sortGroup.className = 'tcs-toolbar-group';
        const sortLabel = document.createElement('span');
        sortLabel.className = 'tcs-toolbar-label';
        sortLabel.textContent = 'Sort:';
        sortGroup.appendChild(sortLabel);

        [
            { key: 'speedPts',    label: 'Speed'    },
            { key: 'accelPts',    label: 'Accel'    },
            { key: 'handlingPts', label: 'Handling' },
            { key: 'upgrades',    label: 'Upgrades' },
            { key: 'winPct',      label: 'Win%'     },
            { key: 'name',        label: 'Name'     },
            { key: 'class',       label: 'Class'    },
            { key: 'custom',      label: 'Custom'   },
        ].forEach(({ key, label }) => {
            const btn = document.createElement('button');
            btn.className = 'tcs-btn tcs-sort-btn' + (sortKey === key ? ' sort-active' : '');
            btn.dataset.sort  = key;
            btn.dataset.label = label;
            btn.textContent   = label + (sortKey === key && key !== 'custom' ? ' ↓' : '');
            btn.addEventListener('click', () => {
                if (sortKey === key && key !== 'custom') sortDir *= -1;
                else { sortKey = key; sortDir = -1; }
                updateSortButtons();
                renderGrid();
            });
            sortGroup.appendChild(btn);
        });

        // Gear button — change API key
        const gearBtn = document.createElement('button');
        gearBtn.className = 'tcs-gear-btn';
        gearBtn.title = 'Change API key';
        gearBtn.textContent = '⚙';
        gearBtn.addEventListener('click', () => {
            GM_setValue(API_KEY_STORAGE, '');
            wrapper.remove();
            document.querySelectorAll('ul.enlist-list').forEach(l => l.style.display = '');
            init();
        });

        const divider = document.createElement('div');
        divider.className = 'tcs-divider';

        toolbar.appendChild(filterGroup);
        toolbar.appendChild(divider);
        toolbar.appendChild(sortGroup);
        toolbar.appendChild(gearBtn);

        const grid = document.createElement('div');
        grid.id = 'tcs-grid';

        const status = document.createElement('div');
        status.id = 'tcs-status';

        wrapper.appendChild(toolbar);
        wrapper.appendChild(grid);
        wrapper.appendChild(status);

        anchor.parentNode.insertBefore(wrapper, anchor);
        anchor.style.display = 'none';
        document.querySelectorAll('ul.enlist-list').forEach(l => {
            if (l !== anchor) l.style.display = 'none';
        });
    }

    function showLoading(anchor) {
        const el = document.createElement('div');
        el.id = 'tcs-loading';
        el.innerHTML = '<div class="tcs-spinner"></div><span>Loading all your cars…</span>';
        anchor.parentNode.insertBefore(el, anchor);
        return el;
    }

    // ─── Init ────────────────────────────────────────────────────────────────────

    let _initTimer = null;

    async function init() {
        clearTimeout(_initTimer);
        _initTimer = setTimeout(async () => {
            const firstList = document.querySelector('ul.enlist-list');
            if (!firstList || document.getElementById('tcs-wrapper') || document.getElementById('tcs-setup') || document.getElementById('tcs-loading')) return;

            // Inject styles early
            if (!document.getElementById('tcs-styles')) {
                const s = document.createElement('style');
                s.id = 'tcs-styles';
                s.textContent = STYLE;
                document.head.appendChild(s);
            }

            const apiKey = getApiKey();
            if (!apiKey) {
                showSetupUI(firstList, async (key) => {
                    await loadAndRender(firstList, key);
                });
                return;
            }

            await loadAndRender(firstList, apiKey);
        }, 300);
    }

    async function loadAndRender(anchor, apiKey) {
        const loader = showLoading(anchor);
        anchor.style.display = 'none';

        try {
            // Try cache first
            let apiCars = getCachedCars();
            if (!apiCars) {
                const json = await fetchCarsFromApi(apiKey);
                apiCars = parseApiCars(json);
                setCachedCars(apiCars);
            }

            // Merge DOM stats for cars visible on current page
            const domStats = extractDomStats();
            carData = apiCars.map(car => {
                const dom = domStats[car.carId] || {};
                return { ...car, ...dom, el: findDomEl(car.carId) };
            });

            loader.remove();
            customOrder = getCustomOrder();
            nicknames   = getNicknames();

            buildWidget(anchor);
            renderGrid();

        } catch (e) {
            loader.remove();
            anchor.style.display = '';
            // If key error, clear and show setup again
            if (e.code === 2 || e.code === 16) {
                GM_setValue(API_KEY_STORAGE, '');
                showSetupUI(anchor, async (key) => {
                    await loadAndRender(anchor, key);
                });
            } else {
                const errEl = document.createElement('div');
                errEl.style.cssText = 'color:#ff6666;font-size:11px;padding:8px 0;';
                errEl.textContent = `Car Sorter error: ${e.message}. Reload to retry.`;
                anchor.parentNode.insertBefore(errEl, anchor);
            }
        }
    }

    function findDomEl(carId) {
        const items = document.querySelectorAll('ul.enlist-list > li');
        for (const el of items) {
            const link = el.querySelector(`a.enlist-link.remove[id-value="${carId}"]`);
            if (link) return el;
        }
        return null;
    }

    // ─── Observer ────────────────────────────────────────────────────────────────

    const observer = new MutationObserver(() => {
        const hasList   = !!document.querySelector('ul.enlist-list');
        const hasWidget = !!(document.getElementById('tcs-wrapper') || document.getElementById('tcs-setup') || document.getElementById('tcs-loading'));

        if (hasList && !hasWidget) init();

        if (!hasList) {
            clearTimeout(_initTimer);
            ['tcs-wrapper', 'tcs-setup', 'tcs-loading'].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.remove();
            });
        }
    });

    observer.observe(document.body, { childList: true, subtree: true });
    init();

})();
